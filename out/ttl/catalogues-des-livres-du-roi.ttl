<deb22e69-3907-4d35-9150-32a220da961d> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <8cbb77e5-55af-48f8-8fc8-269ee9fb54ae> ;
    crm:P141_assigned "Exemplaire réglé à l'encre rouge. D³ v° (2ᵉ partie) vierge et réglé. Annotation et <em>ex-libris</em> ms. sur la 2ᵉ garde volante : « Livre venu de Mesnil Garnier /par Emile Havel /et destiné a Marc Havel », signé « Havel 1922 ». Cachet bleu « BIBLIOTHEQUE CONSERVATION, Musée de Versailles ». Manquent la p. de titre, les f. 21/22, 39/40. Texte ms. au r° de la garde volante de la fin : <em>Congregati sunt</em>, de la main de Du Mont." ;
    crm:P14_carried_out_by <710d0c6e-48ed-47b6-b209-00520636d7be> ;
    crm:P177_assigned_property_type <7432ae29-7f76-4b3e-83eb-c548b874a480> .

