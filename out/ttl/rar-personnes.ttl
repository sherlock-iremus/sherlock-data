<78a3764d-530b-4cde-92e5-1279ae5b7311> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <329db659-22a5-447b-a14a-dd8f3f26a4b3> ;
    crm:P141_assigned "Un M. Paulin, « bénéficier de Notre-Dame », est mentionné à deux reprises dans le Mercure Galant de 1704, en tant qu'auteur d'un Te Deum en musique donné au couvent des Célestins le 6 juillet 1704 et à l’église des Augustins du faubourg Saint-Germain le 14 juillet, pour célébrer la naissance du duc de Bretagne, arrière-petit-fils de Louis XIV. Il est possible qu'il s'agisse de Frédéric-Hubert Paulin, auteur d'un recueil de motets (1705 ca) et d'airs sérieux et à boire (1705)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

