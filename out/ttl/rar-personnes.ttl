<aa65d78a-2ead-4d6a-b704-92f9c7ffcecb> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <114858fe-833e-443e-9634-d14bfda4ad31> ;
    crm:P141_assigned "Luis Antonio Tomás Fernández de Portocarreño, compte de Palma (1649-1723) fut viceroi de Catalogne. Il était neveu de Luis Manuel Fernández de Portocarrero-Bocanegra (1635-1709), cardinal de Portocarrero (sed. 1669-1709) (cf. https://es.qaz.wiki/wiki/Luis_Antonio_Tomas_de_Portocarrero, consulté le 10 février 2021)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<aab52b3a-bf2f-4501-8d9f-8d44fb7c5781> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <7344509a-6dcc-4aee-88da-d7c22e2edd5e> ;
    crm:P141_assigned "Jacques Cabassole (1671-?) était prêtre et maître de musique. Il a exercé aux Saint-Innocents de Paris entre 1698 et 1702, puis à la Cathédrale de Chartres entre 1702 et 1706 (cf. Hajdu Hayer, John. The Lure and Legacy of Music at Versailles. Louis XIV and the Aix School. Cambridge : Cambridge University Press, 2014, p. 107, 108)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

