<dd504107-0504-468e-9d14-cc40c5846fbf> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <83c2998b-9d94-4166-83f0-7d01933ae8bc> ;
    crm:P141_assigned "<p>D'apr&egrave;s Gilbert Rose, Mathieu Furdaux &eacute;tait ma&icirc;tre de musique et \"ma&icirc;tre de ch&oelig;ur\" de la cath&eacute;drale de Metz, d&eacute;j&agrave; en place en 1672, ann&eacute;e o&ugrave; il signa comme parrain au bapt&ecirc;me de Jeanne C&eacute;cile Brechon, fille d'un des musiciens de la cath&eacute;drale. Il &eacute;tait originaire de Verdun et mourut &agrave; Metz le 4 f&eacute;vrier 1688, &acirc;g&eacute; de 66 ans. Pr&ecirc;tre, il &eacute;tait b&eacute;n&eacute;ficier de l'autel Sainte-Catherine en l'&eacute;glise Sainte-Croix ; il &eacute;tait par ailleurs aum&ocirc;nier au parlement de Metz (cf. Gilbert Rose, <em>Metz et la Musique au XVIIIe si&egrave;cle,</em> 1992, p. 31).</p>" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<dd78be53-35a1-48ac-b1a4-e417af7761fe> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <5f10463c-e2cd-4b50-b411-f7d09d04b8e3> ;
    crm:P141_assigned "Collet (Jean-Baptiste) (1713-ap. 1779), inspecteur des Bâtiments du roi au département des Dehors de Versailles (1734-1748), contrôleur des Bâtiments du roi au département des châteaux de Blois et Chambord (1748-1773), contrôleur (1773-1776), puis inspecteur (1776-1779…) des Bâtiments du roi à Vincennes" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type she_ns:definition .

