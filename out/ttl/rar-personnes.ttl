<17c24e27-313d-4df6-a0e7-a2728b3a6781> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <544e00d1-3bea-4100-aaa9-03a935493fec> ;
    crm:P141_assigned "<p>G. Montbard a publi&eacute; en 1708 une estampe (Illustrissimus Ecclesiae Princeps D. D. Carolus Le Goux de la Berchere [&hellip;].). Il est mentionn&eacute; dans le Mercure galant d&rsquo;ao&ucirc;t 1710 en tant que graveur d&rsquo;une estampe d&rsquo;une cornaline antique du cabinet du roi (cf. MG-1710-08_074).</p>" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

