<c08310ed-03ef-416f-9d6d-8ef553468378> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <4c3ef283-87cb-447d-8a55-844b04035855> ;
    crm:P141_assigned "<p>Dans le <em>Mercure Galant</em> de mars 1705<em>, </em>le r&eacute;dacteur&nbsp;<em> </em>attribue les paroles d'un po&egrave;me qui sera mis en air &agrave; \"Mr. Chauveau de Chartes qui a donn&eacute; au Public deux Volumes d'histoires galantes &amp; comiques &amp; plusieurs petits contes en vers, qui ont est&eacute; bien re&ccedil;&ucirc;s.\"&nbsp;</p>" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

