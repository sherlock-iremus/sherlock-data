<f372a5cf-5893-4b7a-8d9e-b42feb698213> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <54c0e0eb-f7c0-4f52-b907-65c3c9d51725> ;
    crm:P141_assigned "« Jacques de Noailles, né le 3 novembre 1653, reçu chevalier de Malte le 14 août 1657, a été depuis bailly et commandant de Louvières, de Vaulemion de Bourdeaux, de Saint-Thomas de Trinquetaille en Provence, et de la Croie en Brie, lieutenant général des galères et des armées navalles du Roy ; fut nommé ambassadeur de Malte en France, par le grand-maître de cet ordre au mois de juin 1703 (mourut à Paris le 22 avril 1712 en sa 59e année et fut enterré en l’église cathédrale de Paris » (cf. L’histoire généalogique et chronologique de la Maison royale de France, des paris, grands officiers de al Couronne &amp; de la Maison du roi…., 3/ Paris, La Compagnie des Libraires, 1728, t. 4, p. 791, https://books.google.fr/books?id=Hv8IP37ZmjQC&amp;pg=PA791#v=onepage&amp;q&amp;f=false, consulté le 22 mars 2021). " ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
