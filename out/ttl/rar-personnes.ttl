<13b3a727-9d92-406a-9ccd-3c3873b48601> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <a69bf250-9e4b-44a7-a2eb-9590fa17c8ed> ;
    crm:P141_assigned "<p>M. Du Breuil de Vignancourt est l'auteur d'airs parus dans le <em>Nouveau Mercure</em> entre 1714 et 1716. D'apr&egrave;s la livraison de novembre 1714, M. du Breuil de Vignancourt &eacute;tait un \"digne &eacute;l&egrave;ve du fameux Lambert\" (cf. MG-1714-11_345). Un commentaire de Dusfresny dans le <em>Mercure </em>de novembre 1715 (cf. MG-1715-11_090) permet de lui attribuer un air sign&eacute; sous le pseudonyme \"Amoureux o&iuml;sif des bords de Marne\" : il indique en effet que sous ce pseudonyme se cache l'auteur du po&egrave;me et de la musique, et accompagne cet air de sa partition grav&eacute;e portant le nom de \"De Bre&uuml;il de Vignancourt\".</p>" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

