<90e9233f-20e8-43dc-8916-4932cf7d235d> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <5ff6c7e0-f35a-4dec-8cda-c246c76cee3f> ;
    crm:P141_assigned "<p>Rabiet d'Antespine est l'auteur des paroles d'un air publi&eacute; dans le <em>Mercure Galant </em>en janvier 1691 (cf. MG-1691-01_332).</p>" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<9114169d-3a7f-465f-bd61-e9bfe043a583> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <f760ab70-c8f9-45f8-8da4-a977c26067eb> ;
    crm:P141_assigned "Le Mercure galant fait mention en juillet 1704 d'un comte de la Bretesche, frère du marquis de la Bretesche, lieutenant général des Armées du Roy. L'arbre généalogique présentant plusieurs frères, le comte est difficilement identifiable sans informations complémentaires." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<911746c9-20ce-4f60-81f8-3fa1c1086dd8> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <2a655236-ee99-4ab8-93a8-77fb53969c58> ;
    crm:P141_assigned "La Houssaye (Félix Le Pelletier de) (1663-1723), conseiller au Châtelet de Paris (1682-1687), conseiller au parlement de Paris (1687-1690), maître des requêtes de l'Hôtel du roi (1690…), intendant de Soissons (1694-1698), de Montauban (1698-1699), d'Alsace (1699-1715), maître des requêtes honoraire (1707…), conseiller d'État semestre (1708…), conseiller au Conseil des Finances de la Régence (1715…), conseiller d'État ordinaire (1719…), directeur du département des Fermes Générales (1720…), contrôleur général des finances (1720-1721), prévôt et maître des cérémonies commandeur de l'ordre du Saint-Esprit (03/1721-06/1721)" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type she_ns:definition .

<9122436a-622c-4061-a07d-6cf913a69642> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <e285284d-2a74-4b20-87a2-cf74f5057799> ;
    crm:P141_assigned "Alexandre Maître (1650-1715), marquis de Bay, “servait depuis 1702 dans les troupes espagnoles et était lieutenant général et capitaine général des deux Castilles ; Phillipe V lui avait donné la Toison d’Or en 1707” (cf. Mémoires du chevalier de Quincy. III. 1710-1713, Paris: Société de l’histoire de France, 1901, p. 37). " ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

