    crm:P141_assigned "<p>D'apr&egrave;s le <em>Mercure galant</em>, M. Loyseau &eacute;tait organiste de Saint-Martin de Tours (cf. MG-<span data-sheets-formula-bar-text-style=\"font-size:13px;color:#000000;font-weight:normal;text-decoration:none;font-family:'docs-Helvetica';font-style:normal;text-decoration-skip-ink:none;\">1679-01_077</span>).</p>" ;
