<34794a1e-840d-4c6f-8763-c6d4622a4a1a> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <2d16ca0e-2698-4e2f-bd1f-cb27cb723bc3> ;
    crm:P141_assigned "<p>Dans la notice de la SIEFAR consacr&eacute;e &agrave; Fran&ccedil;oise Pascale (<a title=\"\" href=\"http://siefar.org/dictionnaire/fr/Fran%C3%A7oise_Pascal\" target=\"_blank\" rel=\"noopener\">http://siefar.org/dictionnaire/fr/Fran%C3%A7oise_Pascal</a>), Deborah Steinberger pr&eacute;cise qu'il est possible que lui soient attribu&eacute;es des paroles d'airs : \"A. &Eacute;vain a trouv&eacute; mention d&rsquo;une pastorale musicale en cinq actes, non publi&eacute;e, mais pr&eacute;sent&eacute;e aux Appartements &agrave; Versailles en 1686, dont les paroles seraient de &laquo; Mlle Pascal &raquo;. Et, en 1688, para&icirc;t dans le <em>Mercure galant</em> une chanson compos&eacute;e par le ma&icirc;tre de choeur de l&rsquo;h&ocirc;tel de Guise, dont les paroles (profanes) sont &eacute;galement sign&eacute;es de &laquo; Mlle Pascal &raquo;. On ignore la date de sa mort, mais, selon Vertron, l&rsquo;autrice vit encore en 1698.\"</p>" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

