<1df2ddf5-6120-4deb-8ddb-8412dea9814d> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <32089b24-0a8c-4778-abfe-c082a13b2c6f> ;
    crm:P141_assigned "Joseph l’Espinay a été le curé de Sceaux de 1700 à 1716, d’après Michel Charaire (cf. Histoire de la ville de Sceaux depuis son origine jusqu'à nos jours, Sceaux, Charaire, Paris, Picard,1883, p. 515 (cf. https://gallica.bnf.fr/ark:/12148/bpt6k6527179v/f570.item, consulté le 21 avril 2021)." ;
