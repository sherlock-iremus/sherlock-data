<d6030781-cb20-4e24-af19-d7c74b260c17> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <a2cce19f-13e4-49ff-ab8a-c9d4797ef406> ;
    crm:P141_assigned "La Baume (Louis-Honoré Raibaud de) (?-?), gentilhomme servant du roi (…1698-1708…)" ;
