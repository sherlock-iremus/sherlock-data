    crm:P140_assigned_attribute_to <53d108ef-922e-4c69-9f5c-2b68976e248c> ;
    crm:P141_assigned "Notes: Madame de Middleton est mentionnée dans le Mercure galant comme participante à une fête organisée par Louis XIV à Versailles et où la cour d’Angleterre exilée à Saint-Germain-en-Laye participe. Il peut s’agir de Catherine Brudenell, comtesse de Middleton (cf. <a href= https://www.npg.org.uk/collections/search/portrait/mw139850/Catherine-ne-Brudenell-Countess-of-Middleton  rel= noopener noreferrer  target= _blank >https://www.npg.org.uk/collections/search/portrait/mw139850/Catherine-ne-Brudenell-Countess-of-Middleton</a>, consulté le 2 avril 2021), épouse du comte de Middleton (cf. <a href= https://fr.nipponkaigi.net/wiki/Charles_Middleton,_2nd_Earl_of_Middleton  rel= noopener noreferrer  target= _blank >https://fr.nipponkaigi.net/wiki/Charles_Middleton,_2nd_Earl_of_Middleton</a>, consulté le 2 avril 2021)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

