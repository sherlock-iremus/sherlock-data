<d52b9713-b0db-4fb8-bb84-3442ef9f84b1> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <ad07a209-6696-47ae-8a5b-a1e6a7b55b97> ;
    crm:P141_assigned "Arnaud Laborie, prêtre, était membre de l'Académie des Jeux floraux de Toulouse où il a été Maître entre 1679 et 1702. Il fut lauréat en 1672 (pris de l'Églantine), 1676 (prix du Souci) et 1679 (prix de la Violette) (cf. François de Gélis, Histoire critique des jeux floraux depuis leur origine jusqu'à leur transformation en Académie (1323-1694), Toulouse, E. Privat, 1912, p. 157, 284, 316-318) ." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

