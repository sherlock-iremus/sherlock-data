<587a5113-d3bd-4a3b-828a-6cec0f4e920a> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <35b0da01-6f9a-4a1a-9d4d-ea03a475defa> ;
    crm:P141_assigned "Luiggi Sampieri était le fils du marquis Filippo Maria Sampieri et de Costanza Scappi (pour un arbre de la famille, cf. http://badigit.comune.bologna.it/books/sol/mostratalon/pannello%201%20albero%20SAMPIERI%20.pdf)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<58a4f48d-c445-48f9-a6fd-fef3e5615728> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <48208206-5419-4ebc-a2ba-f08d56ba517d> ;
    crm:P141_assigned "Paul-Joseph Douradou de Cambefort a été curé de Notre-Dame-de-Bonne-Nouvelles depuis 1696 à sa mort en 1722, et abbé commendataire de Saint-Pierre de Maurs, du diocèse de Saint-Flour (cf. Ségolène Dainville-Barbiche, «Prosopographie des curés de Paris (1695-1789)», dans Devenir curé à Paris.Institutions et carrières ecclésiastiques (1695-1789), sous la direction deSégolènede  Dainville-Barbiche. Paris cedex 14, Presses Universitaires de France, «Le Noeud Gordien», 2005, p. 425-511. URL : <a href= https://www.cairn.info/devenir-cure-a-paris--9782130543404-page-425.htm  rel= noopener noreferrer  target= _blank >https://www.cairn.info/devenir-cure-a-paris--9782130543404-page-425.htm</a>)" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<58bcf05d-6f1b-4191-b579-68c22ffb33a3> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <184da222-2136-4aee-8837-246cf6a70c6a> ;
    crm:P141_assigned "<p>D'apr&egrave;s le Mercure galant, M. Labb&eacute;, a &eacute;t&eacute; successivement ma&icirc;tre de musique &agrave; Saint-Jacques de Dieppe (1678-1679) puis ma&icirc;tre de musique de Ca&euml;n (1679), avant de s'&eacute;tablir &agrave; Rouen \"comme un homme rare &amp; qui passe pour un des plus habiles Musiciens du Royaume, non seulement pour l'Art de composer, mais aussi pour la belle m&eacute;tode du Chant, qu'il enseigne &agrave; tout ce qu'il y a de Personnes de qualit&eacute; dans la Ville\" (cf. MG-1686-11_070b). Il se serait form&eacute; aupr&egrave;s des meilleurs ma&icirc;tres de Paris et aupr&egrave;s de Bacilly lors d'un passage de ce dernier en Normandie (cf. MG-1687-09_350).</p>" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<58c1364c-ddc4-4188-96e1-9600f795b3d8> a crm:E13_Attribute_Assignement ;
