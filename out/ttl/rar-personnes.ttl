<21f50fe4-519d-491b-8a33-dbb6d1624531> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <114858fe-833e-443e-9634-d14bfda4ad31> ;
    crm:P141_assigned "Luis Antonio Tomás Fernández de Portocarreño, compte de Palma (1649-1723) fut viceroi de Catalogne. Il était neveu de Luis Manuel Fernández de Portocarrero-Bocanegra (1635-1709), cardinal de Portocarrero (sed. 1669-1709) (cf. https://es.qaz.wiki/wiki/Luis_Antonio_Tomas_de_Portocarrero, consulté le 10 février 2021)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

