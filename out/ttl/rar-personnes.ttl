<b2633de4-b71d-40df-a2dd-9d7e5cd58320> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <249daaa4-d418-44cf-8c86-c0d19bc1d7e0> ;
    crm:P141_assigned "En 1675, Marguerite de Quibly succéda sa tante homonyme en tant qu’abbesse à l’abbaye de la Déserte à Lyon (cf. https://gallica.bnf.fr/ark:/12148/bpt6k5819645n/f138.item.r=%22marguerite%20de%20quibly%22, consulté le 23 avril 2021). En 1732, elle fut succédée par Antoinette de Châtillon, cependant, le Mercure galant signale en 1710 que “Me de Châtillon” était abbesse de la Déserte, formulant ainsi une erreur dans l’identification de cette personne." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<b289bafd-8bb3-4e65-9b5e-4e01d36d248a> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <2967fbca-0881-4be2-b151-65790007d29f> ;
    crm:P141_assigned "Nicolas de Malézieu (1650-1727) était chancelier de Dombes, précepteur du duc de Maine, secrétaire général des Suisses et Grisons de France, membre de l'Académie des sciences (élu en 1699) et de l'Académie française (élu en 1701)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<b2b32146-16d2-476c-8cc4-d6b4dbd09b1b> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <0b8cc125-2ddf-483c-bb74-0e51e3c242b5> ;
    crm:P141_assigned "Jacques de Vaux a été premier président de la chambre de comptes de l’élection de Nevers (cf. Le Bayer, Jacques. <span style= color: rgb(51, 51, 51); >Mémoire de la généralité de Moulins, Moulins : L. Grégoire, 1906, p. 121)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

