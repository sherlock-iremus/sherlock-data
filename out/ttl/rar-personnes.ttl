<3667aeef-4b49-4d32-9969-3139d8481468> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <d3cf1a9c-a77f-417c-9886-8fb43e34f65a> ;
    crm:P141_assigned "Claude Philippe Auburtin fut «reçut avocat au Parlement de Metz le 12 septembre 1678. Il fut maire alternatif de Metz en 1707-1712 et 1720-1738 (cf. Étienne Broglin, Dictionnaire biographique sur les pensionnaires de l'académie royale de Juilly (1651-1828) Tome I, 2017, p. 533, consultable en ligne <a href= https://www.geneanet.org/archives/ouvrages?action=detail&amp;amp;livre_id=14915305&amp;amp;page=533&amp;amp;book_type=livre&amp;amp;name=BIONVILLE&amp;amp;tk=1f03c8c157c16808  rel= noopener noreferrer  target= _blank >https://www.geneanet.org/archives/ouvrages?action=detail&amp;amp;livre_id=14915305&amp;amp;page=533&amp;amp;book_type=livre&amp;amp;name=BIONVILLE&amp;amp;tk=1f03c8c157c16808</a>, consulté le 1 avril 2021)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

