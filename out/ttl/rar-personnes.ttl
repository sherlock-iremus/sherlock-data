<7d052d6e-b255-48ce-8fc9-bddfd2e988d2> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <2982f6b4-0f40-43e3-a0a9-3154ff757aae> ;
    crm:P141_assigned "Joseph Fabre était  banquier et armateur marseillais, mais aussi trésorier de la Marine, ambassadeur de France au Levant, agent du comté de Savoie, délégué de la ville au Conseil du commerce du roi  (cf. Faïence et Porcelaine de Marseille, XVIIe-XVIIIe siècles - Collections du Musée de la Faïence de Marseille, RMN, 1997, p. 15). Il est également l'un des fondateurs de la Compagnie de la Méditerranée en 1685." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<7d0d2bfb-c42f-417d-a66c-2b66451dfc4f> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <f1e4e7db-6342-4d27-909d-74ce092c90ed> ;
    crm:P141_assigned "Jean-Baptiste Sabatini était peintre de la ville de Nevers.  Il travaille parallèlement pour divers châteaux, églises ou hôtels particuliers des environs (église de Parigny-les-Vaux, 1689). Il semble s’être installé définitivement à Nevers, puis à Bourges  (cf. https://www.academie-sabl-dijon.org/celebration/deces-de-jean-baptiste-battista-sabatini-peintre/, consulté le 15 juin 2021)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<7d12c6cd-1aba-431f-bd4e-73160c16cea7> a crm:E13_Attribute_Assignement ;
