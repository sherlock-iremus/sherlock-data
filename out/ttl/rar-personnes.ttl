<a7fdfa62-5969-40ef-951e-9c9fa4da636b> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <7265f98f-e651-4668-948e-d2ee761d95d6> ;
    crm:P141_assigned "Francisco Antonio marquis d'Eguaras y Pasquier (fl. 1701) fut envoyé extraordinaire, “désigné en juillet 1701 pour aller à la cour de France de la part de Philippe V présenter ses compliments de condoléance au Roi au sujet de la mort de Monsieur, duc d'Orléans, son frère”." ;
