<52898d58-0b23-42ad-8d38-79928784423c> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <d84b06d5-8000-43b6-a732-2aa90683d8c6> ;
    crm:P141_assigned "Joseph de Fontanès de Chemé-La Vallette (1673-1759) fut chanoine-comte de Lyon. Il était le neveu de Claude de Saint-Georges, Archevêque de Lyon (cf. Vicomte de Montravel, « Fontanès », Revue historique, archéologique, littéraire et pittoresque du Vivarais illustrée, Paris, Dumont, Lyon, Brun fils, Privas, Imprimerie centrale, 1907, t. XV, n° 7, p. 325 ; https://gallica.bnf.fr/ark:/12148/bpt6k9770351s, consulté le 23 avril 2021)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

