<ec8623c3-4371-45b1-b917-9c9f4084d3c4> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <d43150b4-7c7a-4444-868e-d8aa7fbac7e6> ;
    crm:P141_assigned """<p>Marie-Gatienne Bacilly, ni&egrave;ce de Bertrand de Bacilly, &eacute;pousa le chanteur Jean Daniel qui reprit en 1678 la clientelle de Bertand de Bacilly (cf. L. Guillo et F. Michel,&laquo; Nouveaux documents sur le ma&icirc;tre de chant Bertrand de Bacilly (1621-1690) &raquo;, <em>Revue de musicologie</em>, 97/2 (2011), p. 269-327).</p>
<p>.</p>""" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<ec89d72e-e758-4865-826a-9563a5957435> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <0edc62b8-0ae2-4384-8f81-3c23fec9d98b> ;
    crm:P141_assigned "Ferrand (François-Antoine) (1657-1731), conseiller au Châtelet (1677…), lieutenant particulier au Châtelet (1683…), maître des requêtes de l'hôtel du roi (1690-1718…), intendant de Bourgogne (1694-1705), intendant de Bretagne (1705-1716), conseiller au conseil du commerce (1716…), conseiller au conseil de la Marine (…1718…), conseiller d'État (1719…), maître des requêtes honoraire (…1722-1727…), conseiller d'État ordinaire (1728…)" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type she_ns:definition .

<ec8b8dc7-4211-48c4-8dae-44e7f467d085> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <54f88894-a50c-470d-bcd4-00f948bb7da8> ;
    crm:P141_assigned "<p>M. Capus, \"Maistre de Musique fort estim&eacute;, &amp; &eacute;tably &agrave; Dijon\", composa la musique d'un air paru dans le Mercure galant de septembre 1690 (cf. MG-1690-09_111).</p>" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
