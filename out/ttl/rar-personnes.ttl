<b91548e8-5e4b-4dd8-9351-61f1738034bf> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <a8a1b119-358f-4e75-abc2-adb9b396b31c> ;
    crm:P141_assigned "M. Puget,  de Berance  est l'auteur d'une ode publiée dans le Mercure galant en avril 1702 (MG-1702-04_282). Nous n'avons pas pu identifier avec certitude la ville où il réside à cette date. Peut-être s'agit-il de Cérance, dans l'évêché de Coutances (gouvernement de Normandie), à peu de distance de la Bérence, affluent de la Sienne." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

