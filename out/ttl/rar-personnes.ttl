    crm:P140_assigned_attribute_to <bdf7a9b6-b37d-49b1-86d1-94e85f7cf63b> ;
    crm:P141_assigned "D’après la thèse de Juan Antonio López Anguita intitulée “Pouvoir et influence politique d'une reine d'Espagne lors de la Guerre de Succession : Marie-Louise Gabrielle de Savoie, première épouse de Philippe V”, Madame de Noyers (?-1720) était gouvernante de Marie-Louise, reine d’Espagne (cf. https://core.ac.uk/download/pdf/33108544.pdf, consulté le 4 février 2021). En 1655, elle épousa François Rey, baron de Noyers." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

