<577c2498-5f46-4198-8d1b-b7e566fa5dbd> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <7a8c0a9f-2775-4a11-b329-88d468917b91> ;
    crm:P141_assigned "Claude-Marie de Saint Georges (1677-?), chanoine-comte de Saint-Jean de Lyon (1697), était le neveu de Claude de Saint-Georges, Archevêque de Lyon. Il fut “précenteur de l’église de Lyon” (cf. Journal Historique sur les Matières du Tems, Tome VI, Paris : Étienne Ganeau, 1719, p. 155)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

