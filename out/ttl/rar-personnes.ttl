<b4c3ae1c-fc66-4aba-a6bc-45acdf784665> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <21459ec3-8849-4a0d-a2e2-5ae8aa893bb4> ;
    crm:P141_assigned "<p>M. No&euml;l &eacute;tait compositeur &agrave; Paris. Il a publi&eacute; un recueil de motets en 1687.</p>" ;
