<2652ea51-5241-4230-8637-e3a2ea887660> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <dcbf5c95-5ec8-41e6-b71b-45dec763548e> ;
    crm:P141_assigned "<p>M. Chesnon est l'auteur des paroles d'un air publi&eacute; dans le <em>Mercure Galant </em>de janvier 1679 (cf. MG-1679-01_077) et de celles d'un air publi&eacute; dans le <em>Mercure galant </em>de mars 1684 (cf. 1684-03_348). Les deux articles pr&eacute;cisent qu'il est originaire de Tours.</p>" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

