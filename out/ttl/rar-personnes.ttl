<336d0fac-8964-42a8-b26e-20f8edac551f> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <57281046-da03-4987-998e-6ec4a8a5589c> ;
    crm:P141_assigned "<p>M. de Rochebrune est l'auteur des paroles d'un air publi&eacute; dans le <em>Mercure Galant</em> en janvier 1717. Peut-&ecirc;tre s'agit-il de Claude Gu&eacute;rin de Rochebrune (1660-1719), polygraphe et parolier dont Voltaire disait &ecirc;tre le fils ill&eacute;gitime (Pearson, <em>Voltaire almighty </em>..., 2005, p. 9).</p>" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<337f6e76-6f97-403d-a5cc-3741f65aabbf> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <18c4fe2c-4450-4513-b305-2a45ec16af38> ;
    crm:P141_assigned "Le père jésuite Joseph Mahoudeau a remporté le prix de l'ode française décerné à Caen en février 1702. Son ode est publiée dans le Mercure galant du même mois (MG-1702-02_251). D'après ce périodique, Mahoudeau a également remporté le prix de l'épigramme latine dont un exemplaire publié à Caen en 1702 est conservé à la BnF (https://catalogue.bnf.fr/ark:/12148/cb308600558)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

