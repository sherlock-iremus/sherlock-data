<ec338e9b-145a-40a9-8ec4-ed610f609ea4> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <eb9ce2bd-fc6d-41b8-9e8d-47f6930d4f0c> ;
    crm:P141_assigned "Giuseppe Tortoriti fut acteur et membre de la Comédie Italienne (1683-1697). Il était connu pour son rôle de Pascariel (cf. Guy Boquet,  Les Comédiens Italiens à Paris au temps de Louis XIV , dans Revue d’histoire moderne et contemporaine, tome 26 N°3, Juillet-septembre 1979. pp. 422-438 ; https://www.persee.fr/doc/rhmc_0048-8003_1979_num_26_3_1065)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<ec56de41-414f-4883-9fb1-a7fb9df1050a> a crm:E13_Attribute_Assignement ;
