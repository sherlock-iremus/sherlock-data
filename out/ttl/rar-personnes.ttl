<b4d382fd-d2f2-483c-91e6-938052c324b1> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <57281046-da03-4987-998e-6ec4a8a5589c> ;
    crm:P141_assigned "<p>M. de Rochebrune est l'auteur des paroles d'un air publi&eacute; dans le <em>Mercure Galant</em> en janvier 1717. Peut-&ecirc;tre s'agit-il de Claude Gu&eacute;rin de Rochebrune (1660-1719), polygraphe et parolier dont Voltaire disait &ecirc;tre le fils ill&eacute;gitime (Pearson, <em>Voltaire almighty </em>..., 2005, p. 9).</p>" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

