<d7474f94-e184-4d34-b522-22a57c928130> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <634ed06e-ff44-4c56-8632-dba32b38db37> ;
    crm:P141_assigned "<p>Nicolas Montailly est un compositeur et ma&icirc;tre de musique fran&ccedil;ais actif &agrave; Paris dans le dernier quart du <abbr class=\"abbr\" title=\"17ᵉ si&egrave;cle\"><span class=\"romain\">XVII</span><sup style=\"font-size: 72%;\">e</sup></abbr>&nbsp;si&egrave;cle et le premier du <abbr class=\"abbr\" title=\"18ᵉ si&egrave;cle\"><span class=\"romain\">XVIII</span><sup style=\"font-size: 72%;\">e</sup></abbr>. Il est l'auteur de nombreux airs dont vingt-deux parurent dans le <em>Mercure galant</em> entre 1688 et 1708.</p>" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

