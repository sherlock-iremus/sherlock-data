<8f3f2191-4d3a-4ef2-84f2-a1657b3e58f2> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <127c5a91-1c1a-4944-80ea-f8c555664bf1> ;
    crm:P141_assigned "<p>F. Lach&egrave;vre (t. III, p. 320) attribue quatre chansons &agrave; boire &agrave; un Dubuisson, &agrave; propos duquel il pr&eacute;cise \"Ce Du Buisson ne serait-il pas le capitaine tour &agrave; tour au service de la Hollande et de la France, officier distingu&eacute; et &eacute;crivain &eacute;l&eacute;gant, &agrave; qui M. Albert Waddington, professeur &agrave; la Facult&eacute; des Lettres de l'Universit&eacute; de Lyon, attribue les \"M&eacute;moires de Hollande\" ? Du Buisson est l'auteur d'une vie de Turenne publi&eacute;e en 1685.\" (t. III, p. 320)</p>" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

