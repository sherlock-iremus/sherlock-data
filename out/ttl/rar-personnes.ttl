<38ac1a7b-4339-4771-bff7-439ac2136344> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <4689332c-e034-4bd6-8280-0d5b3faa9146> ;
    crm:P141_assigned "<p>M. de Monbrun est l'auteur des paroles d'airs publi&eacute;s dans le <em>Mercure Galant</em> d'octobre 1681 (cf. MG-1681-10_125 ; MG-1681-10_375) et janvier 1682 (MG-1682-01_275). Le <em>Mercure Galant </em>d'octobre 1681 pr&eacute;cise qu'il est conseiller au Parlement de Toulouse. </p>" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<38e4f39c-77b1-4c12-93e1-9440ba342945> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <816bf254-08f6-4c59-9cb1-d91d2a533ad9> ;
    crm:P141_assigned "<p>M. Pageau est l'auteur des paroles d'un air publi&eacute; dans le <em>Mercure Galant </em>d'ao&ucirc;t 1679 (cf. MG-1679-08_362). Dans sa pr&eacute;sentation de l'air, le r&eacute;dacteur du <em>Mercure </em>pr&eacute;cise que M. Pageau est avocat au Parlement.&nbsp;</p>" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

