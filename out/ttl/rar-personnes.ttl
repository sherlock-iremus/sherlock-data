<6e61ce77-0fb5-4b44-9f4e-ded895626a63> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <b041a97e-ce2b-481b-ac6d-7e426fdb61a3> ;
    crm:P141_assigned "Michel Bourayne a été «Maître des maçons de Chartres et voyer, entrepreneur  Capitaine des chevaliers du Vidame de Chartres, Premier échevin de Chartres (1710), Receveur du domaine du duché de Chartres (1710)» (cf. <a href= https://gw.geneanet.org/favrejhas?lang=fr&amp;n=bourayne&amp;p=michel  rel= noopener noreferrer  target= _blank >https://gw.geneanet.org/favrejhas?lang=fr&amp;n=bourayne&amp;p=michel</a>, consulté le 1 avril 2021)." ;
