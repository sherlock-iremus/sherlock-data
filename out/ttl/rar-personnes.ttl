<8bcefdda-e34a-4c2b-ad37-256a9af7ef21> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <38e261c2-b8ff-4925-baee-ff3852997acf> ;
    crm:P141_assigned "<p>M. Champenois, ma&icirc;tre de musique, composa la musique d'un air publi&eacute; dans la premi&egrave;re partie du Mercure galant de novembre 1688 (cf. MG-1688-11a_213).</p>" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<8bfeed2a-6d3d-49d6-bcb3-c54ff5971559> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <86788459-98b8-4428-b6c6-7560b43cc2e9> ;
    crm:P141_assigned "<p>D'apr&egrave;s le Mercure galant, M. Daches, auteur d'une gavotte et d'un menuet parus dans le p&eacute;riodique, &eacute;tait &laquo; de la musique du roi &raquo; (cf. MG-1684-02_234). Il ne figure cependant pas dans les effectifs de la Musique du roi donn&eacute;s pas les &Eacute;tat de la France.</p>" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

