<38a61d09-426b-40cf-bec1-b25a06173bab> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <d90f0b6c-1187-4134-bc11-26fd8887b566> ;
    crm:P141_assigned "Jacques Leullier (fl. 1693-1723) était curé de Saint-Louis-en-l'Île depuis 1693. Il résigne sa cure vers 1723 à Jacques Robbe, son neveu (cf. de Dainville-Barbiche, Ségolène. « Prosopographie des curés de Paris (1695-1789) », Devenir curé à Paris. Institutions et carrières ecclésiastiques (1695-1789), sous la direction de de Dainville-Barbiche Ségolène. Presses Universitaires de France, 2005, p. 485). " ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

