    crm:P141_assigned "<p>M. Vaudry est l'auteur d'un air paru dans le <em>Mercure galant</em> en 1699 (cf. MG-<span data-sheets-formula-bar-text-style=\"font-size:13px;color:#000000;font-weight:normal;text-decoration:none;font-family:'docs-Helvetica';font-style:normal;text-decoration-skip-ink:none;\">1699-03_105</span>).</p>" ;
