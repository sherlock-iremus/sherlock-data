<908c82fd-5433-4976-a21c-69227950367d> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <9e647a56-85ec-4f5f-b81b-d3bfd649c9d3> ;
    crm:P141_assigned "Gilles Le Sourd fut principal du Collège de la Marche (1689) puis recteur de l’université de la Sorbonne à Paris. Il fut également curé de la paroisse Saint-Paul de 1692 à 1711." ;
