<34eac9b1-9c8e-406d-aa74-569f0b31f945> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <01d49cac-ac1b-42ac-a08b-2709f4ca97e8> ;
    crm:P141_assigned "Gratien Raoul, récollet, nommé professeur de théologie en 1703, fut élu en 1708 supérieur du couvent de Port-Louis.  Il séjourna dans la colonie de l’Île Royale de 1710 à 1715 puis entre 1754 et 1758, cette fois-ci en qualité de de Supérieur de l’île Saint-Jean. Il mourut probablement autour de 1780 (cf. Marc-Antoine Alix, Missionnaires bretons dans les Nouveaux Mondes (XVIe-XVIIIe siècles, Mémoire de Master 2, Université Rennes 2 Haute-Bretagne, 2016-2017, Annexes, p. 186, https://dumas.ccsd.cnrs.fr/dumas-01586706/file/2017_MM2_ALIX_M_A_vol.%202.pdf, consulté le 12 avril 2021)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

