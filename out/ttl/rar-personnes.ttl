    crm:P141_assigned "Esgrigny (René Jouenne d') (?-1732), huissier de la Chambre du roi, capitaine au régiment de la Couronne, commissaire des guerres, intendant de l'armée d'Irlande (1689…), puis de Catalogne et d'Italie, intendant de Catalogne" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
