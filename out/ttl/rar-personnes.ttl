<47acc456-90ee-42a3-bb16-84556f005538> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <1f792bf7-8d20-4c89-bd07-8e9514a70317> ;
    crm:P141_assigned "Guy Carré, seigneur de Montgeron (?- 1732) fut Intendant du Berry de 1705 à 1708 (cf. Mémoires de la Société des antiquaires du Centre, (1931-1933) vol. 45, Bourges, Imprimerie André Tardy, 1934, p. 220 ; https://gallica.bnf.fr/ark:/12148/bpt6k415240d/f1.item?lang=FR, consulté le 29 mars 2021). Il fut aussi “maître des requêtes puis intendant à Limoges (1709-1711)” (cf. https://fr.wikipedia.org/wiki/Liste_des_intendants_de_la_généralité_de_Bourges, consulté le 29 mars 2021)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

