<e6689187-056f-4042-870e-7c2bbf4b7edb> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <a9e0a1e5-e2e4-421d-9d64-c9cd2bc77732> ;
    crm:P141_assigned "<p>M. le Redde mit en musique un air, paru dans le <em>Mercure galant</em> de mars 1679 (cf. MG-1679-03_042). Le po&egrave;me de cet air a &eacute;t&eacute; &eacute;crit par M. No&euml;l, avocat &agrave; Chartres. Peut-&ecirc;tre pourrait-il s'agir de Nicolas Le Redde, marchand bourgeois &agrave; Nonancourt. Il &eacute;tait le p&egrave;re de Nicolas Le Redde qui &eacute;pouse Marie Piet &agrave; Chartres en juin 1717 et &eacute;tait d&eacute;c&eacute;d&eacute; &agrave; cette date (cf. <a title=\"\" target=\"_blank\" rel=\"noopener\">\"France, Eure-et-Loir, Parish and Civil Registration, 1526-1902\", database, FamilySearch (https://www.familysearch.org/ark:/61903/1:1:69SP-4VW2 : 1 July 2021), Nicolas le Redde</a>).</p>" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<e6db7b3a-0d50-4cbd-9a81-cdaf3437c5a0> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <7df66d2f-0ecf-43ac-8e81-97ba899deafa> ;
    crm:P141_assigned "<p>Fille de Manuel Ier et de Marie d'Aragon, &eacute;pousa en 1526 son cousin Charles Quint.</p>" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

