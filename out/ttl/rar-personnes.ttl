    crm:P141_assigned "Petit (Louis) (?-?), contrôleur des Bâtiments du roi à Saint-Germain-en-Laye (1665-1683), à Marly (1679-1683) et à la machine de Marly (1682-1683), gentilhomme servant du prince de Condé" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type she_ns:definition .

<c94f5ee5-f1e9-43a7-a0b2-24020c5d29ac> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <eb0c8aa8-1232-4d0b-97d3-44adff9d240a> ;
    crm:P141_assigned "<p>C&eacute;l&egrave;bre danseur, membre de l'Acad&eacute;mie royale de danse et danseur &agrave; l'Acad&eacute;mie royale de Musique (cf. S. Bouissou, P. Denecheau, F. Marchal-Ninosque, <em>Dictionnaire de l'op&eacute;ra de Paris sous l'Ancien R&eacute;gime (1669-1791)</em>, Paris, Garnier, 2019, t. 3, p. 687-691).</p>" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
