    crm:P141_assigned "<p>M. Lesgu est l'auteur de trois airs publi&eacute;s en 1678 dans le <em>Mercure galant</em> (cf. MG-<span data-sheets-formula-bar-text-style=\"font-size:13px;color:#000000;font-weight:normal;text-decoration:none;font-family:'docs-Helvetica';font-style:normal;text-decoration-skip-ink:none;\">1678-05_109</span> ; MG-<span data-sheets-formula-bar-text-style=\"font-size:13px;color:#000000;font-weight:normal;text-decoration:none;font-family:'docs-Helvetica';font-style:normal;text-decoration-skip-ink:none;\">1678-06_071</span> et MG-<span data-sheets-formula-bar-text-style=\"font-size:13px;color:#000000;font-weight:normal;text-decoration:none;font-family:'docs-Helvetica';font-style:normal;text-decoration-skip-ink:none;\">1678-10_328</span>).</p>" ;
