<aaff781c-dce8-4f55-abc8-9d0ae8672f95> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <dc00bcd2-7b40-485a-8831-c7aed9e93fbc> ;
    crm:P141_assigned "«Abbé de Saint-Pierre de Tasque, au diocèse de Tarbes en 1691, […], il fut rapidement nommé par ordonnance royale, le 24 décembre 1701 à l'abbaye de Sainte Marie d’Arles-sur-Tech et Saint André de Sorède de l’ordre de Saint Benoit. Confirmé par le pape le 31 juillet de l'année suivante et sacré à Paris le 4 octobre 1702, il fut également docteur en théologie et prédicateur du roi et devint membre honoraire du Conseil souverain de Roussillon en 1703» (cf. <a href= http://www.hyacinthe-rigaud.com/catalogue-raisonne-hyacinthe-rigaud/portraits/1144-gaillard-de-chaudon-noel  rel= noopener noreferrer  target= _blank >http://www.hyacinthe-rigaud.com/catalogue-raisonne-hyacinthe-rigaud/portraits/1144-gaillard-de-chaudon-noel</a>, consulté le 12 avril 2021)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<ab15e21d-17ae-4e7e-a146-545b91031e84> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <c919e633-a3ef-4a75-a0d5-8fbb07575648> ;
    crm:P141_assigned "José Manuel Fernández de Velasco y Tovar était en 1701 « ambassadeur extraordinaire [d'Espagne en France] pour remercier Louis XIV de son acceptation du testament » (cf. François-Marie Gérard, Liste des ambassadeurs, et autres agents politiques de la cour de France auprès des principales puissances européennes,…, Paris, ‪A.Pihan de la Forest, 1833‬, p. 29)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

