<b2063f14-af1d-45d7-9677-6c9fbce83b64> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <b2ecedf7-6ba0-4a77-9432-a3a43fe1d63c> ;
    crm:P141_assigned "Marc-Antoine Deslandes fût chanoine du chapitre de la cathédral de Tréguier de 1677 à 1702, archidiacre de la même ville de 1688 à 1708 ainsi que recteur de la paroisse de Saint-Michel de Saint-Brieuc de 1702 à 1708 (cf. CHARLES, Olivier, Chanoines de Bretagne : Carrières et cultures d'une élite cléricale au siècle des Lumières. Nouvelle édition [en ligne]. Rennes, Presses universitaires de Rennes, 2004 (généré le 23 mars 2021). Disponible sur Internet : http://books.openedition.org/pur/17414 ; ISBN : 9782753524699 ; DOI : https://doi.org/10.4000/books.pur.17414, consulté le 22 mars 2021)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

