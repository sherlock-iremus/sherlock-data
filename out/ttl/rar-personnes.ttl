<e09213dd-681f-4069-a27a-7c3f19ffc74e> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <3d1f2444-8724-41f6-a501-a78b6165cbf8> ;
    crm:P141_assigned "Marie de Sourdille était l'épouse de René II du Guesclin (1647-1714), seigneur de Beaucé et capitaine de cavalerie." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<e0ca84d5-a31e-42a9-94a2-b6059c147eb7> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <a69bf250-9e4b-44a7-a2eb-9590fa17c8ed> ;
    crm:P141_assigned "<p>M. Du Breuil de Vignancourt est l'auteur d'airs parus dans le <em>Nouveau Mercure</em> entre 1714 et 1716. D'apr&egrave;s la livraison de novembre 1714, M. du Breuil de Vignancourt &eacute;tait un \"digne &eacute;l&egrave;ve du fameux Lambert\" (cf. MG-1714-11_345). Un commentaire de Dusfresny dans le <em>Mercure </em>de novembre 1715 (cf. MG-1715-11_090) permet de lui attribuer un air sign&eacute; sous le pseudonyme \"Amoureux o&iuml;sif des bords de Marne\" : il indique en effet que sous ce pseudonyme se cache l'auteur du po&egrave;me et de la musique, et accompagne cet air de sa partition grav&eacute;e portant le nom de \"De Bre&uuml;il de Vignancourt\".</p>" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<e0f9a16c-ab95-4d94-a9a4-4d68114f6592> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <51ed1529-59a0-403c-86d5-f2171cad1391> ;
    crm:P141_assigned "<p>M. l&rsquo;abb&eacute; Roy &laquo; Chanoine de S. Jacques de l&rsquo;Hopital, &acirc;g&eacute; de 80 ans &raquo; est l&rsquo;auteur du po&egrave;me d&rsquo;un air en l&rsquo;honneur de Louise-Ad&eacute;la&iuml;de de Savoie publi&eacute; dans la livraison d&rsquo;ao&ucirc;t 1718 du Mercure galant (cf. MG-1718-08_188).</p>" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<e10b135f-9532-423e-b900-edda11078cec> a crm:E13_Attribute_Assignement ;
