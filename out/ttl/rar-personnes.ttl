<5be65d4b-e5bf-4fb3-b562-431e076a3067> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <ecce42df-06b2-4f29-9a0d-1563b9ad4c03> ;
    crm:P141_assigned "Regnouf (Louis) (?-?), maître paveur, un des entrepreneurs de pavé de la ville de Paris (1686 ou 1687-1699, 1711…), paveur ordinaire du roi (1686-1708 ou 1709)" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type she_ns:definition .

<5bf7c0d3-5ba5-4d36-b3d8-a407678a3e00> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <bdc0760d-b96e-4e62-9b4d-4858a3407e93> ;
    crm:P141_assigned """<p>Fils de Charles II (1630-1685). Duc de Monmouth et de Buccleuch.&nbsp;</p>
<p>Se d&eacute;clare pr&eacute;tendant au tr&ocirc;ne &agrave; la mort de son p&egrave;re en 1685. Ex&eacute;cut&eacute; le 15 juillet 1656 apr&egrave;s l'&eacute;chec de la Reb&eacute;llion de Montmouth.</p>""" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<5c08e7be-d56d-4fe6-8209-2aeafe3863c0> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <0c0d1af4-d6b5-477d-acaf-29a82676a3ef> ;
    crm:P141_assigned "Philippe de Clérambault (?-1704), comte de Palluau, était “lieutenant général, décédé à la Bataille de Höchstädt”. Il est fils de “Philippe de Clérembault, comte de Palluau (1606-1665), homme de guerre français, maréchal de France dit le maréchal de Palluau” (cf. https://fr.wikipedia.org/wiki/Clérambault, consulté le 10 février 2021)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<5c37411b-aeaa-4e6d-b6d0-77d31f998d24> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <a368c0f6-734f-4f3d-b2e5-981679e740ce> ;
    crm:P141_assigned "Louis Nivelle (1638-1718) était avocat au parlement de Paris). Il est le père de Gabriel-Nicolas Nivelle (1687-1771), prêtre janséniste." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<5c42dc7d-d470-4c91-852c-673d6791a6f4> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <90f56079-e4e3-42b4-ae3b-bb74007c6f2f> ;
    crm:P141_assigned "Saulx (Marie-Françoise-Casimire de Froulay de Tessé, comtesse de) (1714-1753), dame du palais de la reine (1746-1753)" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type she_ns:definition .

<5c9bd4eb-2196-4790-9831-b69b10f99dcc> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <e4d115ec-b455-40a2-afe4-d1fe46444d3b> ;
    crm:P141_assigned "<p>M. Prevost &eacute;tait un compositeur, candidat au concours pour le poste de sous-ma&icirc;tre de musique de la Chapelle Royale (cf. MG-1683-04_310). Lors de la publication d'un air dans le <em>Mercure galant</em>, il est indiqu&eacute; qu'il &eacute;tait &laquo; ci-devant ma&icirc;tre de musique de la cath&eacute;drale de Clermont en Auvergne &raquo; (cf. MG-1687-04_160).</p>" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<5ca6d44e-4b47-4901-938b-19041d7f2c0c> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <387caa71-c14c-4a40-8d1b-7c947bdb2ab9> ;
    crm:P141_assigned "Jean Truchet, dit le Père Sébastien, était membre de l'Académie des Sciences. Il a été «Académicien honoraire, premier titulaire, nommé par Louis XIV, le 28 janvier 1699 - Démissionnaire le 16 août 1726» (cf. <a href= https://www.academie-sciences.fr/fr/Liste-des-membres-depuis-la-creation-de-l-Academie-des-sciences/les-membres-du-passe-dont-le-nom-commence-par-t.html  rel= noopener noreferrer  target= _blank >https://www.academie-sciences.fr/fr/Liste-des-membres-depuis-la-creation-de-l-Academie-des-sciences/les-membres-du-passe-dont-le-nom-commence-par-t.html</a>, consulté le 9 avril 2021)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

