<a10c0dd5-aa57-42b8-9542-0984db89ac97> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <be636175-10c2-434c-ab7f-421358ebc342> ;
    crm:P141_assigned "Florent Galland du Désert était maître à danser et fils de François Galland du Désert, Chancelier de l’Académie Royale de Danse (cf. <span style= background-color: rgba(0, 0, 0, 0); >MG-1680-06_263). Avec son frère, François II Galland du Désert, il constituait le duo “Des-Airs” (cf. Powell, John. “Pierre Beauchamps, Choreographer to Molière's Troupe du Roy” dans Music &amp; Letters , Vol. 76, No. 2 (May, 1995), p. 172)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

