<188bc29f-557e-467d-a9a0-bc6f8a083104> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <4de2f405-2052-4bff-979c-7d54b7c43a13> ;
    crm:P141_assigned "Johann Kasimir Kolbe von Wartenberg (6 février 1643 - 4 juillet 1712) fut premier ministre du Royaume de Prusse de 1697 à 1710. Le grand-chambellan de Frédéric Ier de Prusse, fut également maréchal du royaume, chancelier de l'Ordre de l'Aigle noir et Statthalter héréditaire de toutes les principautés, comtés et seigneuries de la succession d'Orange.  (cf. https://fr.wikipedia.org/wiki/Johann_Kasimir_Kolbe_von_Wartenberg, consulté le 26 mars 2021)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<18cbd0e8-677d-407e-9152-75841174a62d> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <52b29b19-328f-4b16-a715-c1f0f63830b6> ;
    crm:P141_assigned "Anne-Marie des Fontaines (fl. 1685-1724) était chanteuse de la Chambre du roi. Sa fille, Marguerite-Dorothée Le Peintre, lui succéda dans sa charge en 1724." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

