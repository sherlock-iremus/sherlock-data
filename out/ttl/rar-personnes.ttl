<0e65da8f-701b-43b5-9101-450ca8c54946> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <d6c3a737-80e4-4c5f-91bd-c1a4d6beca66> ;
    crm:P141_assigned "<p>M. de la Tour est l'auteur de sept airs publi&eacute;s dans le Mercure galant entre 1678 et 1720 (2 en 1678, 1 en 1693, 1 en 1705, 3 en 1719 et 1720). Il est toutefois difficile de savoir s'il s'agit du m&ecirc;me compositeur ou non.</p>" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

