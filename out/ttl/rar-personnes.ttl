<2d9cc0c1-d45e-4e91-a955-9fbf3a7112b6> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <6b77332e-2b1b-47bc-8919-f1f3989ad3a3> ;
    crm:P141_assigned "<p>M. Le Froid, \"Homme fort consomm&eacute; en Musique, &amp; qui fait de tres-habiles Ecoliers\" (MG-1678-05_44) est l'auteur de deux airs parus dans le Mercure galant en 1678 et 1679.</p>" ;
