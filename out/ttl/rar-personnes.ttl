<d3369266-c5c8-48c9-90fd-086891a91a7e> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <46535821-6b53-46c9-b38c-26d3f1c4b591> ;
    crm:P141_assigned "Le Mercure galant évoque «MrBlandin Notaire» (cf.MG-1707-05_18) : il s’agit peut-être de Philippe Blandin, notaire royal (cf. <a href= https://gw.geneanet.org/druhen?lang=fr&amp;amp;pz=dominique&amp;amp;nz=druhen&amp;amp;ocz=1&amp;amp;p=philippe&amp;amp;n=blandin  rel= noopener noreferrer  target= _blank >https://gw.geneanet.org/druhen?lang=fr&amp;amp;pz=dominique&amp;amp;nz=druhen&amp;amp;ocz=1&amp;amp;p=philippe&amp;amp;n=blandin</a>, consulté le 24 mars 2021)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<d35f8170-70f8-43cc-b0d3-56cd37817589> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <fa1204f1-dc80-44d0-a34b-fa57a6d0fa41> ;
    crm:P141_assigned "Le Mercure galant mentionne une  Madame de Brion , épouse de Mr de Brion, capitaine d’Infanterie dans la Reine,qui a participé aux réjouissances publiques à Château-Gontier pour la naissance du duc de Bretagne." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<d3670047-f2de-43f3-bea9-79267a71c08a> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <25248697-6869-41dc-8fe9-af9a780636ae> ;
    crm:P141_assigned "Madame Brossard est mentionné dans le Mercure galant comme venant de la ville de Bourg-en-Bresse : il s’agit peut-être d’un membre de la famille de Jacques Brossard de Montaney (1638-1702)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

