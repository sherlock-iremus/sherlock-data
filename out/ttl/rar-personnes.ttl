<91e9ba70-7baa-4732-8408-b1bcd0484f16> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <4f98bb88-9799-4e4b-a27f-2afc83af46d7> ;
    crm:P141_assigned "<p>M. Malo est l'auteur des paroles d'un air publi&eacute; dans le <em>Mercure Galant&nbsp; </em>d'octobre 1687 (cf. MG-1687-10_121). Le <em>Mercure Galant </em>de f&eacute;vrier 1681 pr&eacute;cise qu'il organisait des concerts publics (cf. MG-1681-02_130). </p>" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

