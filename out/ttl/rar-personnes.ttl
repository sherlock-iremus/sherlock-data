<d5adca8a-3b8f-4110-849f-6d9f66dcfab0> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <a6fc1723-a57f-4ed5-947d-42732ea461f7> ;
    crm:P141_assigned "Don José Domingo Benito de Gurrea y Aragón a exercé la charge de gouverneur du royaume d'Aragon entre 1696 et 1705/6 (cf. Gómez Zorraquino, José Ignacio, <em>Patronazgo y clientelismo :Instituciones y ministros reales en el Aragón de los siglos XVI y XVII</em>, Prensas de la Universidad de Zaragoza,29 avr. 2016, p. 256)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

