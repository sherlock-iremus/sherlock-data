    crm:P141_assigned "<p>M. Garnier a mis en musique une Compleinto sur l'&eacute;tat pr&eacute;sent des affaires du duc de Savoie, en occitan, parue dans le Mercure galant de juin 1691 (cf. MG-<span data-sheets-formula-bar-text-style=\"font-size:13px;color:#000000;font-weight:normal;text-decoration:none;font-family:'docs-Helvetica';font-style:normal;text-decoration-skip-ink:none;\">1691-06_127).</span></p>" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

