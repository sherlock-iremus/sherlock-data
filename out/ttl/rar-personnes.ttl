<1aa3e1ea-8c75-49c4-9499-36c27ccd66d8> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <06dcf0a1-acec-4256-82e8-80ba9ed281cd> ;
    crm:P141_assigned "<p>M. Normandeau l'a&icirc;n&eacute;, \"cy-devant Page de la Chapelle du Roy\" (cf. MG-1699-09_205), ne doit pas &ecirc;tre confondu avec M. Normandeau, auteur de deux airs parus dans le <em>Mercure galant</em> en 1689 et 1691 (cf. MG-11689-06a_114 et MG-1691-09_311a). Ce dernier &eacute;tait peut-&ecirc;tre le p&egrave;re de l'ancien Page.</p>" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

