<bf7d36e8-19ea-43bb-ade2-f04bddf40d88> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <e42404c0-fff8-4d34-b913-ebdfccfcef74> ;
    crm:P141_assigned "Arthur Chichester (1666-1706) était un soldat irlandais. “En 1704, il accompagna le régiment dans la Guerre de Succession d'Espagne en Espagne et fut nommé major général des forces espagnoles” (cf. https://fr.wikipedia.org/wiki/Arthur_Chichester_(3e_comte_de_Donegall), consulté le 18 mars 2021). " ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

