<aef39378-44c1-45c9-86d0-e49ae4b6aaa7> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <0e7e2ecd-fee7-4d1c-923e-1eaa909e1502> ;
    crm:P141_assigned "Jacques de Drouillet fut conseiller au Parlement de Toulouse (1653-1677) puis président à la deuxième chambre des Enquêtes (1677). Il présida également l'Académie des Jeux floraux de Toulouse entre 1704 et 1718 (cf. Axel Duboul, « Les deux siècles de l’Académie des Jeux floraux », Toulouse, imprimerie et librairie E. Privat, 1901, t. 2, p. 96 ; https://gallica.bnf.fr/ark:/12148/bpt6k998931/f114.item.r=druillet, consulté le 26 mars 2021)" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<aef8f178-4a20-4649-8f1e-f30841dcf376> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <fecff36d-9ae5-446e-8644-dab82d0c8a59> ;
    crm:P141_assigned "Jean Marius était un inventeur français et créateur notamment du clavecin brissé et du clavecin à maillets (cf. COHEN, Albert, «Marius, Jean»,Grove Music Online,2001, Oxford University Press (généré le 07/04/2021). Disponible en ligne: <a href= https://www.oxfordmusiconline.com/grovemusic/view/10.1093/gmo/9781561592630.001.0001/omo-9781561592630-e-0000017820  rel= noopener noreferrer  target= _blank >https://www.oxfordmusiconline.com/grovemusic/view/10.1093/gmo/9781561592630.001.0001/omo-9781561592630-e-0000017820</a> .DOI: <a href= https://doi.org/10.1093/gmo/9781561592630.article.17820  rel= noopener noreferrer  target= _blank >https://doi.org/10.1093/gmo/9781561592630.article.17820</a>)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<af28556c-5aae-4cb7-a5f7-3f84a37717f3> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <52b29b19-328f-4b16-a715-c1f0f63830b6> ;
    crm:P141_assigned "Anne-Marie des Fontaines (fl. 1685-1724) était chanteuse de la Chambre du roi. Sa fille, Marguerite-Dorothée Le Peintre, lui succéda dans sa charge en 1724." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

