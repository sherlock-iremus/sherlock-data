<4faa0994-dd39-4491-82d6-26e0287f8cb0> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <ba8da1d1-8224-43e8-8a8a-37d99bbf0ef6> ;
    crm:P141_assigned "Francisco Antonio de Borja-Centelles y Ponce de León (né le 27 mars 1659 à Sassari, en Sardaigne, et mort à Calahorra le 3 avril 1702) est un cardinal autrichien de la fin du xviie et du début du xviiie siècle. Il est le frère du cardinal Carlos de Borja-Centelles y Ponce de León (1720). Le pape Innocent XII le crée cardinal lors du consistoire du 21 juin 1700, il ne reçut jamais son titre cardinalice. Il ne participe pas au conclave de 1700, lors duquel Clément XI est élu. Le cardinal Borja est élu évêque de Calahorra-La Calzada en 1701 et est promu à l'archidiocèse de Burgos le 3 avril 1702, le jour de sa mort . (https://fr.wikipedia.org/wiki/Francisco_Antonio_de_Borja-Centelles_y_Ponce_de_León, consulté le 9 janvier 2021)" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<4fb7dc81-bbbf-4005-a58e-d245cbdb44e2> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <0e42fe12-bae7-4749-99d4-99ac338c39ba> ;
    crm:P141_assigned "Premier président du parlement de Paris (1678.06)" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type she_ns:P3_definition .

<4fc9757f-bee9-41e5-b238-214d3b97f004> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <06a9e9c0-58ed-487a-a050-b9c43fa2bcd5> ;
    crm:P141_assigned "Villacerf (Édouard Colbert, marquis de) (1628-1699), premier maître d'hôtel de la reine (1666…), premier commis de la Guerre (…1686), inspecteur général des Bâtiments du roi (1686-1691), surintendant des Bâtiments du roi (1691-1699), premier maître d'hôtel de la dauphine (1697…)" ;
