    crm:P177_assigned_property_type she_ns:definition .

<d2c96217-206a-493f-9da1-465aec4c3b04> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <29f29d46-1d69-43da-b426-0c09d78a0897> ;
    crm:P141_assigned "Courçay (André Barthélemy, abbé de) (1744-1799), garde adjoint du Cabinet des médailles du roi (1770-1795), conservateur-bibliothécaire du Cabinet des médailles de la Bibliothèque de France (06/1795-10/1795), conservateur du Cabinet des médailles de la Bibliothèque de France (1795-1799), directeur du Conservatoire de la Bibliothèque de France (1795-1796)" ;
