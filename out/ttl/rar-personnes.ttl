<ed8fcb19-083d-496a-9ff7-968f3f714404> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <d356c2c7-9078-4a94-9a02-37136dc41915> ;
    crm:P141_assigned "Marc-Antoine Oudinet était avocat aux parlements de Paris, puis de Reims et garde du cabinet des médailles du roi de 1689 à 1712." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<eda93884-3fe2-451c-80f2-edef6a0b8720> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <7344509a-6dcc-4aee-88da-d7c22e2edd5e> ;
    crm:P141_assigned "Jacques Cabassole (1671-?) était prêtre et maître de musique. Il a exercé aux Saint-Innocents de Paris entre 1698 et 1702, puis à la Cathédrale de Chartres entre 1702 et 1706 (cf. Hajdu Hayer, John. The Lure and Legacy of Music at Versailles. Louis XIV and the Aix School. Cambridge : Cambridge University Press, 2014, p. 107, 108)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<eded691b-e3da-4d92-9821-750bbfc04f76> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <cd2830d9-e74d-4d98-9bb7-3f1ef2a8fdcd> ;
    crm:P141_assigned "Jean-Baptiste Dantécourt, génovéfain, fut régent de théologie à Évaux (1670), professeur de philosophie à Sainte-Geneviève (1675-1686), chancelier de l'Université (1680-1707) et curé de Saint-Étienne-du-Mont (1694-1710)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

