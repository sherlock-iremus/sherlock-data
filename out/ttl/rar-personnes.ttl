<4ef833fb-b907-47ae-8e91-ce86af55a1f0> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <897a8647-85d0-4bfd-96b9-afcabd894512> ;
    crm:P141_assigned "<p>D'apr&egrave;s le <em>Mercure galant </em>o&ugrave; il publie un air, M. Riel &eacute;tait \"connu pour un des plus consommez que nous ayons dans la Musique, &amp; le premier Eleve de Mr Lambert\" (cf. MG-1678-08_354).</p>" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<4f436388-e3c8-4d15-9663-b1ca5744c6ef> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <4e1fc1b4-ffdb-4215-9b08-e2f185beef34> ;
    crm:P141_assigned "<p>M. Daubaine est l'auteur des paroles de plusieurs airs parus dans le <em>Mercure Galant </em>entre novembre 1681 et septembre 1682. Il est &eacute;galement le traducteur de fables de Jacques R&eacute;gnier, parues en 1685.</p>" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<4f4971d5-ffee-4465-a605-e4521a2694f4> a crm:E13_Attribute_Assignement ;
