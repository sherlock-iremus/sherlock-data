<90bd178d-a3ba-4dfb-9a79-a09d21b492cc> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <aab44a88-5255-4a4b-bf67-04bea43a4358> ;
    crm:P141_assigned "C’est à Christian Ludwing von Brandenburg-Schwedt que J.S. Bach dédie les six Concerts Brandebourgeois." ;
