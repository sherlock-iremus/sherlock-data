    crm:P140_assigned_attribute_to <aeeb263e-fbc4-4bbb-be18-aebaeb7f9105> ;
    crm:P141_assigned "<p>Le \"Solitaire de Pontoise\" est le pseudonyme utilis&eacute; par l'auteur d'un air publi&eacute; dans le <em>Mercure Galant </em>de juillet 1678 (cf. MG-1678_07_034).</p>" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
