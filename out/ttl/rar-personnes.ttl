<d610c4d3-3297-4f78-a884-819a5dde25ac> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <ce6ecc75-d874-46b1-813a-cb6b0ef2e79d> ;
    crm:P141_assigned "<p>M. No&euml;l est l'auteur des paroles d'un air publi&eacute; dans le <em>Mercure Galant </em>de mars 1679. Le r&eacute;dacteur du Mercure pr&eacute;cise que \"Les Paroles sont de Mr No&euml;l, Homme d'un fort grand merite, &amp; que je vous ay d&eacute;ja dit que la Ville de Chartres avoit choisy pour son Avocat.\" (cf. MG-1679-03_042). Il s'agit de Milles No&euml;l dont l'acte de d&eacute;c&egrave;s indique qu'il &eacute;tait \"advocat en parlement et de la ville de Chartres\" (cf. <a title=\"\" href=\"https://familysearch.org/ark:/61903/3:1:3Q9M-C33B-DRK3?cc=3460907 : 2 July 2021\" target=\"_blank\" rel=\"noopener\">Registres paroissiaux de Saint-Hilaire de Chartres</a>). Il &eacute;pousa en juin 1670 Catherine Bouvart.</p>" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<d61b9c7f-1f47-41a1-b208-9e9f29ec034d> a crm:E13_Attribute_Assignement ;
