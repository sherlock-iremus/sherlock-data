    crm:P141_assigned "Coigny (Marie-Thérèse-Josèphe-Corentine de Névet, comtesse de) (1717-1778), dame pour accompagner Mesdames cadettes (1750-1775), dame pour accompagner Madame Victoire (1775-1776)" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type she_ns:definition .

<d0d2c63b-13c0-4845-9819-480da2d89577> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <f379276f-4bf5-483c-b1c1-a58c3c723391> ;
    crm:P141_assigned "<p>M. Charles, \"disciple de M. Brossant\" (cf. MG-1706-04_375), est l'auteur de la musique d'airs parus dans le Mercure galant entre 1706 et 1710. peut-&ecirc;tre convient-il de lire \"Brossard\" et non \"Brossant\".</p>" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

