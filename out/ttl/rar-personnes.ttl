    crm:P177_assigned_property_type crm:P3_has_note .

<2e1e5db8-d059-49d5-885d-a6666e71af05> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <eabaaa79-157d-4d9c-b02b-eb6ab08ca83e> ;
    crm:P141_assigned "<p>Aphrodise &eacute;tait un compositeur et ma&icirc;tre de musique actif &agrave; Toulouse entre 1696 et 1706.</p>" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<2e5fe44f-c52d-46c1-a2d0-12dc4f834c79> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <c6174b29-7226-40da-a705-00f95f602e27> ;
    crm:P141_assigned "<p>M. Le Comte est l'auteur des paroles d'un air publi&eacute; dans le <em>Mercure </em><em>Galant </em>d'ao&ucirc;t 1698, qui pr&eacute;cise qu'il est \"Conseiller au Parlement de Toulouse\" (cf. MG-1698-08_127). </p>" ;
