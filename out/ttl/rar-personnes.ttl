<0ffca227-3fc8-4752-b503-9171aa81bbae> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <c4d1d247-c367-4185-98d9-6b40620dbc27> ;
    crm:P141_assigned "<p>Mlle de Saint-Quentin est l'autrice des paroles d'un air publi&eacute; dans le <em>Mercure Galant</em> de d&eacute;cembre 1707 (cf. MG-1707-12_160) et d'un <em>Trait&eacute; de la Possibilit&eacute; de l'Immortalit&eacute; Corporelle </em>&eacute;voqu&eacute; dans le <em>Mercure Galant </em>de novembre 1692 et dans celui de janvier 1693 (cf. MG-1707-12_160). En 1804, le <em>Dictionnaire</em> de Fortun&eacute;e Briquet &eacute;crit &agrave; son propos : \"SAINT-QUENTIN, (Mademoiselle de) fille d'un avocat de m&eacute;rite, au parlement de Paris, v&eacute;cut vers la fin du 17e. si&egrave;cle. Elle &eacute;tait tr&egrave;s-vers&eacute;e dans la philosophie de Descartes. On lui doit un trait&eacute;, <em>Sur la possibilit&eacute; de l'immortalit&eacute; corporelle</em>, avec une r&eacute;ponse aux objections qui lui furent faites. Cet ouvrage fit beaucoup de bruit lorsqu'il parut.\" (Fortun&eacute;e Briquet, <em>Dictionnaire historique, biographique et litt&eacute;raire des Fran&ccedil;aises et &eacute;trang&egrave;res naturalis&eacute;es en France</em>, Paris, Treuttel et W&uuml;rtz, 1804.)</p>" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

