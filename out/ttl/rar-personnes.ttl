<54ad7876-42ef-46b2-ae6f-6f5f28644427> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <350fb47d-3bd8-4b5b-af36-ca28e339842f> ;
    crm:P141_assigned "Marguerite d’Alençon est une religieuse bénédictine, élue abbesse de Sainte-Hoïlde en 1694 (cf. Arthur Benoit, Notes sur l’abbaye de Sainte-Hoïlde. Liste des abbesses, requête au duc Léopold, dans, Mémoires de la société des lettres, sciences et arts de Bar-le-Duc, 1894, p. 55) (cf. https://gw.geneanet.org/delsevy?n=d+alencon&amp;oc=&amp;p=marguerite+francoise, consulté le 1er mars 2021)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<54cab854-d97c-42f1-b8b4-289592107633> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <3ebd4c3e-d347-4544-a666-b430ee8ec45b> ;
    crm:P141_assigned "Mademoiselle Conradi a chanté à l’Opéra de Hambourg entre 1690 et 1710 (cf. <a href= http://www.quellusignolo.fr/sopranos/conradi.html  rel= noopener noreferrer  target= _blank >http://www.quellusignolo.fr/sopranos/conradi.html</a>, consulté le 25 mars 2021).  Dans le ballet «Sieg der Schönheit über die Helden», présenté lors du mariage du prince de Prusse en 1706, elle a joué les rôles de Vénus et de la Prusse. " ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<55028317-1168-4c8c-a3af-39c2aec0797a> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <38e261c2-b8ff-4925-baee-ff3852997acf> ;
    crm:P141_assigned "<p>M. Champenois, ma&icirc;tre de musique, composa la musique d'un air publi&eacute; dans la premi&egrave;re partie du Mercure galant de novembre 1688 (cf. MG-1688-11a_213).</p>" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

