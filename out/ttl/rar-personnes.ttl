    crm:P141_assigned "Chanoine et sacristain de la Cathédrale en mars 1687; frère de Henri de Boche, grand sénéchal d'Arles." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type she_ns:definition .

