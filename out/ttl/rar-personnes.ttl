<325e2337-8c3f-422b-91db-2b42303393f1> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <26767cf0-8cae-465d-9f23-c263697e75b0> ;
    crm:P141_assigned "<p>M. Pivin, \"d'un pays o&ugrave; l'on ne fait point de scrupule de faire rimer Trompette avec Conqueste\", est l'auteur de quatre airs parus dans le <em>Mercure galant</em> en 1697 et 1698. Le <em>Mercure galant</em> indique que l'air paru en novembre 1697 a &eacute;t&eacute; chant&eacute; &agrave; Claye (de nos jours Claye-Souilly), au souper de la duchesse de Lorraine.</p>" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

