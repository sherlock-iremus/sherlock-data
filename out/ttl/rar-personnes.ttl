<38018e76-b376-4cb3-aa56-e1be74d6b708> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <2fbc89d6-9182-40c4-9073-9574e983d155> ;
    crm:P141_assigned "Bernard de Manthe était maître à danser, membre de l’Académie Royale de Danse. Il a remplacé Thomas le Vacher, mort quelques jours après la fondation de l’Académie (cf. Société des études historiques. L’Investigateur, Paris: 1879, p. 320)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

