<8fe94b30-7409-41e3-9430-4dace5cf4d33> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <adeffde6-7401-4838-936a-3a75ba3fef54> ;
    crm:P141_assigned "capitaine du château de Meudon (1686.09)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
