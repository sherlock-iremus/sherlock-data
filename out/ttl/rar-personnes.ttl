<61ee47ee-0793-4684-bf05-cd9ad8dba578> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <d4c5ec39-9828-4f00-bff6-94dcdb99c415> ;
    crm:P141_assigned "Charles Trudaine, seigneur de Montigny (1660-1721) fut maître des requêtes (1689), intendant de Lyon (1704-1710), intendant de Bourgogne (1710-1711) après quoi il siégea au Conseil d'État. Il fut membre de l'Académie des sciences, belles-lettres et arts de Lyon de 1704 à 1710." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

