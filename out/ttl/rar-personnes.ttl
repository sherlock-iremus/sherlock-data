<06681c48-dad8-492f-be7c-8670e3c091f6> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <d79f8ebe-3408-4b67-93c3-d0b01a70bd42> ;
    crm:P141_assigned "Cazaubiel (Philippe-Charles-François) (1734-?), chapelain du château de Saint-Hubert (…av. janvier 1785)" ;
