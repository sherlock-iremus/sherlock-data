<d0b31670-94f3-4e72-9db6-909087d79db3> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <c92f5e49-d8b0-4b34-bdf7-d0a3b0cb96dc> ;
    crm:P141_assigned "<p>D'apr&egrave;s le <em>Mercure galant</em>, M. Normandeau &eacute;tait organiste du Coll&egrave;ge de Navarre. Il est l'auteur de deux airs parus dans le p&eacute;riodique en 1689 et 1691 (cf. MG-1689-06a_114 et MG-1691-09_311a). Il ne doit pas &ecirc;tre confondu avec M. Normandeau l'a&icirc;n&eacute;, dont le <em>Mercure galant </em>affirme en 1699 qu'il &eacute;tait \"cy-devant Page de la Chapelle du Roy\" (cf. MG-1699-09_205). Ce dernier &eacute;tait peut-&ecirc;tre son fils.</p>" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

