<04579d3a-c053-4fe1-9e6a-2ebbf5da6545> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <39cf34ed-bba5-4d2e-bb12-62c3b0faf7e4> ;
    crm:P141_assigned "M. Nolet de Cadhilac remporta le prix des Lanternistes de Toulouse en 1702. Le Mercure galant dit de lui qu'il  est né, pour ainsi dire, dans le sein des Muses. Son illustre Famille les a toujours cultivées, &amp; c’est là particulierement qu’elles aiment à faire entendre leurs charmants Concerts. (MG-1702-07a_9)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

