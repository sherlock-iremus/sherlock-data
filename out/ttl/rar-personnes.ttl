<941b5e29-9187-4790-b104-d50f276ed6ad> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <2ee13819-1144-4aab-b8ba-d92c6ddf486f> ;
    crm:P141_assigned "«Seigneur de Précy-sur-Marne et d’Arcueil, Pomponne de Refuge, marquis de Refuge (1642-1712), fut successivement lieutenant au bailliage d’Évreux sur démission de son frère (1689), colonel du régiment de Bourbonnais (1672), brigadier d’Infanterie (1676), capitaine d’une compagnie de cadets et gouverneur de Clermont (juin 1685), brigadier d’Infanterie (1676), gouverneur de Charlemont (1685), maréchal de camp (août 1688), lieutenant général des armées (1688). Il terminera sa carrière comme commandant de Franche-Conté (1703) et dans les Trois-Evêchés (1704)» (cf. <a href= http://www.hyacinthe-rigaud.com/catalogue-raisonne-hyacinthe-rigaud/portraits/484-refuge-pomponne-de  rel= noopener noreferrer  target= _blank >http://www.hyacinthe-rigaud.com/catalogue-raisonne-hyacinthe-rigaud/portraits/484-refuge-pomponne-de</a>, consulté le 1 avril 2021)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<9454b46a-618b-4c52-b305-0d12f36d5753> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <6582f426-15d9-406e-91db-5ce4ecc62dce> ;
    crm:P141_assigned "La Motte-Houdancourt (Henri de) (1612-1684), grand aumônier de la reine-mère (1653-1666), évêque de Rennes (1639-1662), archevêque d'Auch (1662-1684)" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type she_ns:P3_definition .

<9459ec7e-f44a-4e5e-af2b-37c484bb4270> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <18dd779e-6e98-4a34-99d8-65a137eafbd2> ;
    crm:P141_assigned "Filley (Louis) (v. 1642 - 1705 ou 1706), ingénieur du roi (1677…), inspecteur des Bâtiments du roi sur le chantier de la rivière de l'Eure (1684-1688), directeur des fortifications des places approchant l'Entre-Sambre-et-Meuse dont Namur (1693-1698…), brigadier d'infanterie (1695…), maréchal des camps et armées du roi (1703…), directeur des travaux du siège de Landau (1703) puis à Nice (1705/1706)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type she_ns:P3_definition .

