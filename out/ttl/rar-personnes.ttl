<e15062c4-7287-47e9-86ea-50c769eed748> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <d58ee2ff-13f9-4f4c-ab01-fb19b0364703> ;
    crm:P141_assigned "Turola (Dominique-Léonard) (1643-1701), garde-meuble du château de Versailles (…1693), garde général du Garde-Meuble de la Couronne (1693-1701)" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type she_ns:definition .

<e15b7201-246c-4cbe-b0a9-e5c03c34bea2> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <0c12ce1c-541d-413c-9030-a7d2b08e50fa> ;
    crm:P141_assigned "Le Mercure galant de juillet 1704, consacré aux réjouissances pour la naissance du duc de Bretagne, mentionne M. Lhuillier, alors Grand-Maître du collège du Cardinal Lemoine. Les mémoires de la Société de l’histoire de Paris et de l’Ile-de-France publié en 1876 indique que Claude Leullier occupa ce poste de 1694 à sa mort en 1733 (https://gallica.bnf.fr/ark:/12148/bpt6k63057479). L’article de Marie-Madeleine Compère et Boris Noguès, « La direction d’établissement dans les collèges de l’université de Paris sous l’Ancien Régime », dans Histoire de l’éducation, 2001, lui attribue la fonction de principal du collège du Cardinal Lemoine aux mêmes dates (https://journals.openedition.org/histoire-education/829), mais situe sa mort en 1732." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

