<fdb2f7fb-42cf-48ad-90dc-d7102b924d81> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <8dd78a25-a07b-4778-bd9c-c10aed9bb208> ;
    crm:P141_assigned "Auteur d'un sonnet publié dans la livraison d'août 1702 du Mercure galant (MG-1702-08_5), résidant à Saint-Laurent dans le Périgord. M. Robert publia en juillet de la même année l'épitaphe de Nicolas-Antoine Lebègue (MG-1702-07a_168), mais rien ne permet d'affirmer avec certitude qu'il s'agit d'une seule et même personne." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

