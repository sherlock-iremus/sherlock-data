<e9980683-51c2-47ac-9620-88d6023682f2> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <7a8c0a9f-2775-4a11-b329-88d468917b91> ;
    crm:P141_assigned "Claude-Marie de Saint Georges (1677-?), chanoine-comte de Saint-Jean de Lyon (1697), était le neveu de Claude de Saint-Georges, Archevêque de Lyon. Il fut “précenteur de l’église de Lyon” (cf. Journal Historique sur les Matières du Tems, Tome VI, Paris : Étienne Ganeau, 1719, p. 155)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<e9d3868a-17e6-4cc1-9c20-2d0acce9d342> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <387caa71-c14c-4a40-8d1b-7c947bdb2ab9> ;
    crm:P141_assigned "Jean Truchet, dit le Père Sébastien, était membre de l'Académie des Sciences. Il a été «Académicien honoraire, premier titulaire, nommé par Louis XIV, le 28 janvier 1699 - Démissionnaire le 16 août 1726» (cf. <a href= https://www.academie-sciences.fr/fr/Liste-des-membres-depuis-la-creation-de-l-Academie-des-sciences/les-membres-du-passe-dont-le-nom-commence-par-t.html  rel= noopener noreferrer  target= _blank >https://www.academie-sciences.fr/fr/Liste-des-membres-depuis-la-creation-de-l-Academie-des-sciences/les-membres-du-passe-dont-le-nom-commence-par-t.html</a>, consulté le 9 avril 2021)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<e9f183b5-badc-4d9d-a70f-1af2e0385404> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <b1a125e3-78d3-459a-9e01-9390c6757834> ;
    crm:P141_assigned "Konstantyn Józef Zieliński est mentionné dans le Mercure galant en tant qu' « ’Archevêque de Leopol » (cf.MG-1705-12_16), nom francisé de la ville de Lviv." ;
