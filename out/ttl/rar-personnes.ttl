<3f488875-d0f0-4a28-80df-8a03c15259ee> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <a9e0a1e5-e2e4-421d-9d64-c9cd2bc77732> ;
    crm:P141_assigned "<p>M. le Redde mit en musique un air, paru dans le <em>Mercure galant</em> de mars 1679 (cf. MG-1679-03_042). Le po&egrave;me de cet air a &eacute;t&eacute; &eacute;crit par M. No&euml;l, avocat &agrave; Chartres. Peut-&ecirc;tre pourrait-il s'agir de Nicolas Le Redde, marchand bourgeois &agrave; Nonancourt. Il &eacute;tait le p&egrave;re de Nicolas Le Redde qui &eacute;pouse Marie Piet &agrave; Chartres en juin 1717 et &eacute;tait d&eacute;c&eacute;d&eacute; &agrave; cette date (cf. <a title=\"\" target=\"_blank\" rel=\"noopener\">\"France, Eure-et-Loir, Parish and Civil Registration, 1526-1902\", database, FamilySearch (https://www.familysearch.org/ark:/61903/1:1:69SP-4VW2 : 1 July 2021), Nicolas le Redde</a>).</p>" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<3f5dcdd0-c5c7-4146-9c95-48dd5d818d69> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <3bf0eb1d-94a5-4fbf-bec6-6ca247d42903> ;
    crm:P141_assigned "échevin de Moulins (1682.10)" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type she_ns:definition .

<3f6285c7-9bb8-4eb2-84c4-ef8246bf9311> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <0bfa8f2d-e816-4aa5-b242-21f1385961e8> ;
    crm:P141_assigned "Membre de l'Académie de Nîmes, auteur d'une l’épître au roi d’Espagne parue dans le Mercure galant de janvier 1701 (MG-1701-01_085) et probablement aussi de l’Épître au Roy sur la prise de Barcelone, (Paris, J.-B. Coignard, 1697, https://catalogue.bnf.fr/ark:/12148/cb30718820j)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<3f74e28a-5428-4b33-a276-7b2e75d61a80> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <d7d4a03e-e9b6-4a14-b3fe-ad5fc18d900f> ;
    crm:P141_assigned "Montausier (Julie d'Angennes, duchesse de) (1607-1671), gouvernante des Enfants de France (1661), dame d'honneur de la reine (1664)" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type she_ns:definition .

<3f9709ad-a8ed-40bd-b4de-838afc47f7f6> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <bdf7a9b6-b37d-49b1-86d1-94e85f7cf63b> ;
    crm:P141_assigned "D’après la thèse de Juan Antonio López Anguita intitulée “Pouvoir et influence politique d'une reine d'Espagne lors de la Guerre de Succession : Marie-Louise Gabrielle de Savoie, première épouse de Philippe V”, Madame de Noyers (?-1720) était gouvernante de Marie-Louise, reine d’Espagne (cf. https://core.ac.uk/download/pdf/33108544.pdf, consulté le 4 février 2021). En 1655, elle épousa François Rey, baron de Noyers." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

