<a400105c-e310-414a-b2ca-1b0e1affc1d4> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <48dc3845-d163-4a92-88f2-b7bd3d8e01d2> ;
    crm:P141_assigned "Edmond Pirot (1631-?) était “docteur et professeur de Sorbonne […] d'abord chantre de Varzy dans le diocèse d'Auxerre, puis chanoine de Notre-Dame à Paris, et enfin chancelier de cette cathédrale” (cf. https://fr.wikipedia.org/wiki/Edmond_Pirot, consulté le 9 mars 2021). " ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<a416ebca-0e0d-4082-98cf-44d02121881c> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <4d6fa7f9-9065-4abc-8a0e-5aa3609370df> ;
    crm:P141_assigned "Pierre Perrichon (1645-1721) fut “notaire, avocat et secrétaire à Lyon [devenant] échevin en 1700 […]. En 1699, il portrait le titre d’avocat au Parlement et secrétaire de la commune puis, dans les années 1710-15, d’avocat en Parlement et ex-consul de la ville (cf. http://www.hyacinthe-rigaud.com/catalogue-raisonne-hyacinthe-rigaud/portraits/192-perrichon-pierre, consulté le 20 avril 2021)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<a41d6807-5bcb-4a07-96aa-611b195aeb42> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <e1c6f78b-3513-4493-aeef-52262642bc56> ;
    crm:P141_assigned "Échevin de Luzy (1698.02)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type she_ns:definition .

<a45e7994-70c0-4308-9b94-8275a27444f7> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <4f8d1de7-4640-4702-b0ac-d89e6582c39d> ;
    crm:P141_assigned "<p>M. de La Coste pourrait avoir propos&eacute; une nouvelle harmonisation de l'air \"Ainsi que mon amour\" publi&eacute; anonymement dans le Mercure galant de septembre 1700 (cf. MG-1700-09_144). Cette harmonisation est parue dans le Recueil d'airs s&eacute;rieux et &agrave; boire (Paris, Ballard, juillet 1700).</p>" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<a4645563-9133-4dcd-a2af-3254f587ed14> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <d31c14e5-ef9a-4617-9993-c1e68a60df63> ;
    crm:P141_assigned "Laurent Degas était magistrat et prévôt des marchands à Lyon. Il est également l'un des fondateurs de l'Académie des sciences, belles-lettres et arts de Lyon." ;
