<d3d45a73-3a3f-4613-90ab-3ce34215d86a> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <b49037a2-c7e4-4b64-aed9-82c0d7270579> ;
    crm:P141_assigned "Laura de Castelvi était l’épouse de Nicola Antonio de Caracciolo, marquis de Torrecuso. Leur mariage, cité dans le Mercure galant en septembre 1705, a eu lieu le 4 janvier de cette année (cf. https://gallica.bnf.fr/ark:/12148/bpt6k6279055c/f74.item, consulté le 7 avril 2021)." ;
