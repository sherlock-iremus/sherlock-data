<6289310b-c965-4450-8985-06fb7a992714> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <75dc3451-d0ca-4c1f-ab3b-b9653382e591> ;
    crm:P141_assigned "François le Maçon des Rabines a été chanoine du Mans, aumônier du duc d’Orléans et traducteur.Il est né à Château-du-Loir et mort à Paris en 1723 (cf. Société historique et archéologique du Maine, Revue historique et archéologique du Maine, Janvier 1938, page 103, en ligne https://gallica.bnf.fr/ark:/12148/bpt6k5613918f, consulté le 31 mars 2021)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<62a76817-b8b4-4ca5-9eb4-5a5db3ccbb45> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <615873bf-518c-4d7a-b235-c15d4d1f3b21> ;
    crm:P141_assigned "D'après data.bnf, la veuve de Robert Chevillon (décédé en 1693), revendit ses presses en janvier 1694 et continua  à exercer la librairie jusqu'en 1719 au moins  (https://data.bnf.fr/fr/15636070/robert_chevillion/)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<62c8f2c4-15ee-4268-9f3c-8f92904497b3> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <38b3fd4d-fc71-4e51-bf02-e0645f3d3898> ;
    crm:P141_assigned "Marie-Anne Pajot était l'épouse de Gaspard-François Legendre de Lormoy, intendant de Montauban de 1699 à 1714." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<6321ec54-5f0a-4cae-811a-bc789ca59950> a crm:E13_Attribute_Assignement ;
