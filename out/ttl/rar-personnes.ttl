<da14432b-c12a-42fc-95d8-5b87c1b944c6> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <2eae7d95-3c3f-4e0f-b8c2-e6085efb7263> ;
    crm:P141_assigned "Blouin (Louis) (1660-1729), premier valet de chambre du roi (1665-1715), intendant des terres, parcs et châteaux de Versailles (1701-1729) et de Marly (1679-1729), gouverneur de Coutances (1713)" ;
