<b5ac89fe-16db-42e1-9773-5a3c36579792> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <714ab30f-1593-4f5a-896a-07f61256a6d7> ;
    crm:P141_assigned "Jean Vivant (1660-1739) était  docteur de la maison et société de Sorbonne, prieur de Saint-Fiacre de Gagny, chanoine de Soissons et de l'Église de Paris, vicaire général de Mgr l'Archevêque, cardinal de Noailles, et son official métropolitain, [...] curé de Saint-Merry  (cf. Baloche, Constant. Église Saint-Merry de Paris : histoire de la paroisse et de la collégiale, 700-1910. Tome 1. Paris : Librairie H. Oudin, 1912, p. 432-433). " ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

