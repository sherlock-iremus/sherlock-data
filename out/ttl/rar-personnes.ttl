<c685e34f-3e1d-449e-a71c-21d48d16a978> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <249daaa4-d418-44cf-8c86-c0d19bc1d7e0> ;
    crm:P141_assigned "En 1675, Marguerite de Quibly succéda sa tante homonyme en tant qu’abbesse à l’abbaye de la Déserte à Lyon (cf. https://gallica.bnf.fr/ark:/12148/bpt6k5819645n/f138.item.r=%22marguerite%20de%20quibly%22, consulté le 23 avril 2021). En 1732, elle fut succédée par Antoinette de Châtillon, cependant, le Mercure galant signale en 1710 que “Me de Châtillon” était abbesse de la Déserte, formulant ainsi une erreur dans l’identification de cette personne." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<c699afc4-81b8-41bd-ab96-7d1d7caf62b5> a crm:E13_Attribute_Assignement ;
