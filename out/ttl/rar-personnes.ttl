<ecec5ad7-2d82-4dfc-b1ea-b40effb0eb63> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <3b61589d-11f4-4d8a-9500-e0c29cdd57e9> ;
    crm:P141_assigned "Joachim de la Chétardie (1636-1714) était “directeur dans les séminaires de Limoges, du Puy et de Bourges, [puis] Curé de Saint-Sulpice à Paris de 1696 à sa mort (29 juin 1714) (cf. http://beauchesne.immanens.com/appli/article.php?id=12223, consulté le 9 mars 2021). " ;
