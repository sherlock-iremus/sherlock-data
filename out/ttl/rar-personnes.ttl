<8fcdc894-fe3d-4efb-a527-50db5c11a762> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <4f8d1de7-4640-4702-b0ac-d89e6582c39d> ;
    crm:P141_assigned "<p>M. de La Coste pourrait avoir propos&eacute; une nouvelle harmonisation de l'air \"Ainsi que mon amour\" publi&eacute; anonymement dans le Mercure galant de septembre 1700 (cf. MG-1700-09_144). Cette harmonisation est parue dans le Recueil d'airs s&eacute;rieux et &agrave; boire (Paris, Ballard, juillet 1700).</p>" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
