<0d6563d7-64fe-4e7d-b3c7-bc0d0cbe373f> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <a58ed6f2-7d86-4ef5-a277-0ee0e76aef68> ;
    crm:P141_assigned "<p>M. de la Fevrerie &eacute;tait un contributeur du <em>Mercure Galant</em> qui publia en f&eacute;vrier 1695 sa \"R&eacute;ponse &agrave; la Satire contre les Vers irreguliers employ&eacute;e dans le Mercure du mois d'Avril 1694\" (cf. MG-1695_02_236) et &eacute;crivit les paroles d'un air publi&eacute; dans le <em>Mercure Galant</em> de d&eacute;cembre 1708 (cf. MG-1708-12_267). </p>" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

