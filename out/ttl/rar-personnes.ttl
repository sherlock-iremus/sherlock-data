<e2542369-c86c-486b-b6af-578d8c7cf1f1> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <9e90c60e-72d2-407f-9589-e46b0eefaa53> ;
    crm:P141_assigned "<p>Monsieur D. L. Txxx composa la musique de l'air \"Votre toutou vous flatte\" paru dans le Mercure galant de mai 1720 (cf. MG-<span data-sheets-formula-bar-text-style=\"font-size:13px;color:#000000;font-weight:normal;text-decoration:none;font-family:'docs-Helvetica Neue';font-style:normal;text-decoration-skip-ink:none;\">1720-05_138).</span></p>" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<e27c0d65-7172-4e10-95f5-24321fc121d7> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <3ae2cac9-573d-4408-adda-12ef9c82b088> ;
    crm:P141_assigned "colonel des gardes de la cour de Hanovre (1681.04 et 08)" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
