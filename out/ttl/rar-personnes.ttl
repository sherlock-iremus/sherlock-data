<e2cbb3a2-9cc7-4c62-9763-12fcb009717d> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <6f416c47-13b7-4693-b07e-1f28e8f02a16> ;
    crm:P141_assigned "François de Bertier (1657-1723) a été  chevalier et seigneur de Saint-Geniez (Saint-Geniès-Bellevue), mainteneur de l'Académie des Jeux floraux et premier président du Parlement de Pau (1703), puis de Toulouse (1710)” (cf. https://fr.wikipedia.org/wiki/François_de_Bertier, consulté le 24 mars 2021)." ;
