<d986eb24-d387-493e-ba4d-b64fbdd5e309> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <cecc3176-d5d1-4bd9-ae28-3d67c084d414> ;
    crm:P141_assigned "<p>Mlle d'O est l'autrice de deux airs parus dans le <em>Mercure galant</em> en 1680. En septembre 1680, le p&eacute;riodique<em> </em>affirme \"[qu'] elle est du Quartier S. Paul, dont elle fait un des plus beaux ornemens, &amp; tres-digne Fille d&rsquo;une Mere qui ayant est&eacute; dans son Printemps la plus aimable du monde, conserve dans son Et&eacute; tous les agr&eacute;mens que peuvent avoir celles de son &acirc;ge.\" (cf. MG-1680-09a_340 et MG-1680-11_045).</p>" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

