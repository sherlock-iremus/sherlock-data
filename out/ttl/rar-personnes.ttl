<23c952a3-a52e-484c-b17d-f7f9eac87048> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <1ed9554b-3c21-45b4-b52e-8afd3a34cd19> ;
    crm:P141_assigned "<p>M. du Mesnil-Marchand (ou M. Mesnil-Marchand) composa la musique de trois airs publi&eacute;s dans le Mercure galant (cf. MG-1701-09_165, MG-1701-09_402 et MG-1701-12_293).</p>" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<23da0d0f-d887-47c0-9a7b-c36efd3e40f5> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <f760ab70-c8f9-45f8-8da4-a977c26067eb> ;
    crm:P141_assigned "Le Mercure galant fait mention en juillet 1704 d'un comte de la Bretesche, frère du marquis de la Bretesche, lieutenant général des Armées du Roy. L'arbre généalogique présentant plusieurs frères, le comte est difficilement identifiable sans informations complémentaires." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<23e969f5-0273-4e83-9317-78afb6e68d40> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <dc782aff-a132-4d3e-a1bd-b44193d6627f> ;
    crm:P141_assigned "Boquet (Louis-René) (1717-1814), dessinateur d'habits, entrepreneur de décorations et fabricant d'accessoires pour les Menus Plaisirs et pour l'Académie royale de musique (1751-1789), dessinateur en chef des habits de fêtes et cérémonies (1764-1789), inspecteur général des Menus Plaisirs (1781-1789)" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type she_ns:definition .

<23fe6bb2-1552-4dd1-b83a-adc41a83edbd> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <f41d059d-0a21-4d8d-9922-9c4f43b49a50> ;
    crm:P141_assigned "Rohan (Louis-Constantin de) (1697-1779), premier aumônier du roi (1748-1757)" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type she_ns:definition .

<241b5fb9-a638-449b-8ba8-40237bb2a39d> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <143a62ba-53ac-4ba4-90b7-581cbf33cbac> ;
    crm:P141_assigned "Brun (Louis-Auguste) (1758-1815), peintre (1771-1801)" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type she_ns:definition .

<2422734d-e712-480c-bf39-3c7bbe13d9fb> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <bdbb41ee-e9af-44a7-add3-b01fe42858fa> ;
    crm:P141_assigned "<p>Fran&ccedil;ois I Martin est un compositeur fran&ccedil;ais, actif &agrave; Paris durant la seconde moiti&eacute; du XVIIe si&egrave;cle. Il a &eacute;t&eacute; ordinaire de la musique de Gaston d'Orl&eacute;ans et a publi&eacute; un recueil de pi&egrave;ces pour la guitare (1663), un recueil d'airs (1668) et des airs isol&eacute;s, dont quatre dans le <em>Mercure galant</em> (cf. MG-1678-04_071 ; MG-1689-04a_076 ; MG-1688-11a_136 et MG-1689-04a_317). Il est &eacute;galement l'auteur d'une pastorale, Les Bergers heureux (MG-1689-09_021). Il est le p&egrave;re de Fran&ccedil;ois (1661-?).</p>" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<243d96f2-c473-4f33-b036-d6967899542c> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <2afdc81f-04b2-4744-848b-e662924085b6> ;
    crm:P141_assigned "Mamiel (Marie-Madeleine de) (1765-ap. 1793), femme de chambre de Marie-Thérèse de Savoie (1783-1789)" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type she_ns:definition .

<2447f120-8daf-4b7d-8a7f-da1535b81ec6> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <0fd8b283-86e7-47e1-a4a3-4acbb8058fcd> ;
    crm:P141_assigned "Boulduc (Gilles-François) (1675-1742), apothicaire du roi (1712)" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type she_ns:definition .

<244f5707-1374-4e23-b2d9-7f5801b739dd> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <6cada961-c534-4700-b6c2-c62230640ce9> ;
    crm:P141_assigned "Ernst Rüdiger von Starhemberg était général du Saint-Empire romain germanique et gouverneur militaire de Vienne." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<247c3e43-4570-49e5-a792-d8da214eaaba> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <184da222-2136-4aee-8837-246cf6a70c6a> ;
    crm:P141_assigned "<p>D'apr&egrave;s le Mercure galant, M. Labb&eacute;, a &eacute;t&eacute; successivement ma&icirc;tre de musique &agrave; Saint-Jacques de Dieppe (1678-1679) puis ma&icirc;tre de musique de Ca&euml;n (1679), avant de s'&eacute;tablir &agrave; Rouen \"comme un homme rare &amp; qui passe pour un des plus habiles Musiciens du Royaume, non seulement pour l'Art de composer, mais aussi pour la belle m&eacute;tode du Chant, qu'il enseigne &agrave; tout ce qu'il y a de Personnes de qualit&eacute; dans la Ville\" (cf. MG-1686-11_070b). Il se serait form&eacute; aupr&egrave;s des meilleurs ma&icirc;tres de Paris et aupr&egrave;s de Bacilly lors d'un passage de ce dernier en Normandie (cf. MG-1687-09_350).</p>" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

