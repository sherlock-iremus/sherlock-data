<90770aaa-e04c-4df8-9e07-9da0e2fd14f9> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <f379276f-4bf5-483c-b1c1-a58c3c723391> ;
    crm:P141_assigned "<p>M. Charles, \"disciple de M. Brossant\" (cf. MG-1706-04_375), est l'auteur de la musique d'airs parus dans le Mercure galant entre 1706 et 1710. peut-&ecirc;tre convient-il de lire \"Barddard\" et non \"Brossant\".</p>" ;
