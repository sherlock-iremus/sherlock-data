    crm:P141_assigned "Écuyer de Madame la Duchesse de Bourgogne, Mathieu Douart était le fils de Mathieu Douart (1643-1711), avocat du roi, et de Marie de Rivault (1640 ca-1718)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

