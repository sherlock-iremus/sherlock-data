<94a1ff4d-ba51-4c16-a283-bd525281bfdb> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <7ae4cbf1-36ec-4b4b-a517-16f0fc29dfb3> ;
    crm:P141_assigned "Hardion (Jacques) (1686-1766), précepteur, censeur royal, secrétaire du comte de Morville, écrivain principal de la Marine royale (1721…), puis des Affaires étrangères (…1762), précepteur de Mesdames de France (1748), garde de la bibliothèque particulière du roi à Versailles et du Cabinet des livres à la suite de la cour (…1736-1766)" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type she_ns:definition .

