    crm:P190_has_symbolic_content "ARBITRE SOUVERAIN DU MONDE" ;
    crm:P2_has_type <5891daa1-81be-494a-8bf9-9055574f0530> .

<52533dd1-4053-4aaf-89aa-de7196b7ef30> a crm:E33_Linguistic_Object,
        crm:E41_Appellation ;
    crm:P190_has_symbolic_content "Les vignes ont manqué chacun s'en inquiète" ;
    crm:P2_has_type <a7453d39-b7f0-4ca2-ba62-9fc560438c60> .

<52575cd5-fec2-4cd1-8f93-b4bd001a4a77> a crm:E33_Linguistic_Object,
        crm:E41_Appellation ;
    crm:P190_has_symbolic_content "Il n'est plus temps de répandre des larmes" ;
