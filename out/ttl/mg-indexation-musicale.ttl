<7cbb7fcf-1747-4410-9100-fcef49e0ba9c> a crm:E35_Title ;
    rdfs:label "AIR NOUVEAU" .

<7cc79dcd-daf0-431c-81dd-a207bf5d7a5b> a crm:E33_Linguistic_Object,
