        crm:E41_Appellation ;
    crm:P190_has_symbolic_content "Le printemps revient tous les ans" ;
    crm:P2_has_type <a7453d39-b7f0-4ca2-ba62-9fc560438c60> .

<0eab25ab-f458-4fe2-8a67-2ca8baaed76a> a crm:E33_Linguistic_Object,
        crm:E41_Appellation ;
    crm:P190_has_symbolic_content "Quand sur nos charmants rivages" ;
    crm:P2_has_type <a7453d39-b7f0-4ca2-ba62-9fc560438c60> .

