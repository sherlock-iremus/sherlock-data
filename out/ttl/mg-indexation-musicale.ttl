<0e62cc4c-8f01-4ca4-919b-8f8a4ed8e96d> a crm:E33_Linguistic_Object,
        crm:E41_Appellation ;
    crm:P190_has_symbolic_content "En quittant la Savoie ; Votre auguste présence ; Louis et votre père ; Le Prince qu'on vous donne ; Son coeur comme le vôtre ; La paix ensevelie ; À votre mariage ; Ma flûte est toute prête ; L'on m'entendra sans cesse ; Sur le bord de la Seine" ;
    crm:P2_has_type <a7453d39-b7f0-4ca2-ba62-9fc560438c60> .

<0e6ebfc8-34b5-4aba-9481-9b89f677432e> a crm:E33_Linguistic_Object,
        crm:E41_Appellation ;
    crm:P190_has_symbolic_content "Je ne reconnais plus mon aimable Lisette ;Je ne reconnais plus ma charmante Lisette" ;
    crm:P2_has_type <a7453d39-b7f0-4ca2-ba62-9fc560438c60> .

<0e744b0f-befa-4229-8a6c-af355235cd43> a crm:E33_Linguistic_Object,
        crm:E41_Appellation ;
    crm:P190_has_symbolic_content "Hâte-toi sombre hiver de régner sur la terre" ;
    crm:P2_has_type <a7453d39-b7f0-4ca2-ba62-9fc560438c60> .

<0e85e244-e75c-42c3-a86e-94c518a0bc7d> a lrm:E65_Creation ;
