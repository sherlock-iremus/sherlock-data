<341ee208-28c9-401f-9e8b-ad984662b1dd> a crm:E33_Linguistic_Object,
        crm:E41_Appellation ;
    crm:P190_has_symbolic_content "Charmante Gabrielle Bel astre je vous quitte Recevez ma couronne Je n'ai pu dans la guerre Le fils de Gabrielle On n'a que trop à craindre Mon aimable maîtresse Au milieu de la Flandre Ma charmante Isabelle Pendant ma longue absence Les échos de ces plaines Fâcheuse récompense Faut-il que j'abandonne Quelle douleur extrême Le tigre et la tigresse Mon coeur est plus à plaindre Assurez-moi ma belle" ;
    crm:P2_has_type <a7453d39-b7f0-4ca2-ba62-9fc560438c60> .

<34261a1d-90c7-4fc9-8ea9-59b0e89f7be3> a crm:E33_Linguistic_Object,
        crm:E41_Appellation ;
    crm:P190_has_symbolic_content "Je veux et ne veux plus vous voir" ;
