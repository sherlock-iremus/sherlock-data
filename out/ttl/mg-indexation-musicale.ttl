<327b744e-5596-4008-a2ad-e00d1d6a4d2e> a crm:E33_Linguistic_Object,
        crm:E41_Appellation ;
    crm:P190_has_symbolic_content "Ce gras par malheur ; Ce rimeur pour faire un sonnet ; Ton juge s'endort au palais ; Ce gascon par un rude effort ; Ce vieux mari sombre et jaloux ; Que dites-vous de ce poltron ; Regardez cet enfant de Mars ; Des Anciens être entêté ; D'où vient que cet heureux amant ; Je suis un nouveau médecin" ;
    crm:P2_has_type <a7453d39-b7f0-4ca2-ba62-9fc560438c60> .

<327c57d9-99aa-4077-9ec6-44f5c756564b> a lrm:E65_Creation ;
