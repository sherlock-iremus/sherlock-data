<19dc2514-1e55-43f3-91f3-05262109f8e7> a crm:E33_Linguistic_Object,
        crm:E41_Appellation ;
    crm:P190_has_symbolic_content "Que ne devons-nous pas au retour du printemps" ;
    crm:P2_has_type <a7453d39-b7f0-4ca2-ba62-9fc560438c60> .

<19e8d1cb-2530-46ef-b64d-a609eb8a96bd> a crm:E33_Linguistic_Object,
        crm:E41_Appellation ;
    crm:P190_has_symbolic_content "Un soir dans une grotte obscure ; Lors que l'excès de ma souffrance ; Quand sur ma musette plaintive ; De fleurs fraîchement amassées ; De ma soeur entre tes compagnes ; Piqué de quelque jalousie ; Quelquefois par un trait de flamme ; Pour me prouver toute la force ; Ingrat interrompt la bergère ; Répandant des pleurs d'allégresse ; Un faune habitant de cet antre ; Cette histoire par la contrée" ;
    crm:P2_has_type <a7453d39-b7f0-4ca2-ba62-9fc560438c60> .

