<65f7c10a-c4ea-4117-9342-a1af06d92389> a crm:E33_Linguistic_Object,
        crm:E41_Appellation ;
    crm:P190_has_symbolic_content "Notre fortune est certaine ; Sur les rives de la Seine ; Adieu dame Melpomène ; Ne faites pas tant la vaine ; Rendez ma gloire certaine",
        "Nous n'avons plus de voeux à faire ; Notre Apollon est le parterre ; Au public ne songeons qu'à plaire ; Longtemps de ma juste colère ; La Foire est contrainte à se taire" ;
    crm:P2_has_type <a7453d39-b7f0-4ca2-ba62-9fc560438c60> .

<6645129e-0240-4b2b-b229-dc0543598478> a crm:E35_Title ;
    rdfs:label "CHANSON ; Le Rossignol en cage" .

<664910e0-2abd-4dc9-bce7-2e94811cc5fb> a crm:E33_Linguistic_Object,
        crm:E41_Appellation ;
    crm:P190_has_symbolic_content "CE N'EST POINT SEULEMENT AUX LOUPS" ;
    crm:P2_has_type <5891daa1-81be-494a-8bf9-9055574f0530> .

<665f01c9-515b-4bad-97e6-909cfa1d33c6> a crm:E33_Linguistic_Object,
        crm:E41_Appellation ;
    crm:P190_has_symbolic_content "Ah que le printemps a d'appas" ;
    crm:P2_has_type <a7453d39-b7f0-4ca2-ba62-9fc560438c60> .

<666a7766-fe51-4d59-89ed-066683a5bf59> a crm:E35_Title ;
