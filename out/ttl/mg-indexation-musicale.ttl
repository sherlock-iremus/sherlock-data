<c569c294-2ef4-4b38-98da-cda8f3836496> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <422dbde0-e38c-4ae5-9895-c4d3b2826311> ;
    crm:P141_assigned "Ut Majeur, 3, 80 mesures. Cinq sections, toutes de forme binaire, composent ce duo : - duo (AAB, 14 mesures) - air pour dessus (ut1, AAB, 12 mesures) - air de basse (fa3, AAB, 22 mesures) - duo (AAB, 19 mesures) - reprise du premier duo (AAB, 14 mesures)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

