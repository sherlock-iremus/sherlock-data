<0e4aee1c-fea0-48a4-bccd-a8b37243f0b7> a crm:E33_Linguistic_Object,
        crm:E41_Appellation ;
    crm:P190_has_symbolic_content "Un berger discret et tendre" ;
    crm:P2_has_type <5891daa1-81be-494a-8bf9-9055574f0530> .

<0e4f9bc4-b6f4-4573-be77-8d176fdc5ac5> a crm:E33_Linguistic_Object,
        crm:E41_Appellation ;
    crm:P190_has_symbolic_content "BERGERS AJUSTEZ VOS MUSETTES" ;
