<b5c1e6d5-07ec-43f9-a369-57b8a23a0611> a crm:E33_Linguistic_Object,
        crm:E41_Appellation ;
    crm:P190_has_symbolic_content "Ture lu ture lu ture lure lure ; Un savant par sa ture lure ; En tapinois quand les nuits sont brunes ; Ô crédulité désirable ; Faisons tant de tope et tingue ; Que ce trouble heureux puisse encore ; Au tric-trac petit coup désespère ; Pour nous récréer dit le Sage ; Tictoc choc est bon à coups de verre ; Lucifer d'affreuse mémoire ; Plus je bois et plus ma femme crie ; Deux époux dit un grand oracle" ;
    crm:P2_has_type <a7453d39-b7f0-4ca2-ba62-9fc560438c60> .

