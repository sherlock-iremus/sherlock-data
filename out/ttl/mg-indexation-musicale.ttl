<88184124-3e80-4d53-8eb8-34a02e29accd> a crm:E33_Linguistic_Object,
        crm:E41_Appellation ;
    crm:P190_has_symbolic_content "Par les yeux d'Annette ; La rose nouvelle ; Lorsqu'autour d'Anette ; Quand sur ma musette ; Il me faut attendre" ;
    crm:P2_has_type <a7453d39-b7f0-4ca2-ba62-9fc560438c60> .

<88370021-645d-46f4-bdc2-1dc94b673350> a crm:E33_Linguistic_Object,
