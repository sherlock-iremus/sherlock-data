<7a1a922a-e60d-4cfd-8abf-ae0009e5fa69> a crm:E35_Title ;
    rdfs:label "CHANSON" .

<7a1bfa3c-e1b5-49eb-bf9c-3c2925f5f2b9> a crm:E33_Linguistic_Object,
        crm:E41_Appellation ;
    crm:P190_has_symbolic_content "Une faveur Lisette ; Si j'entens sa musette ; À force de te plaindre ; Pardon belle Lisette ; Est-ce à moi de me plaindre ; Qu'un berger est aimable ; Je laisse de Silvandre" ;
    crm:P2_has_type <a7453d39-b7f0-4ca2-ba62-9fc560438c60> .

<7a32c7fb-43e9-43ec-878d-119ab63d8308> a lrm:E65_Creation ;
    lrm:P94_has_created <2ac0eb13-5dc9-49d0-9ee5-43ee9868e21f> .

<7a6887ba-1167-46f8-a897-6e4205c3bfdf> a crm:E33_Linguistic_Object,
        crm:E41_Appellation ;
    crm:P190_has_symbolic_content "Le doux printemps est enfin de retour" ;
    crm:P2_has_type <a7453d39-b7f0-4ca2-ba62-9fc560438c60> .

<7a75c351-4f5c-4f28-9883-63b0c41ce976> a crm:E33_Linguistic_Object,
        crm:E41_Appellation ;
    crm:P190_has_symbolic_content "QUE SERVENT TOUS CES VAINS DISCOURS" ;
    crm:P2_has_type <5891daa1-81be-494a-8bf9-9055574f0530> .

<7a821aa6-8a7f-42e3-afc9-54d405e40a4a> a crm:E35_Title ;
    rdfs:label "AIR EN RÉCIT" .

<7a84cfc8-c34d-40c9-b582-9a87b1bdf427> a crm:E35_Title ;
