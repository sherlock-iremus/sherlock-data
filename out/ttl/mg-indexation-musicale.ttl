<d6107a1e-ccdf-476c-bb38-8f55f4e19137> a crm:E33_Linguistic_Object,
        crm:E41_Appellation ;
    crm:P190_has_symbolic_content "Quand on a bu la tête tourne ; Qu'entre nous la bouteille tourne ; Ce courtisan dont l'esprit tourne ; Près de Philis la tête tourne" ;
    crm:P2_has_type <a7453d39-b7f0-4ca2-ba62-9fc560438c60> .

<d6140cbf-2d52-4ba5-8586-21a532e9ddc6> a crm:E33_Linguistic_Object,
        crm:E41_Appellation ;
    crm:P190_has_symbolic_content "TOUS MES MAUX SONT FINIS J'AI REVU CE QUE J'AIME" ;
    crm:P2_has_type <5891daa1-81be-494a-8bf9-9055574f0530> .

<d6145c3a-0065-4dff-ad4b-655aae012835> a crm:E35_Title ;
