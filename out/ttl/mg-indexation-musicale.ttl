        crm:E41_Appellation ;
    crm:P190_has_symbolic_content "JE NE VOUS SUIVRAI POINT REDOUTABLES GUERRIERS" ;
    crm:P2_has_type <5891daa1-81be-494a-8bf9-9055574f0530> .

<d5eec3b8-2573-4844-9c6a-748c356488a4> a lrm:E65_Creation ;
