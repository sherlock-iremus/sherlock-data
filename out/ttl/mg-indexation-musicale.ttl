<50cff553-084c-49eb-a117-d979aed5f844> a crm:E33_Linguistic_Object,
        crm:E41_Appellation ;
    crm:P190_has_symbolic_content "L'aimable saison des zéphirs" ;
    crm:P2_has_type <a7453d39-b7f0-4ca2-ba62-9fc560438c60> .

<50e3b3b7-ae42-4801-8c48-4b4a54c04111> a crm:E33_Linguistic_Object,
        crm:E41_Appellation ;
    crm:P190_has_symbolic_content "VOUS DEMANDEZ DES VERS ET SI J'EN CROIS VOS YEUX" ;
    crm:P2_has_type <5891daa1-81be-494a-8bf9-9055574f0530> .

<50e4b981-12d1-41f9-9ae3-79e286407f88> a crm:E33_Linguistic_Object,
        crm:E41_Appellation ;
    crm:P190_has_symbolic_content "SI VOUS VOULEZ IRIS QU'UNE COULEUR VERMEILLE" ;
    crm:P2_has_type <5891daa1-81be-494a-8bf9-9055574f0530> .

<5104ed96-27d6-4d69-8008-add091fa3366> a crm:E33_Linguistic_Object,
        crm:E41_Appellation ;
    crm:P190_has_symbolic_content "COULE JUS PRÉCIEUX POUR L'OBJET QUI M'ENFLAMME",
        "PLEUREZ AMANTS AUX PIEDS DE VOS MAÎTRESSES" ;
    crm:P2_has_type <5891daa1-81be-494a-8bf9-9055574f0530> .

<510b5bfd-4a57-41ce-9d66-871027434c71> a lrm:E65_Creation ;
    lrm:P94_has_created <8b430fff-b9d5-4822-9327-e93cbf37942b> .

<515ea6ee-7740-4ab7-ad51-62d765800069> a crm:E33_Linguistic_Object,
        crm:E41_Appellation ;
    crm:P190_has_symbolic_content "Ture lu ture lu ture lure lure ; Un savant par sa ture lure ; En tapinois quand les nuits sont brunes ; Ô crédulité désirable ; Faisons tant de tope et tingue ; Que ce trouble heureux puisse encore ; Au tric-trac petit coup désespère ; Pour nous récréer dit le Sage ; Tictoc choc est bon à coups de verre ; Lucifer d'affreuse mémoire ; Plus je bois et plus ma femme crie ; Deux époux dit un grand oracle" ;
    crm:P2_has_type <a7453d39-b7f0-4ca2-ba62-9fc560438c60> .

<5162f19b-9f74-44b3-a853-fcfd1c29f85c> a lrm:E65_Creation ;
    lrm:P94_has_created <8476d3b2-e02b-421d-8309-ddfea846d82e> .

<516e9f48-08de-4fd5-8495-82dd1baf21a9> a crm:E33_Linguistic_Object,
        crm:E41_Appellation ;
    crm:P190_has_symbolic_content "LE SOLEIL SUR NOS CHAMPS TROP LONGTEMPS ARRÊTÉ" ;
    crm:P2_has_type <5891daa1-81be-494a-8bf9-9055574f0530> .

<51774753-5f77-4b7d-bd11-4f74e71e6edd> a crm:E33_Linguistic_Object,
        crm:E41_Appellation ;
    crm:P190_has_symbolic_content "AH PRINTEMPS VOS DOUCEURS" ;
    crm:P2_has_type <5891daa1-81be-494a-8bf9-9055574f0530> .

<517f3751-b518-4236-8a2b-8f7e1ccb1f45> a lrm:E65_Creation ;
    lrm:P94_has_created <cbabd0e2-f412-468b-952a-c1666d0dbf0b> .

<51a9746b-a5a4-41dd-a48e-8820e0acef0c> a lrm:E65_Creation ;
    lrm:P94_has_created <4d8c7e35-19bb-4a67-9b09-2af83bb80ac4> .

<51c0581a-0bf6-42ec-b29d-bf40a6262c3d> a crm:E33_Linguistic_Object,
        crm:E41_Appellation ;
    crm:P190_has_symbolic_content "En vain tu peins nos champs des plus vives couleurs" ;
    crm:P2_has_type <a7453d39-b7f0-4ca2-ba62-9fc560438c60> .

<52214627-f7aa-4eb9-8ecf-c7975a70c8f0> a lrm:E65_Creation ;
    lrm:P94_has_created <cede94f3-5cd9-4919-9a3b-3360f54d0830> .

<5228aff9-2c79-43d6-bc46-f2043b4a69e3> a crm:E33_Linguistic_Object,
        crm:E41_Appellation ;
    crm:P190_has_symbolic_content "Sans frayeur dans ce bois seule je suis venue" ;
    crm:P2_has_type <5891daa1-81be-494a-8bf9-9055574f0530> .

<522dd038-911a-47a3-8b7a-e1d3f98664cd> a crm:E35_Title ;
