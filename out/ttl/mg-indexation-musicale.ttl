<fe7ca4e4-c13e-4abe-9b90-89f1f509c38d> a crm:E33_Linguistic_Object,
        crm:E41_Appellation ;
    crm:P190_has_symbolic_content "L'INHUMAINE L'INGRATE A PU M'ABANDONNER" ;
    crm:P2_has_type <5891daa1-81be-494a-8bf9-9055574f0530> .

<fe93e9c5-4ce3-41a4-90dd-ff3e1e8efe12> a crm:E35_Title ;
    rdfs:label "AIR NOUVEAU" .

<feaf3c0e-c13f-4905-aada-08ceb5342869> a crm:E33_Linguistic_Object,
        crm:E41_Appellation ;
    crm:P190_has_symbolic_content "Habitants de ces bois chantez sans craindre" ;
    crm:P2_has_type <5891daa1-81be-494a-8bf9-9055574f0530> .

<fec2e91b-ec05-420d-9ddb-7ba37fa6f3b1> a crm:E33_Linguistic_Object,
        crm:E41_Appellation ;
    crm:P190_has_symbolic_content "On ne peut vous voir sans aimer" ;
    crm:P2_has_type <a7453d39-b7f0-4ca2-ba62-9fc560438c60> .

<fec6e21a-b98e-4465-af82-d4381f7d0775> a crm:E33_Linguistic_Object,
        crm:E41_Appellation ;
    crm:P190_has_symbolic_content "Charmante Gabrielle ; Cruelle départie ; Bel astre je vous quitte ; Recevez ma couronne ; Je n'ai pu dans la guerre ; Le fils de Gabrielle ; On n'a que trop à craindre ; Mon aimable maîtresse ; Au milieu de la Flandre ; Ma charmante Isabelle ; Pendant ma longue absence ; Les échos de ces plaines ; Fâcheuse récompense ; Faut-il que j'abandonne ; Quelle douleur extrême ; Le tigre et la tigresse ; Mon coeur est plus à plaindre ; Assurez-moi ma belle" ;
    crm:P2_has_type <a7453d39-b7f0-4ca2-ba62-9fc560438c60> .

<fecd9b4c-0feb-4ab1-aa5a-1b703a41549c> a lrm:E65_Creation ;
    lrm:P94_has_created <c9795087-6b4f-4e9b-980c-46fb2cfc674c> .

<feddfd3c-95bb-4b7d-9d4c-a3e3636adee5> a crm:E35_Title ;
    rdfs:label "AIR NOUVEAU" .

<ff082b32-32d6-4c44-ae02-276fa2fe6780> a crm:E33_Linguistic_Object,
        crm:E41_Appellation ;
    crm:P190_has_symbolic_content "L'agréable printemps va renaitre en ces lieux" ;
    crm:P2_has_type <a7453d39-b7f0-4ca2-ba62-9fc560438c60> .

<ff0f6a0c-d51f-4a13-94dc-ba7e26e2b64c> a crm:E35_Title ;
    rdfs:label "AIR NOUVEAU" .

<ff170f4b-dea7-40f6-b725-58c247ec4c14> a lrm:E65_Creation ;
    lrm:P94_has_created <d90d7c66-8e38-47cd-ac45-a484d4a2d5a5> .

<ff211eca-6913-440a-9fa6-d1b89b918a75> a crm:E33_Linguistic_Object,
        crm:E41_Appellation ;
    crm:P190_has_symbolic_content "MES FEUX QUE TROP LONGTEMPS RENFERME LA CONTRAINTE" ;
    crm:P2_has_type <5891daa1-81be-494a-8bf9-9055574f0530> .

<ff295bcc-05a0-4a06-bcf6-d5bf6bcbcfde> a crm:E33_Linguistic_Object,
        crm:E41_Appellation ;
    crm:P190_has_symbolic_content "O paix charmante paix" ;
    crm:P2_has_type <a7453d39-b7f0-4ca2-ba62-9fc560438c60> .

<ff35df49-ef45-4bb5-bd51-3a4baa1c302f> a crm:E33_Linguistic_Object,
        crm:E41_Appellation ;
    crm:P190_has_symbolic_content "Brillantes fleurs naissez ; Climène sur ces bords ; Et vous charmantes fleurs" ;
    crm:P2_has_type <a7453d39-b7f0-4ca2-ba62-9fc560438c60> .

<ff367b57-37fa-47fb-89f2-6c901351eda2> a crm:E33_Linguistic_Object,
        crm:E41_Appellation ;
    crm:P190_has_symbolic_content "Il est donc vrai que tu romps ta chaîne" ;
    crm:P2_has_type <a7453d39-b7f0-4ca2-ba62-9fc560438c60> .

<ff3e79d9-2a3e-474a-b702-6110dd3ab61a> a lrm:E65_Creation ;
    lrm:P94_has_created <8b180fba-074b-4f40-9cb5-7ff7d890403f> .

<ff406e77-3915-4ac0-8e83-71a2fd67d641> a crm:E33_Linguistic_Object,
        crm:E41_Appellation ;
    crm:P190_has_symbolic_content "QUE MON IRIS EST BELLE" ;
    crm:P2_has_type <5891daa1-81be-494a-8bf9-9055574f0530> .

<ff5827c9-17f3-4931-a8e6-91ebbf14ccf2> a lrm:E65_Creation ;
