        crm:E41_Appellation ;
    crm:P190_has_symbolic_content "HÂTEZ-VOUS DOUX PRINTEMPS",
        "Que je sens de rudes combats" ;
    crm:P2_has_type <5891daa1-81be-494a-8bf9-9055574f0530> .

<6695db2d-05f6-4af3-8a77-f655cd7635dc> a crm:E33_Linguistic_Object,
        crm:E41_Appellation ;
    crm:P190_has_symbolic_content "QUE L'HIVER EN NOS CHAMPS A CAUSÉ DE DOMMAGES" ;
