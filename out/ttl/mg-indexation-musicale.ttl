<85136443-6b95-4a58-a966-14341d9df0bf> a crm:E33_Linguistic_Object,
        crm:E41_Appellation ;
    crm:P190_has_symbolic_content "Je n'ai pour toute maison ; J'ai dans le même canton ; Quand mes amis sont chez moi ; Que la fortune à son gré ; Trop penser est un abus ; Du monde es-tu mécontent" ;
    crm:P2_has_type <a7453d39-b7f0-4ca2-ba62-9fc560438c60> .

<85143ee0-72b8-405b-ab9b-e5ab4bb22ca7> a crm:E33_Linguistic_Object,
