    lrm:P94_has_created <499d1311-e530-42f0-b051-5252637a4a03> .

<756c6b50-bd30-4ee2-9725-cbe806284e65> a crm:E33_Linguistic_Object,
        crm:E41_Appellation ;
    crm:P190_has_symbolic_content "Rien n'est égal à ma douleur ; Beaux yeux dont j'adore les coups" ;
