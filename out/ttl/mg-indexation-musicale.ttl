<7541d928-fd44-4270-8f0f-fec7d08cb747> a crm:E33_Linguistic_Object,
        crm:E41_Appellation ;
    crm:P190_has_symbolic_content "Chantons chantons le jeune roi ; Il est beau comme le beau jour ; Comme fils de bonne maison ; Il mord dit-on dans le Latin ; On voit bien qu'il a de l'esprit ; On assure qu'il est savant ; Quand il danse à son joli bal ; Ce jeune prince est tout charmant ; Mais puisqu'il veut la mériter ; Ah puisque pour tous ses sujets ; Chantons buvons à sa santé" ;
    crm:P2_has_type <a7453d39-b7f0-4ca2-ba62-9fc560438c60> .

<7549c770-145d-4641-bfdb-6973c6f08e2c> a lrm:E65_Creation ;
