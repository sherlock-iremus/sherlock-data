<7ad6f3ab-15f6-4c11-a59c-cf5faf9f7f63> a crm:E33_Linguistic_Object,
        crm:E41_Appellation ;
    crm:P190_has_symbolic_content "CHER AMUSEMENT DE MA VIE" ;
    crm:P2_has_type <5891daa1-81be-494a-8bf9-9055574f0530> .

<7ae17837-9d1c-423b-8c8c-43dd98511494> a crm:E33_Linguistic_Object,
        crm:E41_Appellation ;
    crm:P190_has_symbolic_content "Si pour avoir vu seulement" ;
    crm:P2_has_type <a7453d39-b7f0-4ca2-ba62-9fc560438c60> .

<7b15818e-fd92-4b22-81a9-bad94d12398f> a lrm:E65_Creation ;
    lrm:P94_has_created <3ab6babd-21b4-4483-bad7-3a0fdbcd79bd> .

<7b2bace5-e3b6-49dc-9867-600aac9553d9> a crm:E33_Linguistic_Object,
        crm:E41_Appellation ;
    crm:P190_has_symbolic_content "VENEZ TOUS VENDANGER CHEZ NOUS" ;
    crm:P2_has_type <5891daa1-81be-494a-8bf9-9055574f0530> .

<7b3c62bd-9221-4f37-9e42-19e5c9907f59> a crm:E35_Title ;
