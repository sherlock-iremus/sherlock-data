<5021d7dd-a478-40e2-81d8-8627f814dfbf> a crm:E33_Linguistic_Object,
        crm:E41_Appellation ;
    crm:P190_has_symbolic_content "Que je crains de Tircis le respect dangereux" ;
    crm:P2_has_type <a7453d39-b7f0-4ca2-ba62-9fc560438c60> .

<502fb0a3-13b0-493a-9643-7086ba709601> a lrm:E65_Creation ;
