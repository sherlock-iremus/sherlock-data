<83f295df-cfed-445e-a0de-a778503f18ea> a crm:E33_Linguistic_Object,
        crm:E41_Appellation ;
    crm:P190_has_symbolic_content "Amis que ma joie est extrême ; Qu'un mysantrope à sa tristesse ; Suivez cette douce manie ; Qu'on nous apporte une bouteille ; Amis quelle liqueur aimable" ;
    crm:P2_has_type <a7453d39-b7f0-4ca2-ba62-9fc560438c60> .

<83ff2ab5-1828-4ff5-8276-663fabfb1036> a crm:E33_Linguistic_Object,
        crm:E41_Appellation ;
    crm:P190_has_symbolic_content "Tous mes maux sont finis j'ai revu ce que j'aime" ;
    crm:P2_has_type <a7453d39-b7f0-4ca2-ba62-9fc560438c60> .

<8406b705-feeb-4e47-9f40-20da6ba7139c> a crm:E33_Linguistic_Object,
        crm:E41_Appellation ;
    crm:P190_has_symbolic_content "Le vin endort l'amour et le vin le réveille" ;
