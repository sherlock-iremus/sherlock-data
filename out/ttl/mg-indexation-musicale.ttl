<9b9e4f0b-ce9b-420c-be02-5844338ce58d> a crm:E33_Linguistic_Object,
        crm:E41_Appellation ;
    crm:P190_has_symbolic_content "Le fier Tircis armé de sa houlette ; Ce beau berger pour qui seul je soupire ; En vain mes yeux auprès de ce volage ; Mais c'est en vain qu'il résiste à ma flamme" ;
    crm:P2_has_type <a7453d39-b7f0-4ca2-ba62-9fc560438c60> .

