<5036d4a4-d772-4ece-91a8-630f7275a10b> a crm:E33_Linguistic_Object,
        crm:E41_Appellation ;
    crm:P190_has_symbolic_content "Retirez-vous dieux de terre et de fange ; Riches habits or argent Dieux du monde ; Jeux ris plaisirs opéra comédie ; Beauté molesse amour illégitime ; Faste grandeur dignité rang couronne ; Que voyons-nous en sa sainte naissance" ;
    crm:P2_has_type <a7453d39-b7f0-4ca2-ba62-9fc560438c60> .

<50722ed2-4dde-4ffc-abda-f0e6e38e9528> a lrm:E65_Creation ;
