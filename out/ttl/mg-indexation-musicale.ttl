        crm:E41_Appellation ;
    crm:P190_has_symbolic_content "Je vivrai sous tes lois adorable Bacchus",
        "Éveillés comme moi par les soins de l'amour" ;
    crm:P2_has_type <a7453d39-b7f0-4ca2-ba62-9fc560438c60> .

