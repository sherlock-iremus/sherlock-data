<7b576897-f5f0-4470-81ad-b89b0b76492d> a crm:E33_Linguistic_Object,
        crm:E41_Appellation ;
    crm:P190_has_symbolic_content "Un berger tendre et constant" ;
    crm:P2_has_type <a7453d39-b7f0-4ca2-ba62-9fc560438c60> .

<7b63501e-d571-46f6-9167-a49b11975322> a lrm:E65_Creation ;
    lrm:P94_has_created <8e52e1a7-8ed7-4f64-91d6-0596edcfae56> .

<7b6d1a1d-b607-49f2-a819-86bcf1072531> a crm:E33_Linguistic_Object,
        crm:E41_Appellation ;
    crm:P190_has_symbolic_content "Vous vous plaignez de ma tristesse" ;
    crm:P2_has_type <a7453d39-b7f0-4ca2-ba62-9fc560438c60> .

<7b71a36f-d033-4dd7-8a44-3f7dfd6dd737> a crm:E35_Title ;
    rdfs:label "AIR NOUVEAU" .

<7b7384e6-2e6b-471b-b8f3-66cabf62ca9d> a crm:E33_Linguistic_Object,
        crm:E41_Appellation ;
    crm:P190_has_symbolic_content "Coule jus précieux pour l'objet qui m'enflamme",
        "Pleurez amants aux pieds de vos maîtresses" ;
    crm:P2_has_type <a7453d39-b7f0-4ca2-ba62-9fc560438c60> .

<7b7a4bb0-8677-418e-9935-db083e1f49e5> a lrm:E65_Creation ;
    lrm:P94_has_created <f37beb16-4c15-4c86-864d-c27d6749165d> .

<7b7b8f94-e57a-4259-bf66-97f3b8dcf6f5> a lrm:E65_Creation ;
    lrm:P94_has_created <e59cace5-a3c0-4282-a94a-2e44af6f6265> .

<7b8fce55-6539-47cc-a387-e1939ea2529d> a lrm:E65_Creation ;
    lrm:P94_has_created <a5ce48bf-2298-458f-9738-fedf1e19cf1d> .

<7b9b5844-5a9e-48ea-8920-e4cc014cdc54> a crm:E33_Linguistic_Object,
        crm:E41_Appellation ;
    crm:P190_has_symbolic_content "Allez charmant nectar" ;
    crm:P2_has_type <a7453d39-b7f0-4ca2-ba62-9fc560438c60> .

<7b9c8f23-6fe0-4a31-8b4d-a928986356a3> a crm:E33_Linguistic_Object,
        crm:E41_Appellation ;
    crm:P190_has_symbolic_content "Que cet almanach véritable ; Que Bachus pendant cet automne ; En été que toujours la glace ; Ici quand nous verons éclore ; Que tout le tems de la froidure ; Qu'un tendre et galant hyménée" ;
    crm:P2_has_type <a7453d39-b7f0-4ca2-ba62-9fc560438c60> .

<7ba8a03e-f0f1-451f-afdc-2ee1c0a91feb> a crm:E35_Title ;
    rdfs:label "AIR NOUVEAU" .

<7babc0e8-e848-4e4e-8ff4-1c85b42247d2> a crm:E35_Title ;
    rdfs:label "[sans titre]" .

<7bb196e8-126d-4c3c-8a23-9ab8c8e6d93b> a crm:E33_Linguistic_Object,
        crm:E41_Appellation ;
    crm:P190_has_symbolic_content "DE TOUS LES BOIS QUI CROISSENT SOUS LES CIEUX" ;
    crm:P2_has_type <5891daa1-81be-494a-8bf9-9055574f0530> .

<7bb671bf-d174-430b-ae01-a83fdd53785d> a lrm:E65_Creation ;
    lrm:P94_has_created <c010a259-3fcd-49f5-9dc0-3f355e972acd> .

<7bb7bc70-e517-4ccb-ad74-db759624bc38> a crm:E33_Linguistic_Object,
        crm:E41_Appellation ;
    crm:P190_has_symbolic_content "Au printemps la vigne gelée ; Pouvu qu'à Paris comme à Rome ; Vive l'amour meurent les vignes" ;
    crm:P2_has_type <a7453d39-b7f0-4ca2-ba62-9fc560438c60> .

<7bc728f4-ce74-4ed7-928d-6a653ce9ad4b> a lrm:E65_Creation ;
    lrm:P94_has_created <fd1b32d3-e265-4ec5-adb1-8fd7914ea562> .

<7bd44053-a78f-4194-9767-a6f0150d07a3> a crm:E33_Linguistic_Object,
        crm:E41_Appellation ;
    crm:P190_has_symbolic_content "Un Gascon rusé matois ; Nous nous croyons trop heureux ; Un laquais d'agioteur ; Un abbé de ces cantons;  La fille d'un procureur ; Un minois de soixante ans ; D'une attentive maman" ;
    crm:P2_has_type <a7453d39-b7f0-4ca2-ba62-9fc560438c60> .

<7bf1a675-1ee5-48e5-b0b1-ddc5ebd29192> a lrm:E65_Creation ;
    lrm:P94_has_created <bc7e3564-487b-4f97-99f8-62d7898670ef> .

<7bfbe161-11ce-451a-ad96-e10727273ccf> a crm:E33_Linguistic_Object,
        crm:E41_Appellation ;
    crm:P190_has_symbolic_content "CHACUN SE PLAINT QUE CET AUTOMNE" ;
    crm:P2_has_type <5891daa1-81be-494a-8bf9-9055574f0530> .

<7c02b73d-6ce2-4f47-bb14-d76f67cd1481> a lrm:E65_Creation ;
    lrm:P94_has_created <836353a2-5b76-460b-bbfa-ef02ec20ecf8> .

<7c04170d-8236-4c32-8148-f65b5c0be62a> a crm:E33_Linguistic_Object,
        crm:E41_Appellation ;
    crm:P190_has_symbolic_content "Jusqu'à Venizo avez couru" ;
    crm:P2_has_type <5891daa1-81be-494a-8bf9-9055574f0530> .

<7c0980c3-3ff9-4447-bc10-259a3c03bc5b> a crm:E33_Linguistic_Object,
        crm:E41_Appellation ;
    crm:P190_has_symbolic_content "Vous me faites chanter tant que dure le jour" ;
    crm:P2_has_type <a7453d39-b7f0-4ca2-ba62-9fc560438c60> .

<7c1a5304-d6a0-49d8-ac63-7a22c2335329> a crm:E33_Linguistic_Object,
        crm:E41_Appellation ;
    crm:P190_has_symbolic_content "CHER AMI TU TROUVES ÉTRANGE" ;
    crm:P2_has_type <5891daa1-81be-494a-8bf9-9055574f0530> .

<7c212905-3af4-488f-a0e3-743456460d0f> a crm:E35_Title ;
    rdfs:label "AIR NOUVEAU" .

<7c35c323-c816-4678-9adc-0b6f23a05427> a lrm:E65_Creation ;
    lrm:P94_has_created <f07078ae-dcee-4e62-81b6-cd6f228daffb> .

<7c3b6a60-5f1b-4306-a148-080db9547a39> a lrm:E65_Creation ;
    lrm:P94_has_created <5e5c11ea-b60a-4909-af4a-9c46bd39918e> .

<7c4233e9-9258-468a-a1eb-ce3095d43765> a crm:E33_Linguistic_Object,
        crm:E41_Appellation ;
    crm:P190_has_symbolic_content "Une jeune et tendre beauté" ;
    crm:P2_has_type <a7453d39-b7f0-4ca2-ba62-9fc560438c60> .

<7c44c9e2-269b-4fa8-ab0f-d2d8063767be> a crm:E33_Linguistic_Object,
        crm:E41_Appellation ;
    crm:P190_has_symbolic_content "Sans flèches sans carquois" ;
    crm:P2_has_type <5891daa1-81be-494a-8bf9-9055574f0530> .

<7c5041dc-dc64-431d-b6d3-4c5d24e6bf73> a crm:E35_Title ;
    rdfs:label "AIR NOUVEAU" .

<7c68c1b1-f3af-41ea-ac86-6345205bf3ec> a lrm:E65_Creation ;
    lrm:P94_has_created <0b120b95-bcd5-4040-9953-76f0766a7ff7> .

<7c828f21-f30b-4cff-b04d-051b9726b1b5> a lrm:E65_Creation ;
    lrm:P94_has_created <ced85216-8ef8-40d8-9414-978ea68e2b63> .

<7c9ac210-3da6-4cef-a9b2-49805746c9ee> a crm:E33_Linguistic_Object,
        crm:E41_Appellation ;
    crm:P190_has_symbolic_content "CONSOLEZ-VOUS MES CHERS TROUPEAUX" ;
    crm:P2_has_type <5891daa1-81be-494a-8bf9-9055574f0530> .

<7ca907a6-57b0-4f70-b949-7b8afd640903> a crm:E33_Linguistic_Object,
        crm:E41_Appellation ;
    crm:P190_has_symbolic_content "Après m'avoir formé les plus aimables chaînes" ;
    crm:P2_has_type <a7453d39-b7f0-4ca2-ba62-9fc560438c60> .

<7cb675f1-77b8-4c30-9086-88483f949363> a lrm:E65_Creation ;
