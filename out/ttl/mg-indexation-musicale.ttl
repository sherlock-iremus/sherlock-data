<52448886-b793-4ce6-98ad-7f0c79b7eab0> a crm:E33_Linguistic_Object,
        crm:E41_Appellation ;
    crm:P190_has_symbolic_content "Recevez mon coeur pour étrennes" ;
    crm:P2_has_type <a7453d39-b7f0-4ca2-ba62-9fc560438c60> .

<52452119-4d57-47e0-9976-0bbe943e6940> a crm:E33_Linguistic_Object,
