        crm:E41_Appellation ;
    crm:P190_has_symbolic_content "Venez petits oiseaux sous ces charmants ombrages" ;
    crm:P2_has_type <a7453d39-b7f0-4ca2-ba62-9fc560438c60> .

<e870ad33-bff7-42cc-9490-430db0287080> a crm:E33_Linguistic_Object,
