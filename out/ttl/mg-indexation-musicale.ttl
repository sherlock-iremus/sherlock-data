<df119b8f-2663-42b9-830b-cbb66e80cc6b> a crm:E33_Linguistic_Object,
        crm:E41_Appellation ;
    crm:P190_has_symbolic_content "Cher amusement de ma vie ; À peine la naissante Aurore ; Prêtez-vous à l'inquiétude ; Confidente de mon martire ; Un jour si votre heureuse adresse" ;
    crm:P2_has_type <a7453d39-b7f0-4ca2-ba62-9fc560438c60> .

