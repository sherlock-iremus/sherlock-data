        crm:E41_Appellation ;
    crm:P190_has_symbolic_content "Quand on soupire" ;
    crm:P2_has_type <a7453d39-b7f0-4ca2-ba62-9fc560438c60> .

<d82639c7-c1fb-447d-8ec4-81c1f8f71d1f> a crm:E33_Linguistic_Object,
        crm:E41_Appellation ;
    crm:P190_has_symbolic_content "Le vin endort l'amour et le vin le réveille ; L'amour nous fait aimer et l'amour nous fait boire ; Le vin nous fait parler et le vin nous fait taire" ;
    crm:P2_has_type <a7453d39-b7f0-4ca2-ba62-9fc560438c60> .

