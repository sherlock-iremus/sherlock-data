<2f197097-a057-4b87-b1a2-d0a2b5a6fd0a> a crm:E33_Linguistic_Object,
        crm:E41_Appellation ;
    crm:P190_has_symbolic_content "En quittant la Savoie ; Votre auguste présence ; Louis et votre père ; Le Prince qu'on vous donne ; Son coeur comme le vôtre ; La paix ensevelie ; À votre mariage ; Ma flûte est toute prête ; L'on m'entendra sans cesse ; Sur le bord de la Seine" ;
    crm:P2_has_type <a7453d39-b7f0-4ca2-ba62-9fc560438c60> .

