    crm:P190_has_symbolic_content "Victime de l'usage ; Vous qui d'un héritage ; Vous qui dans l'esclavage ; Toi qui mets en ménage ; Vous pour qui tout ouvrage" ;
    crm:P2_has_type <a7453d39-b7f0-4ca2-ba62-9fc560438c60> .

