        crm:E41_Appellation ;
    crm:P190_has_symbolic_content "Ah qu'ils sont courts les beaux jours" ;
    crm:P2_has_type <5891daa1-81be-494a-8bf9-9055574f0530> .

<fc2f4c63-8e11-45a4-898d-b103e7c7c5c6> a crm:E33_Linguistic_Object,
        crm:E41_Appellation ;
    crm:P190_has_symbolic_content "Cessez de vous flatter d'une vaine espérance ; Cessez de vous piquer d'une fausse constance" ;
    crm:P2_has_type <a7453d39-b7f0-4ca2-ba62-9fc560438c60> .

<fc52d842-895c-485d-b3cf-3bb6970b297e> a crm:E33_Linguistic_Object,
