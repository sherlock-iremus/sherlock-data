<d637c85c-cd24-4b9e-8b50-388eb528e561> a crm:E33_Linguistic_Object,
        crm:E41_Appellation ;
    crm:P190_has_symbolic_content "Chante qui voudra le printemps" ;
    crm:P2_has_type <a7453d39-b7f0-4ca2-ba62-9fc560438c60> .

<d63d2643-76e7-4102-89da-2ba1b340d6fd> a crm:E33_Linguistic_Object,
