<7ab64645-b521-4ef2-b040-b9697369f61b> a crm:E33_Linguistic_Object,
        crm:E41_Appellation ;
    crm:P190_has_symbolic_content "TOUTES LES FOIS QUE JE VOUS VOIS" ;
    crm:P2_has_type <5891daa1-81be-494a-8bf9-9055574f0530> .

<7ac26e72-a20c-4ac4-bf7f-e0a5c1c84045> a crm:E35_Title ;
