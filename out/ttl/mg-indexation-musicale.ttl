<ddaf2530-53fa-433a-90a3-9693bec57d65> a crm:E33_Linguistic_Object,
        crm:E41_Appellation ;
    crm:P190_has_symbolic_content "Ce fier défi me piqua l'âme ; Que de ce Dieu l'âme est cruelle ; Le dieu qui fait aux coeurs la guerre;  Lassé des rigueurs de ma belle" ;
