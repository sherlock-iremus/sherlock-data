<e812babe-d7af-4d92-926b-37145b702114> a crm:E33_Linguistic_Object,
        crm:E41_Appellation ;
    crm:P190_has_symbolic_content "C'est dans ces lieux qu'on voit l'amour se plaire ; L'amour croyait n'avoir ni soeur ni frère" ;
    crm:P2_has_type <a7453d39-b7f0-4ca2-ba62-9fc560438c60> .

<e81ca2f2-30f6-4720-8412-146f164144b8> a crm:E33_Linguistic_Object,
        crm:E41_Appellation ;
    crm:P190_has_symbolic_content "Un sot qui veut faire l'habile;  Dans Platon ni dans Épicure ; Grands philosophes je vous blâme ; De ceux qui vivent dans l'Histoire ; Les noirs ministres d'Hypocrate ; L'autre jour à l'Observatoire ; Un nouvelliste politique ; Un usurier sur son grimoire ; De l'homme voici la chimère ; Ni par Cujas ni par Barthole ; Si Raphaël peint le sublime ; Mercure vole à tire d'ailes" ;
    crm:P2_has_type <a7453d39-b7f0-4ca2-ba62-9fc560438c60> .

<e833be57-7fe6-46e4-9be5-d895db532f7d> a lrm:E65_Creation ;
