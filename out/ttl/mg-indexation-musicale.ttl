<507e1319-28a2-4f2b-aa73-9ff537ee0d77> a crm:E33_Linguistic_Object,
        crm:E41_Appellation ;
    crm:P190_has_symbolic_content "Avoir tous les appas de l'aimable jeunesse" ;
    crm:P2_has_type <a7453d39-b7f0-4ca2-ba62-9fc560438c60> .

<50bf039a-ef43-40cc-8224-89e9d5848c07> a crm:E35_Title ;
