<79a7a0d2-8ff8-4dfc-b533-93690339b3bf> a crm:E33_Linguistic_Object,
        crm:E41_Appellation ;
    crm:P190_has_symbolic_content "Assez et trop longtemps une importune absence" ;
    crm:P2_has_type <a7453d39-b7f0-4ca2-ba62-9fc560438c60> .

<79a834f0-55fa-42a8-8f3f-e2f9fa43ed70> a crm:E33_Linguistic_Object,
        crm:E41_Appellation ;
    crm:P190_has_symbolic_content "À la fin ces déserts on repris leur verdure" ;
    crm:P2_has_type <a7453d39-b7f0-4ca2-ba62-9fc560438c60> .

