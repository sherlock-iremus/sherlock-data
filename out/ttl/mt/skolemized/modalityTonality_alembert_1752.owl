  <rdf:Description rdf:about="http://data-iremus.huma-num.fr/id/4282d848-be9a-4360-a379-ff91d28e59ee">
    <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
