  <rdf:Description rdf:about="http://data-iremus.huma-num.fr/id/0ccd96e4-0f9d-4142-ad74-5e78a9eb5b8e">
    <owl:annotatedTarget>vingt-quatre modes</owl:annotatedTarget>
