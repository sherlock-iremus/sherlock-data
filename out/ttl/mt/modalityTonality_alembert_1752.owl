  <rdf:Description rdf:about="http://data-iremus.huma-num.fr/id/bbc95442-98a3-4737-b847-890821915279">
    <owl:annotatedTarget>"Le mode d'ut (fa, ut, sol) est appellé mode principal par rapport aux modes de ses deux quintes, qui sont appellées ses deux adjoints." (art 40)</owl:annotatedTarget>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Axiom"/>
    <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#comment"/>
