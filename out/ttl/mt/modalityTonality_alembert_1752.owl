    <owl:annotatedSource rdf:resource="http://modality-tonality.huma-num.fr/static/ontologies/modalityTonality_d_Alembert#dominanteTonique"/>
    <dc:source>242-5</dc:source>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Axiom"/>
    <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#comment"/>
    <owl:annotatedTarget>"La dominante tonique, qui est la quinte au-dessus de la tonique, et qui, soit dans le mode majeur, soit dans le mineur, porte toûjours un accord de septiéme composé [-158-] d'une tierce majeure suivie de deux tierces mineures."
(art 242-5)</owl:annotatedTarget>
  </rdf:Description>
