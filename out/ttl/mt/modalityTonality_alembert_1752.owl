  <rdf:Description rdf:about="http://data-iremus.huma-num.fr/id/762392ce-473d-4cbf-80c6-9ce979df344f">
    <owl:annotatedTarget rdf:resource="http://data-iremus.huma-num.fr/id/ee85ec39-233b-4f7e-8cac-0f37c9f4dbde"/>
    <owl:annotatedSource rdf:resource="http://modality-tonality.huma-num.fr/static/ontologies/modalityTonality_d_Alembert#basseFondametale_SibFaUt"/>
