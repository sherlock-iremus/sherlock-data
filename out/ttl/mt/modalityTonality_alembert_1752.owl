  <rdf:Description rdf:about="http://data-iremus.huma-num.fr/id/711f1ae7-4676-4279-9f48-be8a019d7fcb">
    <owl:annotatedTarget>Définition de mode : 

" 38. LE mode en musique n'est autre chose que l'ordre prescrit entre les sons, tant en harmonie qu'en mélodie, par la progression des quintes."</owl:annotatedTarget>
    <owl:annotatedSource rdf:resource="http://modality-tonality.huma-num.fr/static/ontologies/modalityTonality_d_Alembert#mode"/>
    <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#comment"/>
    <dc:source rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">38</dc:source>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Axiom"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://data-iremus.huma-num.fr/id/37a4df07-0c6e-4b4b-916c-f054efbe558e">
    <owl:annotatedTarget rdf:resource="http://data-iremus.huma-num.fr/id/406c78b8-ef83-49a3-bd6e-c75bdb1b12e4"/>
    <owl:annotatedSource rdf:resource="http://modality-tonality.huma-num.fr/static/ontologies/modalityTonality_d_Alembert#melodic_ut_mi_sol_ut"/>
    <rdfs:comment>"28. Ce chant ut, mi, sol, ut, dans lequel la tierce ut mi est majeure, constitue ce qu'on [-20-] appelle le genre ou mode majeur; d'où il s'ensuit que le mode majeur est l'ouvrage immédiat de la nature."</rdfs:comment>
    <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Axiom"/>
    <dc:source rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">28</dc:source>
  </rdf:Description>
