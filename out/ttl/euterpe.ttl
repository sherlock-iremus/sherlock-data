<90f957f9-bf38-4a37-b5a2-dee4792498dc> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <5fcb79d7-d7fe-4a22-998c-236b903f6cda> ;
    crm:P141_assigned """L'estampe d'après ce dessin figure dans le livre de Danchet "Le Sacre de Louis XV, Roy de France et de Navarre en l'église de Reims le 25 octobre 1722", Paris, 1723. Un exemplaire est conservé à la Bibliothèque municipale de Versailles (Rés. gr. un fol. 1210 d). 
L'auteur du catalogue "Versailles et la musique de cour" (Versailles 2007, p. 52 n° 66) qui commente la gravure précise que "les hautbois, tambours et trompettes ayant fait partie du cortège donnent ensuite un concert pendant le festin royal suivant la cérémonie.\"""" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

