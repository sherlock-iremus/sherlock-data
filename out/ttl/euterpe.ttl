    crm:P140_assigned_attribute_to <98d65a33-379a-4322-b379-c67676708aeb> ;
    crm:P141_assigned """Le motif est repris d'un carton de tapisserie de Rubens pour la tenture de l'histoire de Constantin. Le réel sujet de cette image représente le double mariage de Constantin avec Fausta et de Constance avec Lucinius (voir aussi).
Constance Chlore, le père de Constantin et Maximilien Galere reçurent le titre de César par Dioclitien.""" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type <48b6de1f-259b-41b9-af48-a1a05094ab9f> .

