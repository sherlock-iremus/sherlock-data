<63c6be7c-dfb9-44ec-a7bb-278e8cfa8836> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <b18bedb8-7835-4493-b5d7-97c74ee178ab> ;
    crm:P141_assigned "Montluel est une commune française située dans le Sud-Est de la France, dans le département de l'Ain, en région Auvergne-Rhône-Alpes. Depuis 2014, elle appartient au canton de Maximieux. La commune compte une commune associée: Cordieux (cf. https://fr.wikipedia.org/wiki/Montluel)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<63c86d9a-472f-4f5c-ac6a-aeb988da154b> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <b503d00b-93ff-4eee-bc2e-2a3e0313c489> ;
    crm:P141_assigned "L'église Saint-Louis actuelle date de 1835, elle abritait à l'origine le couvent des Capucins  (cf. http://www.alienor.org/publications/planrelief/ville.htm, consulté le 15 juin 2021)." ;
