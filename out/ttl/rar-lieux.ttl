<5abdd456-da32-493b-90cd-bf5baf3ee8ce> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <8e041d7e-9745-46e6-9577-460b40e2de67> ;
    crm:P141_assigned "Le site internet Des villages de Cassini aux communes d'aujourd'hui mentionne que la commune de Tiffauges s’est appelée Tiffanges durant la période révolutionnaire (http://cassini.ehess.fr/cassini/fr/html/fiche.php?select_resultat=37631)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<5b0e319b-cc53-4221-98fd-45db7fbd10de> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <73412435-c75f-4834-a229-a6c594ea6f69> ;
    crm:P141_assigned "Coucy-le-Château-Auffrique est une commune française du département de l'Aisne et de la région Hauts-de-France, dans l'arrondissement de Laon. La commune de Coucy-le-Château absorba en 1921 celle d'Auffrique-et-Nogent.   (cf. https://fr.wikipedia.org/wiki/Coucy-le-Ch%C3%A2teau-Auffrique. , consulté le 11 décembre 2020)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

