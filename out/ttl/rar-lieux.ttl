<5b6c5c18-6ad4-4066-bfd9-b5d227cf1a48> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <e20787ba-29ce-49f7-b460-a24fdad835a0> ;
    crm:P141_assigned "Marennes est une ancienne commune du Sud-Ouest de la France, située dans le département de la Charente-Maritime en région Nouvelle-Aquitaine. Ses habitants sont appelés les Marennais et les Marennaises. Le 1er janvier 2019, elle fusionne avec Hiers-Brouage pour former la commune nouvelle de Marennes-Hiers-Brouage.   (cf. https://fr.wikipedia.org/wiki/Marennes_(Charente-Maritime), consulté le 15 janvier 2021)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<5b84b728-9e45-438f-a5eb-d68e5ca9848a> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <3c240cbc-8633-427b-8609-a4f87173a14b> ;
    crm:P141_assigned "[Le pays de Vaud] devint pays sujet de Berne (de Berne et Fribourg dans les bailliages communs d'Orbe-Echallens et Grandson) jusqu'à la révolution vaudoise (1798).  (Dictionnaire historique de la Suisse, https://hls-dhs-dss.ch/fr/articles/007395/)" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<5b917af9-15bf-47bf-b57c-7e6be2d3b93a> a crm:E13_Attribute_Assignement ;
