<531ee79f-df87-4f26-b606-d2a74257efd8> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <4e25eb36-b11d-407f-abd9-2bec7829eb4e> ;
    crm:P141_assigned "Celles-sur-Belle est une commune du Centre-Ouest de la France située dans le département des Deux-Sèvres, en région Nouvelle-Aquitaine. Le 1er janvier 2019, elle prend le statut de commune nouvelle par sa fusion avec Saint-Médard.   (cf. https://fr.wikipedia.org/wiki/Celles-sur-Belle, consulté le 29 janvier 2021)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<532995cf-7ff6-45b9-943c-91ad02c4bc7a> a crm:E13_Attribute_Assignement ;
