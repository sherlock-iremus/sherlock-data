<68f485c2-56e6-43b4-ab8b-d97af1ad9b29> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <e529c525-7b28-4350-93e9-55cec3bfe0e9> ;
    crm:P141_assigned "Le couvent, détruit, de Santa Maria de Jesús de Figueres était situé hors les murs de Barcelone. Il figure sur cette carte (Paris, Baillieul, XVIIIe s), au nord de la Porte de l'Ange (cf. https://gallica.bnf.fr/ark:/12148/btv1b8458543d, consulté le 25 janvier 2020 ; voir aussi https://www.monestirs.cat/monst/bcn/bn02jesu.htm, consulté le 27 janvier 2021)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<69303f62-cda3-40a8-9f9e-21c19e513089> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <9a60c04f-b30c-4405-bf49-c8ba6e467b59> ;
    crm:P141_assigned "La commune de Lizy a fusionné le 1er janvier 2019 avec Anizy-le-Château et Faucoucourt pour former la commune nouvelle d'Anizy-le-Grand (cf. https://fr.wikipedia.org/wiki/Lizy, consulté le 18 octobre 2021)." ;
