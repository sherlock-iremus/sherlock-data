<ffdceec2-7bba-4d93-b309-40fe9ccf2818> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <22e0a847-386a-4b97-967d-ce07b9640023> ;
    crm:P141_assigned "Les capucins arrivent à Smyrne en 1636. En 1636 Louis XIII, roi de France, acquiert les territoires qui feront partie du couvent et de l'église des capucins de Smyrne, aujourd'hui détruits (cf. http://www.bibliothequefranciscaine.org/L-Eglise-Saint-Polycarpe, consulté le 10 juin 2021).<span style= color: rgb(51, 51, 51); >" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<ffe5dc76-4d18-4206-a56e-5894920e8556> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <fec76e98-618d-49bc-92f8-33b5e333d123> ;
    crm:P141_assigned "Mentionné dès 1315 dans les pactes, Unterwald était un canton de l'ancienne Confédération, dont le territoire et les voix à la Diète étaient partagés entre Unterwald ob dem Wald et Unterwald nid dem Wald, désignations officielles jusqu'en 1999 des demi-cantons d'Obwald et de Nidwald.  (Dictionnaire historique de la Suisse, https://hls-dhs-dss.ch/fr/articles/007409/)" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

