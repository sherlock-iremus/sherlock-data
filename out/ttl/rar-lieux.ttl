<96dca2bd-357e-49dd-a64b-6c9ec03c2147> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <e4e25377-04dd-4a53-8d5b-b52ecce1fff8> ;
    crm:P141_assigned "Faucoucourt, autrefois appelé Foucaucourt et Feucoucourt, est une ancienne commune française, située dans le département de l'Aisne, en région Hauts-de-France. Elle a fusionné le 1er janvier 2019 avec Anizy-le-Château et Lizy pour former la commune nouvelle d'Anizy-le-Grand, dont elle est une commune déléguée. (cf. https://fr.wikipedia.org/wiki/Faucoucourt, consulté le 18 octobre 2021)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

