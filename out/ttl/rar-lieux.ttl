<3b807333-afd9-4903-8430-ed0968ec7bc5> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <32ca786f-f245-41e9-8f3c-38b61eb3df81> ;
    crm:P141_assigned "Cordieux est une commune associée de la commune française de Montluel dans le département de l'Ain. Située au nord de Montluel à environ 5km, Cordieux est une ancienne commune de l'Ain. Depuis 1973, elle est associée à Montluel (cf. https://fr.wikipedia.org/wiki/Cordieux)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<3b944184-f249-4836-ae03-fd166f5bd385> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <8c6eeeaf-7f29-4b0f-8dfb-fe4f30368dab> ;
    crm:P141_assigned "Dangeau est une commune nouvelle, située dans le département d'Eure-et-Loir en région Centre-Val de Loire, créée le 1er janvier 2018. Elle est issue du regroupement de trois communes : Bullou, Dangeau (ancienne commune) et Mézières-au-Perche, sous le statut de commune nouvelle, sans création de communes déléguées.  (cf. https://fr.wikipedia.org/wiki/Dangeau, consulté le 11 décembre 2020)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

