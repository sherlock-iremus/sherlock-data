<48dcea95-a0b5-4138-af39-46fd571ec334> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <fb2e0501-f5ba-4b30-ab11-a21d2f7d4f5f> ;
    crm:P141_assigned "Située sur le territoire géographique du land de Bade-Wurtemberg, Wangen Im Allgaü était une ville libre d’Empire, c’est-à-dire une ville autonome du Saint-Empire romain directement subordonnée à l'empereur et non à un prince d'Empire, grâce à l'immédiateté impériale." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<48e8e05c-b451-4635-9abc-60ff01ccca6f> a crm:E13_Attribute_Assignement ;
