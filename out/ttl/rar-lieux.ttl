<c1663584-1342-430c-9478-a974a0233f85> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <411d1e74-52fe-486b-ba73-71342b143286> ;
    crm:P141_assigned "Les Rosiers s'est appelé en 1993 Les Rosiers-sur-Loire puis a fusionné en 2018 avec Gennes-Val-de-Loire et  Saint-Martin-de-la-Place dans la nouvelle commune de Gennes-Val-de-Loire." ;
