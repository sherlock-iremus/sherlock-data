<5f11dd3d-ba81-480e-ab48-f5f74bcfe8b2> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <c4b4f236-fa62-4fb8-8e52-32b07827cdf6> ;
    crm:P141_assigned "D'après le site Des villages de Cassini aux communes d'aujourd'hui, Caudebec devient Caudebec-en-Caux en 1801.   Rives-en-Seine est une commune nouvelle située dans le département de la Seine-Maritime en région Normandie constituée le 1er janvier 2016, par la fusion de Caudebec-en-Caux, Saint-Wandrille-Rançon et Villequier.  (cf. https://fr.wikipedia.org/wiki/Rives-en-Seine, consulté le 15 janvier 2021)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<5f1f569d-4e97-41c6-9a97-00e43f9dd56e> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <d79acfcb-da4f-42bb-a771-d688fa523879> ;
    crm:P141_assigned "Selon le site des Villages de Cassini aux communes d'ajourd'hui, Châtenay s'est appelé Châtenay-la-Montagne puis Châtenay-les-Bagneux durant la période révolutionaire (cf. http://cassini.ehess.fr/fr/html/fiche.php?select_resultat=8777, consulté le 17 mars 2021)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

