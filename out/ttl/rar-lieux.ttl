<514eb386-affb-4e03-9c46-8b401ee86c1e> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <4ee4ed7e-1abd-411d-ac1e-e2bd33cde223> ;
    crm:P141_assigned "Cette Province se divise en haute &amp; basse Alsace &amp; pays de Sundgau ; la haute Alsace est divisée de la basse, par un fossé pratiqué depuis les montagnes jusqu'à la rivière d'Ill ; &amp; le Diocèse de Strasbourg, de celui de Basle par le ruisseau d'Eggenbach, qui est une lieuë de Schlestat.  (Claude Marin, Dictionnaire universel de la France ancienne et moderne, Paris, Saugrain, Vve J. Saugrain, P. Prault, 1726, t.1, col. 76-77)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

