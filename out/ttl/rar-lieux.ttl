<d2078ffa-7b8d-4fbb-91eb-9692c9d6736e> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <46620b5a-9603-48cb-95cd-24fdc2e8fb91> ;
    crm:P141_assigned "Saint-Pierre-sur-Dives est une ancienne commune française, située dans le département du Calvados en région Normandie, devenue le 1er janvier 2017 une commune déléguée au sein de la commune nouvelle de Saint-Pierre-en-Auge.   (cf. https://fr.wikipedia.org/wiki/Saint-Pierre-sur-Dives, consulté le 11 décembre 2020)." ;
