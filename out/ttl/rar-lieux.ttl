<13f5ffdf-854b-4975-9bd9-e75706a2d300> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <ca0f2f4d-a7e2-4794-a9db-3ea8a93ed028> ;
    crm:P141_assigned "Aunay-sur-Odon est une ancienne commune française, située dans le département du Calvados en région Normandie, peuplée de 3 232 habitants. (cf. https://fr.wikipedia.org/wiki/Les_Monts_d%27Aunay, consulté le 15 janvier 2021).  Depuis le 1er janvier 2017, elle est une des sept communes déléguées de la commune nouvelle des Monts d'Aunay. (cf. https://fr.wikipedia.org/wiki/Les_Monts_d%27Aunay, consulté le 15 janvier 2021)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<14297b28-2ef0-439c-b6eb-f5e53ef7e52d> a crm:E13_Attribute_Assignement ;
