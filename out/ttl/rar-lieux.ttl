<83cb8a13-f5e7-43a2-9a54-94d4b1cf95c0> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <57dc62ff-bc43-46fe-bbae-1ffb47629c55> ;
    crm:P141_assigned "Le site internet Des villages de Cassini aux communes d'aujourd'hui mentionne que la commune de Longny devient Longny-au-Perche en 1926 (http://cassini.ehess.fr/cassini/fr/html/fiche.php?select_resultat=19944).   Longny-au-Perche est une ancienne commune française, située dans le département de l'Orne en région Normandie, devenue le 1er janvier 2016 une commune déléguée au sein de la commune nouvelle de Longny les Villages.   (cf. https://fr.wikipedia.org/wiki/Longny-au-Perche, consulté le 17 décembre 2020)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<83f3067f-9bd2-4f63-b89d-e8b8ff907964> a crm:E13_Attribute_Assignement ;
