<0b0a39f7-0de5-4d3b-b8d8-a88dfc4c672f> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <ebf92fa5-a858-43a9-97b7-352b0628519d> ;
    crm:P141_assigned "Le site internet Des villages de Cassini aux communes d'aujourd'hui mentionne que les communes d'Aufriques et de Nogent-Coucy fusionnèrent entre 1790 et 1794 pour former Auffrique-et-Nogent. Cette nouvelle commune fut réunie en 1921 à Coucy-le-Château [nommée Coucy-le-Châtel sous l'Ancien Régime] pour former Coucy-le-Château-Auffriques (cf. cassini.ehess.fr/cassini/fr/html/fiche.php?select_resultat=1765)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

