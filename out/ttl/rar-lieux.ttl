<fb92b7d9-32f7-4b71-a94f-f9a9185bf3dd> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <82acbe6d-e0ab-48b7-a3a7-bbc36f19cf5d> ;
    crm:P141_assigned "Au cours de la Révolution française, la commune, alors nommée simplement Saint-Amour, porta provisoirement le nom de Bellevue avant de reprendre son nom précédent.\r C'est en 1903 que la commune ajouta le nom révolutionnaire à son nom originel.  (https://fr.wikipedia.org/wiki/Saint-Amour-Bellevue)" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

