<6ec5726a-4917-47fe-b115-e8f4922fd933> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <8deae820-83ba-49a3-a388-309fb0d89698> ;
    crm:P141_assigned "Le château du Theil fut  rasé en 1809. Il gît à présent sous la chaussée de l'ancienne route nationale 6, au niveau du carrefour principal.  (https://fr.wikipedia.org/wiki/Theil-sur-Vanne#cite_ref-3)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<6ecace11-611e-4d01-b9b6-dc74c55f4928> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <95163fc7-51db-4f70-8d68-c31ae8af747b> ;
    crm:P141_assigned "Ouville-la-Bien-Tournée est une ancienne commune française, située dans le département du Calvados en région Normandie, devenue le 1er janvier 2017 une commune déléguée au sein de la commune nouvelle de Saint-Pierre-en-Auge.   (cf. https://fr.wikipedia.org/wiki/Ouville-la-Bien-Tourn%C3%A9e, consulté le 11 décembre 2020)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
