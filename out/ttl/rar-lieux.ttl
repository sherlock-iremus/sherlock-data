    crm:P140_assigned_attribute_to <ffb842f9-0a15-4b44-ba93-86cb11a2740d> ;
    crm:P141_assigned "Mézières-au-Perche est une ancienne commune française située dans le département d'Eure-et-Loir en région Centre-Val de Loire : le 1er janvier 2018, Mézières-au-Perche a fusionné avec Bullou et Dangeau dans la commune nouvelle de Dangeau.   (cf. https://fr.wikipedia.org/wiki/M%C3%A9zi%C3%A8res-au-Perche, consulté le 11 décembre 2020)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

