<4ce0c3d9-9da4-4f6f-837a-c3eb790d72f6> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <1e3f1d53-8802-4cb6-b759-d812f1ae1df7> ;
    crm:P141_assigned "Le château de Limours était un château médiéval et Renaissance, situé sur la commune de Limours, dans le département de l'Essonne. Aujourd'hui détruit, il n'en reste que peu de vestiges, dont principalement un pavillon dessiné par François Mansart.  (https://fr.wikipedia.org/wiki/Ch%C3%A2teau_de_Limours - Consulté le 24-06-2020)" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<4cfca729-4d27-48ab-b2c0-9c17e55a44fc> a crm:E13_Attribute_Assignement ;
