<42bd3b2d-682b-47e3-82b4-b050824bd86e> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <0b58fc35-40e5-44d1-b7b2-00fd3eb5b604> ;
    crm:P141_assigned "Le Palais d’Uceda est un hôtel particulier construit en 1611 pour les ducs d’Uceda, famille importante à la Cour de Philippe III. À la mort de Philippe III, le palais devient résidence pour la famille royale et les membres de la Cour, avant d’accueillir le siège des Conseils d’État (cf. <a href= https://www.do-tours.com/guide/2452-palacio-de-uceda.html  rel= noopener noreferrer  target= _blank >https://www.do-tours.com/guide/2452-palacio-de-uceda.html</a>, consulté le 15/04/2021).  " ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

