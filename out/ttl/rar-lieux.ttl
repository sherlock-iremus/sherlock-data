<de423ed5-6f11-4609-b76b-0bbb7f33435d> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <c35ee619-a43f-48fd-8408-8ba537c25811> ;
    crm:P141_assigned "Ferracière fait partie des Terres Adjacentes qui  échappaient à la compétence de l'Administration provençale pour relever directement du pouvoir royal  (François-Xavier Emmanuelli, « L’administration provinciale des États de Provence (XVIe–XVIIIe siècles). Bilan provisoire », Liame [En ligne], 23 | 2011, p. 9. Mis en ligne le 19 juillet 2011, consulté le 14 mars 2019. URL : http://journals.openedition.org/liame/129 ; DOI : 10.4000/liame.129).\r Marin ne mentionne pas ce bourg en tant que terre adjacente au contraire de l’abbé d’Expilly (Abbé Expilly, Dictionnaire géographique, historique et politique des Gaules et de la France, Amsterdam – Paris : Desaint &amp; Saillant, Bauche, Hérissant, Despilly, Nyon, Leclerc, Pissot, 1768, t.5, p. 973)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<de7c7a28-3786-4acf-b2cb-dd3078416b1e> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <a9f746b2-569f-4254-b9a3-46f00b758a5d> ;
    crm:P141_assigned "CRCV : Corbie [Somme, ch.-l. cant.]" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<de8410ac-7345-4655-beed-f152d5d03261> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <510dd702-36c8-4f63-8f0b-581f81dc08c8> ;
    crm:P141_assigned "Endomagée durant la Révolution puis par le tremblement de terre de 1822,  l'église est presque entièrement reconstruite sous l'impulsion de Mgr Alexandre Devie [de 1835 à 1853]. L'architecte lyonnais Antoine-Marie Chenavard réalise un édifice dans le style néo-gothique, ne conservant de l'ancien que les chapelles absidiales et une partie du portail Nord, ancienne entrée principale de la cathédrale.  (https://fr.wikipedia.org/wiki/Cath%C3%A9drale_Saint-Jean_de_Belley)" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<df30adfc-8de9-4368-9cbf-565f3acf36b3> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <3f9a5195-018c-47fe-a577-5a7ed45db8ef> ;
    crm:P141_assigned "« MALPAS, Malepassus, montagne du Languedoc, qu’on a été obligé de percer pour faire passer le Canal du Languedoc » (Claude Marin, Dictionnaire universel de la France ancienne et moderne, Paris, Saugrain, Vve J. Saugrain, P. Prault, 1726, t.2, col. 465)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

