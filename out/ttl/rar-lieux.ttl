<623caca3-b9c5-4d35-b3d4-c743a7908576> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <39718aec-3b18-488f-ad8e-06f624b73dd9> ;
    crm:P141_assigned "D'après le site des Villages de Cassini aux communes de France, Cours-sous-Magny a été absorbé par Magny en 1830 (http://http://cassini.ehess.fr/cassini/fr/html/fiche.php?select_resultat=10761)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<62a3b4f2-4800-479a-9fa3-1fe1206a69c9> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <d7a605ca-24d2-4a57-8896-c34de2330024> ;
    crm:P141_assigned "Saint-Georges-des-Sept-voies a absorbé en 1840 les villages de Bessay [Bessé], Le Thoureil, Saint-Maur et Saint-Pierre-en-Vaux (cf. http://cassini.ehess.fr/cassini/fr/html/fiche.php?select_resultat=31962). En 2016, Saint-Georges-des-Sept-Voix a intégré la commune nouvelle de Gennes-Val-de-Loire." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

