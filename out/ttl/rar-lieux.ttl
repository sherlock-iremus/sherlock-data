<c9c996de-adac-4d09-9be3-2e8abe237c85> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <b05ba832-f299-49b4-89ac-def9cc4e3db7> ;
    crm:P141_assigned "Pays, qui fait partie du Gouvernement militaire d'Orléanois ; ce Pays est borné au septentrion par le Vendômois &amp; le Dunois, à l'orient par l'Orléanois, au midi par la Sologne, &amp; à l'occident par la Touraine. (Claude Marin, Dictionnaire universel de la France ancienne et moderne, Paris, Saugrain, Vve J. Saugrain, P. Prault, 1726, t.1, col. 437)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

