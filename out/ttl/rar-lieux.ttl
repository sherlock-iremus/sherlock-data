<30a20806-db1b-4b60-8734-5c19dc3f0a3c> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <e920b71b-61d4-4f9b-aab4-1e1fef2a2e69> ;
    crm:P141_assigned "Cordieux est une commune associée de la commune française de Montluel dans le département de l'Ain. Située au nord de Montluel à environ 5km, Cordieux est une ancienne commune de l'Ain. Depuis 1973, elle est associée à Montluel (cf. https://fr.wikipedia.org/wiki/Cordieux)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<30b4c376-6bd2-435e-9324-603aed3eb62d> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <041ae996-79c7-4dfd-b69c-95b6c4eca7b8> ;
    crm:P141_assigned "Aujourd’hui disparue, la forteresse se trouvait à  l’emplacement de l’actuel parc Franck Delmas." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
