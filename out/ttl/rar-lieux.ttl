<803b9f99-1a43-483d-9289-30f3a8708ff4> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <ab97473d-915f-445c-b7f0-19903ab5905f> ;
    crm:P141_assigned "Le Gouvernement Militaire du Havre de Grâce comprend la partie du pays de Caux, qui approche le plus de l'embouchure de la Seine. Il est dépendant de celui de Normandie, &amp; comprend les Gouvernemens particuliers du Havre de Grâce, de Montivilliers, de Fescamp &amp; de Harfleur.  (Claude Marin, Dictionnaire universel de la France ancienne et moderne, Paris, Saugrain, Vve J. Saugrain, P. Prault, 1726, t.2, col. 146)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

