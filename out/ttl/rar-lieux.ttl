    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<4dd3b7f7-c581-413a-842d-ed684b4e646a> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <a6676418-e16f-4c46-b3cf-079cc153aeee> ;
    crm:P141_assigned "L'abbaye de Clairvaux est située sur l'actuelle commune de Ville-sous-la-Ferté. Depuis 1808, les bâtiments de l'abbaye, rachetés par l'État, sont occupés par une institution pénitentiaire française, la maison centrale de Clairvaux, ce qui explique la location approximative de l'abbaye que nous proposons via Geonames." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

