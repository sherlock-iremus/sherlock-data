<138c6b5d-303d-4757-b5a0-2fe47dbbd74b> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <de990917-6f97-4a35-a24a-947e0aacba03> ;
    crm:P141_assigned "Anizy-le-Grand est une commune française située dans le département de l'Aisne en région Hauts-de-France. La nouvelle commune, de statut administratif commune nouvelle, est née le 1er janvier 2019 de la fusion des communes d'Anizy-le-Château, Faucoucourt et Lizy. Son chef-lieu est fixé à Anizy-le-Château  (cf. https://fr.wikipedia.org/wiki/Anizy-le-Grand, consulté le 11 ocotbre 2021). La commune s'est appelée Anizy-la-Rivière pendant la période révolutionnaire (cf. cassini.ehess.fr/fr/html/fiche.php?select_resultat=878)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

