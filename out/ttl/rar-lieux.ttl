<6012bbc3-62a9-46a2-ac23-be5ac2ff1bbe> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <21c91a82-603c-441d-9d98-a754fe1d4610> ;
    crm:P141_assigned "Le Mercure galant relate en juillet 1704 une fête qui s'est déroulée sur une île, près du pont de la ville, qui est probablement le pont nommé Saint-Laurent aujourd'hui." ;
