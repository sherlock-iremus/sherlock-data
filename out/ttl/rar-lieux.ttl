    crm:P177_assigned_property_type crm:P3_has_note .

<e8c5e906-21da-40e5-8ec8-f2aede8cf61f> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <8e7dc845-9cd3-4523-ae72-88ca676194e1> ;
    crm:P141_assigned "Le site internet Des villages de Cassini aux communes d'aujourd'hui mentionne que la commune de Ligueux s'est appelée Ligneux durant la période révolutionnaire (http://cassini.ehess.fr/cassini/fr/html/fiche.php?select_resultat=19572). \r “Au 1er janvier 2016, elle fusionne avec Sorges et devient commune déléguée de la commune nouvelle de Sorges-et-Ligueux-en-Périgord, en région Nouvelle-Aquitaine” (https://fr.wikipedia.org/wiki/Ligueux_(Dordogne)#Histoire)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<e98c45af-5aa0-4859-839e-6612056ee4f0> a crm:E13_Attribute_Assignement ;
