<bcef9b92-b447-4ba1-bf24-a8f9e81d5a30> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <fece1d66-3011-469b-9f67-d70ce28d3b61> ;
    crm:P141_assigned "Province de France, située au milieu du Royaume. Elle est bornée au septentrion par le Bourbonnois, au levant par le Forez, au couchant par le Limosin &amp; la Province de la Marche, &amp; au midi par le Roüergue &amp; le Gevaudan. [...] Cette Province est divisée en haute &amp; basse. [...] Ses Villes les plus considérables sont Clermont, qui est la Capitale de la Province, Riom Siège de l'Intendance, Montferrand, Ambert, Brioude, &amp;c. Celles de la haute sont Aurillac &amp; S. Flour.  (Claude Marin, Dictionnaire universel de la France ancienne et moderne, Paris, Saugrain, Vve J. Saugrain, P. Prault, 1726, t.1, col. 251-252)" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<bcfb213e-638c-4150-8e49-fd5dec01abd4> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <1f484b71-a98d-4420-b313-ab76f25635a2> ;
    crm:P141_assigned "Saint-Leu-Taverni s'est appelé Claire-Fontaine durant la période révolutionnaire (cf.http://cassini.ehess.fr/fr/html/fiche.php?select_resultat=32976, consulté le 28 juin 2021).  En octobre 1915, la commune a été supprimée et les deux communes (Taverny et maintenant Saint-Leu-la-Forêt) constituantes ont été rétablies.  (cf. https://fr.wikipedia.org/wiki/Saint-Leu-Taverny, consulté le 28 juin 2021)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<bd0d82a3-1d4f-4263-8c09-5244a754a5f6> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <7bce7dd3-0672-4b0f-b678-de8247af9f99> ;
    crm:P141_assigned "CRCV : Dordives [Loiret, cant. Ferrières-en-Gâtinais]" ;
