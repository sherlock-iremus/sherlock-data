<00606f4b-4cf7-469a-ba6e-2d15622d5e72> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <1860d70c-082d-483e-a42d-49eb28d40785> ;
    crm:P141_assigned "La commune [de Langeais] est née le 1<sup style= color: rgb(102, 102, 102); >er</sup> janvier 2017 sous le statut administratif de commune nouvelle de la fusion de l'ancienne commune de Langeais et de la commune des Essards qui a pris alors le statut de commune déléguée (cf. https://fr.wikipedia.org/wiki/Langeais)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

