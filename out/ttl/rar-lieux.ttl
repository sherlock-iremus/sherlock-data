    crm:P177_assigned_property_type crm:P3_has_note .

<f9f89d82-341a-4b29-941f-77cf3b1b4847> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <de92e535-35ac-468a-9c3d-c390e89e11f6> ;
    crm:P141_assigned "La cathédrale Notre-Dame-de-l'Assomption de Luçon a été construite à l'emplacement de l'abbatiale de l'ancienne abbaye Notre-Dame et Saint-Benoît de Luçon. Quelques vestiges subsistent encore dans la cathédrale (https://fr.wikipedia.org/wiki/Cath%C3%A9drale_Notre-Dame-de-l%27Assomption_de_Lu%C3%A7on)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

