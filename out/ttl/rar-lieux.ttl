<bf12dd2b-6ac7-447c-908a-dab5081c715e> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <96e9817c-5c8c-44f7-8025-e4b50a9321b3> ;
    crm:P141_assigned "Le pays de Soule et le pays de Bigorre font physiquement partie du gouvernement de Béarn et Navarre mais sont rattachés institutionnellement à la Gascogne." ;
