<bfda2130-8b73-4dfc-935a-cb3fb1893a36> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <eae1a42f-6ca7-4af2-839d-07505d9e73a7> ;
    crm:P141_assigned "La Selle-sur-le-Bied est une commune française située dans le Gâtinais, dans le département du Loiret en région Centre-Val de Loire.  Le 1er mars 2019, la commune absorbe celle de Saint-Loup-de-Gonois en prenant le statut administratif de commune nouvelle  (cf. https://fr.wikipedia.org/wiki/La_Selle-sur-le-Bied#Histoire, consulté le 16 février 2021)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<bfe6d1cc-382b-47f8-84b9-c0b83c3efa4a> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <b6e7fa03-d452-4f0a-9f93-8e1574d1a6cc> ;
    crm:P141_assigned "Sur la carte de George-Louis le Rouge (1757) intitulée “Magdebourg capitale du duché de même nom : une des Fortes places du roy de Prusse a 24 lieues en deça de Berlin, la “Maison royale” est située dans le secteur sud-ouest de la ville, sur la rive gauche de l'Elbe (cf. https://gallica.bnf.fr/ark:/12148/btv1b84955477.r, consulté le 25 mars 2021). " ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<bfe79eac-b2f6-4165-aac6-f9ff8329b9b2> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <aa9f9074-0725-4ae5-99b7-d2a490ddfbd4> ;
    crm:P141_assigned "Saussay a été absorbé par Montfort-le-Rotrou en 1806 (Cassini-ehess : http://cassini.ehess.fr/cassini/fr/html/fiche.php?select_resultat=23430). Par ailleurs, Monfort-le-Rotrou et Pont-de-Gennes ont fusionné au 1er janvier 1986 pour former la commune de Montfort-le-Gennois." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<c0482f02-1de5-4d82-947d-61d3ea29e18d> a crm:E13_Attribute_Assignement ;
