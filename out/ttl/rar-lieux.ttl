<6995137a-04d3-4b79-9b71-5ea798e7a04a> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <c9f51f56-c033-4fd0-9b14-7d9e5083910c> ;
    crm:P141_assigned "Dans la Normandie, Diocèse, Parlement et Intendance de Paris, Election de Chaumont, a 401 habitans. M de Villeroy en est Seigneur.  (Claude Marin, Dictionnaire universel de la France ancienne et moderne, Paris, Saugrain, Vve J. Saugrain, P. Prault, 1726, t.2, col. 1078). Le site internet Des villages de Cassini aux communes d'aujourd'hui mentionne que la commune de Parnes a absorbé celle d'Halincourt [dans le Vexin françois] entre 1790 et 1794 (http://cassini.ehess.fr/cassini/fr/html/fiche.php?select_resultat=61755). (fr)" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<6995db6d-3b7f-4a00-8c66-8a5e34bfd0a9> a crm:E13_Attribute_Assignement ;
