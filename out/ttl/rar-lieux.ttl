<ddade566-5b63-49d6-9965-b1c2c2469e68> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <b3941201-8889-49a5-9172-5eaada44fa3b> ;
    crm:P141_assigned "Païs du Gouvernement militaire de Champagne, situé le long de la rivière d'Yonne. Il est borné au septentrion par la Brie, à l'orient par la Champagne propre, au midi par l'Auxerrois, &amp; à l'occident par le Gastinois. Ses Villes considérables, sont Sens, Villeneuve-l'Archevêque, Villeneuve-le-Roy, Joigny, Chablis, &amp; Tonnerre. Ce païs n'a fait partie de la Champagne que depuis la réünion de cette Province.  (Claude Marin, Dictionnaire universel de la France ancienne et moderne, Paris, Saugrain, Vve J. Saugrain, P. Prault, 1726, t.3, col. 123)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<ddc947e7-9f15-4e7e-9893-b849ce0da25d> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <d1c24847-3d08-4f29-9270-c12e3be9dfad> ;
    crm:P141_assigned "Marchienne-au-Pont est aujourd'hui une section de la ville belge de Charleroi située en Région wallonne dans la province de Hainaut." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<ddd950bd-4b9b-4e75-9bd4-d185d0ac3347> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <6ea22a5c-d9dc-4e80-bb64-45565625828e> ;
    crm:P141_assigned "Il commence au Port de Cette, &amp; traversant la Province du Languedoc, il finit à un quart de lieuë au-dessous de Toulouse, dans la Garonne, traverse l'Étang de Thau, l'Orbe &amp; l'Héraut, passe dessous une Montagne percée exprès, &amp; sous un grand nombre de Ponts sous lesquels coulent beaucoup de rivières.  (Claude Marin, Dictionnaire universel de la France ancienne et moderne, Paris, Saugrain, Vve J. Saugrain, P. Prault, 1726, t.1, col. 618-619)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<de12ce27-48f5-4870-b35e-d24489b31eab> a crm:E13_Attribute_Assignement ;
