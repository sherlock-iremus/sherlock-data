<add3cd78-b445-4614-b215-136f2b4190e4> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <f61b7446-63da-4120-904e-da44b519e4a8> ;
    crm:P141_assigned "Le site internet Des villages de Cassini aux communes d'aujourd'hui mentionne que la commune de Chamant absorbe celle de Balagny-sur-Aunette en 1825 (http://cassini.ehess.fr/cassini/fr/html/fiche.php?select_resultat=7746)." ;
