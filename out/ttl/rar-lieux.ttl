<aba3662c-5f30-4c6a-8682-0000c141db25> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <5d06fff7-2502-41e5-89ed-90602c54327f> ;
    crm:P141_assigned "Ligueux est une ancienne commune française située dans le département de la Dordogne. Au 1er janvier 2016, elle fusionne avec Sorges et devient commune déléguée de la commune nouvelle de Sorges et Ligueux en Périgord, en région Nouvelle-Aquitaine.   (cf. https://fr.wikipedia.org/wiki/Ligueux_(Dordogne), consulté le 17 décembre 2020)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<abac2eb7-11e7-48a6-b56c-8a0b39f9711f> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <c8288ee4-b428-4e6e-96da-83b8a67b59c5> ;
    crm:P141_assigned "<strong style= color: rgb(0, 0, 0); > Bion</strong>est une ancienne<a href= https://fr.wikipedia.org/wiki/Commune_(France)  rel= noopener noreferrer  target= _blank  style= color: var(--accent-color)  ; >commune française</a>, située dans le<a href= https://fr.wikipedia.org/wiki/D%C3%A9partement_fran%C3%A7ais  rel= noopener noreferrer  target= _blank  style= color: var(--accent-color)  ; >département</a>de la<a href= https://fr.wikipedia.org/wiki/Manche_(d%C3%A9partement)  rel= noopener noreferrer  target= _blank  style= color: var(--accent-color)  ; >Manche</a>en<a href= https://fr.wikipedia.org/wiki/R%C3%A9gion_fran%C3%A7aise  rel= noopener noreferrer  target= _blank  style= color: var(--accent-color)  ; >région</a><a href= https://fr.wikipedia.org/wiki/Normandie_(r%C3%A9gion_administrative)  rel= noopener noreferrer  target= _blank  style= color: var(--accent-color)  ; >Normandie</a>, devenue le1<sup>er</sup>janvier 2016une<a href= https://fr.wikipedia.org/wiki/Commune_nouvelle#Communes_d%C3%A9l%C3%A9gu%C3%A9es  rel= noopener noreferrer  target= _blank  style= color: var(--accent-color)  ; >commune déléguée</a>au sein de la<a href= https://fr.wikipedia.org/wiki/Commune_nouvelle  rel= noopener noreferrer  target= _blank  style= color: var(--accent-color)  ; >commune nouvelle</a>de<a href= https://fr.wikipedia.org/wiki/Mortain-Bocage  rel= noopener noreferrer  target= _blank  style= color: var(--accent-color)  ; >Mortain-Bocage</a>.  (cf. https://fr.wikipedia.org/wiki/Bion_(Manche), consulté le 2 avril 2021)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

