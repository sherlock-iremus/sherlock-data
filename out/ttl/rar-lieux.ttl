<a5cd35f3-ebcf-4893-b59c-4c6f15f4ea64> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <6dc56675-17aa-463a-9a71-0a78dbfb55fc> ;
    crm:P141_assigned "Blenio passa aux Suisses en 1495 quand les habitants jurèrent fidélité aux occupants uranais ; en 1503, la paix d'Arona donna la vallée à Uri, Schwytz et Nidwald qui la conservèrent jusqu'en 1798 comme bailliage commun portant en allemand le nom de Bollenz.  (Dictionnaire historique de la Suisse, https://hls-dhs-dss.ch/fr/articles/008541/)" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<a5cfee57-0386-4f57-ba62-19f7d2fad15c> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <bfa49e79-3181-4fb1-8147-feee7b4e935d> ;
    crm:P141_assigned "L’évêché de Blois fut créé en 1697 et la construction du palais épiscopal eut lieu de 1700 à 1704 (https://www.pop.culture.gouv.fr/notice/merimee/IA00141120)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

