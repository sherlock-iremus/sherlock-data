<a146e0d7-5dd5-481c-bd57-4d8fcb974a4a> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <7eb297b7-dd2a-46e4-9f4e-654fd564340f> ;
    crm:P141_assigned "La commune nouvelle nait de la fusion des communes de Boissey, Bretteville-sur-Dives, Hiéville, Mittois, Montviette, L'Oudon, Ouville-la-Bien-Tournée, Sainte-Marguerite-de-Viette, Saint-Georges-en-Auge, Saint-Pierre-sur-Dives, Thiéville, Vaudeloges et Vieux-Pont-en-Auge le 1er janvier 2017. Son chef-lieu est Saint-Pierre-sur-Dives, à la suite de l'arrêté préfectoral du 8 septembre 2016  (Wikipédia : https://fr.wikipedia.org/wiki/Saint-Pierre-en-Auge)" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

