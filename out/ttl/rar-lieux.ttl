<9c07b15e-ed1d-4321-9263-376e3bb0b4d2> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <4017252e-f5ad-4e1b-92df-fe258b8c3620> ;
    crm:P141_assigned "Las Islas de los Ladrones (l'île des voleurs) deviennent Las Marianas (ou Îles Mariannes) à partir de 1688, ainsi nommées d'après Marie-Anne d'Autriche (1635-1696), veuve de Philippe IV d’Espagne." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
