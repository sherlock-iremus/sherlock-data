<6052e7ec-fa6b-4864-968a-5476c364f8a5> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <b0fe253b-5440-4691-9e57-f127af9b62ba> ;
    crm:P141_assigned " Cherbourg-Octeville est une ancienne commune française du département de la Manche. Résultant de la fusion des communes de Cherbourg et d'Octeville le 1er mars 2000, elle devient commune déléguée de Cherbourg-en-Cotentin, commune nouvelle créée le 1er janvier 2016 et issue de la fusion de Cherbourg-Octeville, Équeurdreville-Hainneville, La Glacerie, Querqueville et Tourlaville.  (cf. https://fr.wikipedia.org/wiki/Cherbourg-Octeville, consulté le 1er mars 2021)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<606f5221-a06c-4830-87b5-1f49b3d5827d> a crm:E13_Attribute_Assignement ;
