<79686c66-35a3-4105-932f-fdaded312d0f> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <ff6ae8fc-aa2e-4208-a6bf-7b7c2470b64b> ;
    crm:P141_assigned "[La cathédrale Sante Maria est] connue comme la Catedral Vieja (vieille cathédrale), pour la distinguer de la Catedral Nueva (nouvelle cathédrale), consacrée à l'Immaculée Conception de Marie et érigée au XXe siècle dans le style néogothique.  (https://fr.wikipedia.org/wiki/Cath%C3%A9drale_Santa_Mar%C3%ADa_de_Vitoria)" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

