<f0c47fc0-b8ca-4f7a-b733-6f68ba911982> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <9316c4e1-d8e9-42b5-a859-72a369fc1ce8> ;
    crm:P141_assigned "Vaux, ou Vaux-en-Couhé est une ancienne commune du Centre-Ouest de la France, située dans le département de la Vienne (région Nouvelle-Aquitaine).  [...] Le 1er janvier 2019, elle devient une commune déléguée de Valence-en-Poitou aux côtés de Ceaux-en-Couhé, Châtillon, Couhé et Payré. (cf. https://fr.wikipedia.org/wiki/Vaux_(Vienne), consulté le 17 décembre 2020)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<f0e5adfb-776e-406e-9e69-14fa6ae77b86> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <bcf8db72-5991-4741-8e40-9b47e79fe027> ;
    crm:P141_assigned "Ballon est une ancienne commune française, du département de la Sarthe dans la région Pays de la Loire, devenue une commune déléguée de Ballon-Saint-Mars au 1er janvier 2016.   (cf. https://fr.wikipedia.org/wiki/Ballon_(Sarthe), consulté le 17 décembre 2020)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<f0fea827-8eb0-470e-aab7-1189e8bf38c3> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <b73ca606-392e-4e54-bf55-0f176a9c624f> ;
    crm:P141_assigned "Le château de Falaise (dit château Guillaume-le-Conquérant) est un château fort formé d'une enceinte, situé sur un éperon rocheux au sud-ouest de la ville de Falaise dans le département français du Calvados (région Normandie).  (https://fr.wikipedia.org/wiki/Ch%C3%A2teau_de_Falaise - Consulté le 09-06-2020)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

