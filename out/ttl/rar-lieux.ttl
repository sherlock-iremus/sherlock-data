<da0b030e-ed6b-41cb-8f14-0c92115c404e> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <0711f20e-b217-4d42-a6dd-a7e44f9185f8> ;
    crm:P141_assigned "Située sur le territoire géographique du Cercle de Souabe, Kempten était une ville libre d’Empire, c’est-à-dire une ville autonome du Saint-Empire romain directement subordonnée à l'empereur et non à un prince d'Empire, grâce à l'immédiateté impériale." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<da2034dd-6aa6-416f-9267-56bc197dbc13> a crm:E13_Attribute_Assignement ;
