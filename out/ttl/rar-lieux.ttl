<dfdabbf1-5e63-422f-a943-5a98e9acc6d8> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <6099dfbc-6e0a-4f7b-be3f-1bb462d62d9b> ;
    crm:P141_assigned "Molineuf est une ancienne commune française située dans le département de Loir-et-Cher en région Centre-Val de Loire. Elle intègre la commune nouvelle de Valencisse avec le statut de commune déléguée le 1er janvier 2016.   (cf. https://fr.wikipedia.org/wiki/Molineuf, consulté le 11 décembre 2020). La commune a porté alternativement les noms de Molineuf et Saint-Secondin." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<e00d51a7-1df9-41e0-bd8e-a4e8a41a0ba0> a crm:E13_Attribute_Assignement ;
