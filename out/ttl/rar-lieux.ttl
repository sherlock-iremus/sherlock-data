<e6f95d9c-66d3-4976-abea-e249aaf4db3c> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <1e82c177-24a9-47b9-a7ea-2489769b906f> ;
    crm:P141_assigned "Le collège des Jésuites de Rennes a d'abord été le prieuré des Bénédictines de Saint-Georges (XIIe siècle) puis un hôpital (XVe siècle) et un collège (XVIe siècle) avant d'être donné aux Jésuites en 1604." ;
