<9d0cbd35-2c21-4369-abc0-83b8c909bb47> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <9862e172-be97-409f-b4a4-f2bef73125ca> ;
    crm:P141_assigned "Située sur le territoire géographique du cercle de Basse-Saxe, Lübeck était une ville libre d’Empire, c’est-à-dire une ville autonome du Saint-Empire romain directement subordonnée à l'empereur et non à un prince d'Empire, grâce à l'immédiateté impériale." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<9d0ce12c-788b-48a0-9310-306462e4a405> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <015bcc77-490b-42df-aecc-cd5aa288afcf> ;
    crm:P141_assigned "Château-du-Loir est une ancienne commune française, située dans le département de la Sarthe en région Pays de la Loire [...]. Elle fait partie de la commune nouvelle Montval-sur-Loir.   (cf. https://fr.wikipedia.org/wiki/Ch%C3%A2teau-du-Loir, consulté le 17 décembre 2020)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<9d12454d-4e7d-4931-b059-a1fc54a9d319> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <b43a5e69-fdf5-4340-a2f4-534287f4d1ba> ;
    crm:P141_assigned "La chapelle Saint-Michel du Palais est une église disparue de Paris, située dans l'ancien Palais de justice sur l'île de la Cité [...] Sous l'Ancien Régime, elle accueille la confrérie des pâtissiers, ainsi que celle des sergents du guet. Elle est finalement détruite en 1784  (cf. https://fr.wikipedia.org/wiki/Chapelle_Saint-Michel-du-Palais, consulté le 8 juin 2021)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

