<187d01f3-c45e-4a33-b00d-7dce4c3ed67e> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <25d95a63-8fe7-43d2-8a91-8cea056a6a1f> ;
    crm:P141_assigned " Fourqueux est une ancienne commune française située dans le département des Yvelines en région Île-de-France. Le 1er janvier 2019, elle fusionne en une commune nouvelle avec Saint-Germain-en-Laye.  (cf. https://fr.wikipedia.org/wiki/Fourqueux, consulté le 28 juin 2021)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
