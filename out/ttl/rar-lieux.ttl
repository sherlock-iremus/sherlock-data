<4f480e18-b9a4-47cf-aa0f-20f2d09daf9a> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <f28b3009-3c0a-4462-8be7-32b6153888a8> ;
    crm:P141_assigned "Marnand est une ancienne commune française, située dans le département du Rhône et la région Rhône-Alpes. Elle est partie intégrante de la commune nouvelle de Thizy-les-Bourgs à partir du 1er janvier 2013.   (cf. https://fr.wikipedia.org/wiki/Marnand_(Rh%C3%B4ne), consulté le 17 décembre 2020)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<4f757c9e-e540-43fb-98cb-fc281b225da7> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <297eae5d-1ea2-4ece-b893-4003e0440efb> ;
    crm:P141_assigned "Pays, qui fait partie du haut Dauphiné ; il est du Gouvernement Militaire de cette Province ; il est borné au septentrion par le Graisivaudan ; à l'orient par l'embrunois ; au midi par la Provence ; &amp; à l'occident, par le pays des Baronies &amp; du Diois.  (Claude Marin, Dictionnaire universel de la France ancienne et moderne, Paris, Saugrain, Vve J. Saugrain, P. Prault, 1726, t.2, col. 10)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

