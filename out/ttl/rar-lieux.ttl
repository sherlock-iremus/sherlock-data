<6ba3749f-c88e-4e62-b074-a1f3711ea7ac> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <54c4d965-8b8d-489e-83b4-d84c9900c53c> ;
    crm:P141_assigned "Janville est une ancienne commune française située dans le département d'Eure-et-Loir en région Centre-Val de Loire, devenue le 1er janvier 2019 une commune déléguée au sein de la commune nouvelle de Janville-en-Beauce.   (cf. https://fr.wikipedia.org/wiki/Janville_(Eure-et-Loir), consulté le 17 décembre 2020)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<6be4016f-1449-489b-80f2-0f2c15063e2c> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <333b56fc-f955-4591-8e76-b0f4e63e7755> ;
    crm:P141_assigned "Prise par la Royal Navy en 1708 pendant la guerre de Succession d'Espagne, Minorque devient possession Britanique. Ciutadella perd alors son statut de capitale de l'île au profit de Mahon. L'île est définitivement cédée à l'Espagne par le traité d'Amiens en 1802." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<6bff5311-1723-4f93-b199-cc2dafc4b47b> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <fef63048-7d5f-4b97-9913-a0852e9d46f2> ;
    crm:P141_assigned "CRCV :  Romilly-sur-Seine [Aube, arr. Nogent-sur-Seine]" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<6c384da4-4e0e-4b2d-879b-eddcc7c5d094> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <721bf77d-b979-48ca-b43f-123201c009b6> ;
    crm:P141_assigned "C'est par le décret 97-1331, paru dans le Journal officiel du 3 janvier 1998, que l'appellation de Châlons-sur-Marne est abandonnée au profit de Châlons-en-Champagne." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<6c5aed4d-da0e-44cd-bc9c-9fec55d48b99> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <e52362d4-786f-46d3-8cff-351042bfe6e6> ;
    crm:P141_assigned "Saint-Germain-en-Laye est une commune française située à 19 km à l'ouest de Paris dans le département des Yvelines en région Île-de-France. Elle a depuis le 1er janvier 2019 le statut de commune nouvelle à la suite de l’absorption à cette date de la commune de Fourqueux.  (cf. https://fr.wikipedia.org/wiki/Saint-Germain-en-Laye, consulté le 28 juin 2021)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<6c922c22-407e-47af-9acf-0509879bddd4> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <b13b5e9d-1689-497e-8709-bcc1af2060cf> ;
    crm:P141_assigned "Pays de la basse Picardie, compris entre la Somme &amp; la Canche, borné au septentrion par le Boulonnois, à l'orient par l'Amiénnois, au midi par le Vimeux, &amp; à l'occident par la Mer. [...] Sa Ville Capitale est Abbeville ; les autres considérables sont Montereüil, Ruë, S. Valéry [dans le Vimeux et non dans le Ponthieu], &amp; l'Abbaye de S. Riquier. (Claude Marin, Dictionnaire universel de la France ancienne et moderne, Paris, Saugrain, Vve J. Saugrain, P. Prault, 1726, t.2, col. 1178-1179)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<6c997055-abc1-48de-946a-a7b8859c1a02> a crm:E13_Attribute_Assignement ;
