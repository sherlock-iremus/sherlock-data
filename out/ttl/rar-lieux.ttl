<383bab38-fdb2-445c-aa00-c485dc78cd65> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <cab430bb-4e40-42fd-8696-42082e8ee527> ;
    crm:P141_assigned "Païs particulier de la Beauce, qui fait partie du Gouvernement Militaire de la Province d'Orléanois. Il est borné au septentrion par la Perche, à l'orient par le Dunois, au midi par le Blésois &amp; la Touraine, &amp; à l'occident par le Maine. Sa Ville Capitale est Vendosme, qui l'est aussi du Haut-Vendosmois, autrement nommé petite Beauce. Montoire l'est du Bas-Vendosmois.  (Claude Marin, Dictionnaire universel de la France ancienne et moderne, Paris, Saugrain, Vve J. Saugrain, P. Prault, 1726, t.3, col. 783)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<3848a3c8-4f00-4f76-9639-37b35aa422fb> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <6e67faae-d850-43cc-a58b-4a70993a8e6d> ;
    crm:P141_assigned "Localité appelée Baume-les-Moines sous l’ancien régime, Baume-du-Jura lors de la Révolution puis Baume-les-Messieurs dans le monde contemporain (1968). (fr)" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<386f233a-7b6b-41e5-90ab-cf804f48626b> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <05f971db-4a64-4aab-bf27-2978f39c2740> ;
    crm:P141_assigned "« Des frères capucins s'installent, pour la première fois, à Blois, sous le règne du roi Henri III, vers 1580. Ils s'établissent alors en contrebas des jardins du château, au niveau de l'actuelle chocolaterie Poulain » (https://fr.wikipedia.org/wiki/Couvent_des_Capucins_(Blois).\r L’édifice a aujourd’hui disparu." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<38899f0c-0816-4732-b9e4-aa5022c8cf56> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <13582b5c-d287-4444-bfff-1119dd1398ea> ;
    crm:P141_assigned "Collonges-lès-Premières est une ancienne commune française située dans le département de la Côte-d'Or en région Bourgogne-Franche-Comté  (cf. https://fr.wikipedia.org/wiki/Collonges-lès-Premières, consulté le 16 février 2021). Elle a fusionné le 28 février 2019 avec la commune de Premières pour former la commune nouvelle de Collonges-et-Premières." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<3935910c-0f20-4ff4-9581-df6a6c8420ad> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <36645bd0-09a3-4c32-a1da-72495cafae34> ;
    crm:P141_assigned "CRCV : Alençon [Orne, ch.-l. arr.]" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<393de7c5-994e-4992-9d14-0e3af0aaa49a> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <ccd8e499-22bf-46e7-91bf-500489636041> ;
    crm:P141_assigned "Païs du Dauphiné, borné au septentrion par le Viennois, à l'orient par le Diois, &amp; par le Bailliage des Baronies, au midi par le Tricastinois, &amp; à l'occident par le Rhône. Ce Païs a pris son nom de Valence, sa Ville Capitale. [...] Ses Villes plus considérables après Valence, sont Crest, Montélimart, Donzère, &amp;c.  (Claude Marin, Dictionnaire universel de la France ancienne et moderne, Paris, Saugrain, Vve J. Saugrain, P. Prault, 1726, t.3, col. 735-736) [la ville de Donsère ou Donzère est en fait située dans le Tricastin]." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<3946aed4-ba34-4015-856e-0b80194cb330> a crm:E13_Attribute_Assignement ;
