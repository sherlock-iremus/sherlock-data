<bbdf6a91-3100-4ca7-ae0e-2b75ee3bbc1a> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <13cc37de-15fd-4c38-a051-4e9509237bc8> ;
    crm:P141_assigned "Vieux-Pont-en-Auge est une ancienne commune française, située dans le département du Calvados en région Normandie, devenue le 1er janvier 2017 une commune déléguée au sein de la commune nouvelle de Saint-Pierre-en-Auge.   (cf. https://fr.wikipedia.org/wiki/Vieux-Pont-en-Auge, consulté le 11 décembre 2020)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<bc0556b4-4cfe-47bf-9da6-72080d1b026e> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <7a17cd6c-7cbf-4650-bfbf-7c9a91a8d098> ;
    crm:P141_assigned "Le couvent des Célestins est aujourd'hui disparu.  Fondé au XIVe siècle dans l'actuel 4e arrondissement de Paris [...] il était situé [...] dans Le Marais, entre la rue du Petit-Musc à l'ouest, la rue de l'Arsenal à l'est, la rue de la Cerisaie au nord, le quai des Célestins et la rue de Sully au sud.  ;  Il était la deuxième plus importante nécropole royale, après la basilique Saint-Denis, puisque nombre de princes y furent inhumés.  (https://fr.wikipedia.org/wiki/Couvent_des_C%C3%A9lestins_de_Paris)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<bc1a1282-5e13-4ab8-b7f9-86ca9970894e> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <cefc4279-3e2a-4220-b899-8190fbf2d714> ;
    crm:P141_assigned "Le château de Montargis est un château fort français et une ancienne résidence royale aujourd'hui en grande partie ruinée, situé à Montargis dans le département du Loiret en région Centre Val de Loire." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

