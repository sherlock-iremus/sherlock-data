<6d328a40-eb3c-43a2-845b-4e422dbe1fe7> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <6e171920-58f3-45f8-8210-b26b34cd27f1> ;
    crm:P141_assigned "Les communes de Chénehutte et Les Tuffeaux (qui avait déjà fusionné pour former Chênehutte-les-Tuffeaux), Trèves et Cunault (qui avait déjà fusionné pour former Trèves-Cunault) ont fusionné en 1793 pour devenir la commune de Chênehutte-Trèves-Cunault. Cette commune fait maintenant partie de la commune nouvelle de Gennes-Val-de-Loire." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<6d81bce4-5b15-434d-a494-162781eaf62b> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <9a1eb637-74d2-4a28-85df-9208efbd5cf7> ;
    crm:P141_assigned "CRCV :  Seclin [Nord, arr. Lille]" ;
