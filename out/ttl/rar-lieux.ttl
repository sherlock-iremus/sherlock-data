<908d1bb7-2d63-48b2-a7e4-7e2ccc98e079> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <ac2c06f0-c239-4e93-96ff-048de9f52400> ;
    crm:P141_assigned "Grézillé est une ancienne commune française située dans le département de Maine-et-Loire, en région Pays de la Loire, devenue le 1er janvier 2016, une commune déléguée de la commune nouvelle de Gennes-Val de Loire, puis, le 1er janvier 2018, de Gennes-Val-de-Loire.  (https://fr.wikipedia.org/wiki/Gr%C3%A9zill%C3%A9, consulté le 4 décembre 2020)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

