<48ede49a-6b71-4a53-a2ba-3a30d67335dd> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <e9d0cbc6-512d-4171-be58-017cda100232> ;
    crm:P141_assigned "Vouvray-sur-Loir est une ancienne commune française, située dans le département de la Sarthe en région Pays de la Loire [...]. Le 1er octobre 2016, elle fusionne avec les deux communes de Château-du-Loir et de Montabon pour donner naissance à la nouvelle commune de Montval-sur-Loir qui prend le statut de commune nouvelle.   (cf. https://fr.wikipedia.org/wiki/Vouvray-sur-Loir, consulté le 17 décembre 2020)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<48f3c5de-c7f3-46d6-ae10-3deceb831264> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <7ba82c95-8ee3-4142-be17-0999d5efb57f> ;
    crm:P141_assigned "Le village de Neuilly s'est construit autour d'un port situé sur les deux rives de la Seine [Port de Neuilly]. La partie du village sur la rive droite de la Seine est situé en Isle-de-France propre, celle sur la rive gauche dans le Mantois. (voir : https://www.neuillysurseine.fr/neuilly-en-chronologie)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<48fad410-2f04-44ac-8e2a-f2a69c1ef108> a crm:E13_Attribute_Assignement ;
