    crm:P177_assigned_property_type crm:P3_has_note .

<d0ecdcc8-815a-4597-846c-5bd73afbd381> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <91bf2867-be63-4ae3-a57f-231a93d2a039> ;
    crm:P141_assigned "Le site internet Des villages de Cassini aux communes d'aujourd'hui mentionne que la commune de Choisy-le-Roi s'est d'abord appelée Choisy-sur-Seine puis Choisy (http://cassini.ehess.fr/fr/html/fiche.php?select_resultat=9421)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<d1083c7c-866a-4506-8282-ee5555b0ba9e> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <181019e7-6b9a-4bcf-b6a0-f87411d5b00d> ;
    crm:P141_assigned "“L'ordre des Ursulines s'établit à Ligny en 1643 avec l'aide de la comtesse Marguerite Charlotte de Luxembourg. En 1647, les religieuses s'installent définitivement rue Bayard. En 1734, le monastère s'agrandit et une imposante demeure est édifiée au 56 rue de Strasbourg, qui devient l'entrée officielle du couvent” (cf. https://www.hotel-le-valeran.com/week-end-lorraine/visite-decouvrir-ligny-en-barrois-1.php, consulté le 12 février 2021). " ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<d1243312-6085-4e10-bd49-3d7d5aeabd77> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <f8310297-b06b-4fa9-8d04-eceb1a8fb6b5> ;
    crm:P141_assigned "Rives-en-Seine est une commune nouvelle située dans le département de la Seine-Maritime en région Normandie constituée le 1er janvier 2016, par la fusion de Caudebec-en-Caux, Saint-Wandrille-Rançon et Villequier.   (cf. https://fr.wikipedia.org/wiki/Rives-en-Seine, consulté le 15 janvier 2021)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<d14773e5-d785-455a-aad6-6bc4d21bf495> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <cb6eba6b-caf5-4bb1-9023-684e519d79d3> ;
    crm:P141_assigned "Située sur le territoire géographique du cercle de Souabe, Kaufbeuren était une ville libre d’Empire, c’est-à-dire une ville autonome du Saint-Empire romain directement subordonnée à l'empereur et non à un prince d'Empire, grâce à l'immédiateté impériale." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<d18981e5-f756-4b4f-8122-f5e98300146e> a crm:E13_Attribute_Assignement ;
