<7de97bb2-1562-45a4-b3b3-0eb74bb1e1e5> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <330de643-1add-4ce6-bda4-8b87c3281a33> ;
    crm:P141_assigned "D'après le site Des villages de Cassini aux communes d'aujourd'hui, les villages de Hiers et de Brouage ont été réunis en 1825 (cf. http://cassini.ehess.fr/cassini/fr/html/fiche.php?select_resultat=6061, consulté le 15 janvier 2021)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<7e03fd95-45ef-48f1-98af-7cb5e528e8a0> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <367637c2-2ca6-402e-9fc4-10e454056ba7> ;
    crm:P141_assigned "Province de France qui fait partie du Gouvernement Militaire de la Province de Béarn &amp; Navarre. Cette Province est bornée à l'orient par le pays de Soule ; &amp; au septentrion par le Béarn ; à l'occident par la Gascogne, &amp; au midi par le Pirenées, qui la séparent de la Navarre Espagnole. [...] Ses deux Villes plus considérables sont S. Palais &amp; S. Jean-pied-de-Port ; outre Garrix &amp; la Bastide de Clarence.  (Claude Marin, Dictionnaire universel de la France ancienne et moderne, Paris, Saugrain, Vve J. Saugrain, P. Prault, 1726, t.1, col. 331)" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

