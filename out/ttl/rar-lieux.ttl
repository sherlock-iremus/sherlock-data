<584590be-35e8-45ce-973e-8250d68035f4> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <515d42c0-7a5c-4e63-8984-62d0eef9cab2> ;
    crm:P141_assigned "La commune [de Langeais] est née le 1<sup>er</sup> janvier 2017 sous le statut administratif de commune nouvelle de la fusion de l'ancienne commune de Langeais et de la commune des Essards qui a pris alors le statut de commune déléguée (cf. https://fr.wikipedia.org/wiki/Langeais)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

