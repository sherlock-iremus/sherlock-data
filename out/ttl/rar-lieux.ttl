<597757e1-a088-44fe-8fa6-24d5bd8301ca> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <82488ff0-4ddc-4a77-b346-0adaf8e5d55f> ;
    crm:P141_assigned "Le château de Châlus-Chabrol est un ancien château fort, du XIe siècle, restauré au XVIIe siècle, aujourd'hui en ruine, dont les vestiges se dressent sur la commune française de Châlus dans le département de la Haute-Vienne, en région Nouvelle-Aquitaine. Il est connu pour son siège de 1199 mené par Mercadier, au cours duquel Richard Cœur de Lion est mortellement blessé par un carreau d'arbalète décoché par Pierre Basile  (cf. https://fr.wikipedia.org/wiki/Ch%C3%A2teau_de_Ch%C3%A2lus-Chabrol, consulté le 26 mai)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

