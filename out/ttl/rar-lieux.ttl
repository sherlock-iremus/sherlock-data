<9ff24ed1-236a-40a5-92a1-afcb836cfa3f> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <fcd80f9b-25fa-486e-972a-ddd44b6ec287> ;
    crm:P141_assigned "Le village de Montfort-le-Gesnois est issu du rapprochement de deux communes : Montfort-le-Rotrou et Pont-de-Gennes le 1er janvier 1986 (arrêté préfectoral de fusion simple du 1er novembre 1985) . Il rassemble donc trois anciennes paroisses, celles de Pont-de-Gennes, de Montfort-le-Rotrou et de Saussay, absorbée par Montfort-le-Rotrou en 1806 (https://fr.wikipedia.org/wiki/Montfort-le-Gesnois)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<a0823bf1-c31f-4a13-9850-2f3ba8fdc67c> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <4fa63b01-fe02-42ee-81e9-23990b95a9d4> ;
    crm:P141_assigned "Saint-Mesmin-de-Micy a été réuni à Saint-Privé en 1824 pour former la commune de Saint-Pryvé-Saint-Mesmin." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
