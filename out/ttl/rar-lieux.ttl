<685d2796-c34f-4737-a820-0219ee5676c5> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <3d2feb17-de1c-40e2-8fe3-45f13c3ad627> ;
    crm:P141_assigned "Le Mercure galant de juillet 1704 relate les réjouissances qui eurent lieu à l’hôtel de Pontchartrain le jour de la naissance du duc de Bretagne. Situé rue Neuve des Petits Champs, cet hôtel appartenait en 1704 au chancelier Louis Phélypeaux de Pontchartrain, ancien contrôleur général des finances (https://www2.economie.gouv.fr/files/files/directions_services/caef/Documents/Expositions_virtuelles/ministere_ville/pc.html)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

