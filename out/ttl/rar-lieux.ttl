<bb571ebe-de0d-4959-b9ab-33f1fc132c9d> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <0d6efbef-7003-44a2-8171-c7f8b242fc98> ;
    crm:P141_assigned "Fours-en-Vexin est une ancienne commune française, située dans le département de l'Eure en région Normandie, devenue le 1er janvier 2016 une commune déléguée au sein de la commune nouvelle de Vexin-sur-Epte.  (cf. https://fr.wikipedia.org/wiki/Fours-en-Vexin, consulté le 6 octobre 2021)." ;
