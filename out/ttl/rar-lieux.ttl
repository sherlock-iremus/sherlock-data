<00785239-fc4c-4420-9cb4-935f7a4c9655> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <7d3d1ab3-2c39-4133-bb57-8ba8c15cb4ad> ;
    crm:P141_assigned "Petit Pays de Bourgogne, situé le long de la Loire, sur les confins du Bourbonnois  (Claude Marin, Dictionnaire universel de la France ancienne et moderne, Paris, Saugrain, Vve J. Saugrain, P. Prault, 1726, t.1, col. 543)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<014b3c42-7ae6-499b-a43e-503ab20b9f34> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <f85733b6-ae57-4cc7-9335-2ac8ae94dc9a> ;
    crm:P141_assigned "Pays, &amp; Bailliage du Gouvernement militaire de Dauphiné. Il est borné au septentrion par la Savoye propre, à l'orient par le Comté de Maurienne &amp; le Briençonnois, au midi par le Gapençois &amp; le Diois, &amp; à l'occident par le Viennois. [...] Les Vallées sont fort habitées, il n'y a de Ville que Grenoble, le Bourg d'Oisans, &amp; S. Bonnet.  (Claude Marin, Dictionnaire universel de la France ancienne et moderne, Paris, Saugrain, Vve J. Saugrain, P. Prault, 1726, t.2, col. 76)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<0158998f-8d0e-4afb-aad9-30c1277f2904> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <155127fd-81e0-4dcb-a0c2-6175b1cc9783> ;
    crm:P141_assigned "Un des Etats de la Confédération suisse depuis 1353, le canton de Berne, ainsi nommé de 1798 à 1815 et depuis 1846, a porté aussi d'autres noms:  Ville et République  jusqu'en 1798 et de 1815 à 1831,  République  de 1831 à 1846.   (Dictionnaire historique de la Suisse, https://hls-dhs-dss.ch/fr/articles/007383/)" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<016be061-6cd3-4ee1-a3df-912c67b56058> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <c8a59762-24e1-4597-a161-4d333a346b77> ;
    crm:P141_assigned "Saint-Mesmin-de-Micy a été réuni à Saint-Privé en 1824 pour former la commune de Saint-Pryvé-Saint-Mesmin." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<016d9576-ba8c-49bd-b9fd-724cfe561eab> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <fd192120-8854-4bf4-bcd5-66aee87ac43b> ;
    crm:P141_assigned "CRCV : Notre-Dame-de-Bonne-Nouvelle (abbaye) [Rouen]" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<01e94f8c-3911-4044-88cc-ce3568451a43> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <44edddb9-b617-470e-981e-e1051753f156> ;
    crm:P141_assigned "Franche-Comté ou Comté de Bourgogne. Ce Gouvernement est borné au septentrion par l'Alsace &amp; la Lorraine ; a l'orient par les Cantons Suisses ; au midi et à l'occident par le Gouvernement du duché de Bourgogne.  (Claude Marin, Dictionnaire universel de la France ancienne et moderne, Paris, Saugrain, Vve J. Saugrain, P. Prault, 1726, t.1, col. 1277)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<02313185-0422-41aa-89ae-4dda1bef2146> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <3c4b552d-0f3c-4a45-9560-208fe03f90ed> ;
    crm:P141_assigned "CRCV :  Flavigny-sur-Ozerain [Côte-d'Or, arr. Montbard]" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<0249ba92-5b04-4f6c-82e5-7f64a03121eb> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <a5e7177e-d480-4b6d-8cdb-d3993d103f01> ;
    crm:P141_assigned "Dès l'époque romaine, un gué existait à cet endroit qui se transforma en port où quelques habitations formaient le lieu-dit Nully. C'est en 1790 que la commune de Neuilly fut créée (d'après https://fr.wikipedia.org/wiki/Neuilly-sur-Seine). \r Le village de Neuilly s'est donc construit autour d'un port situé sur les deux rives de la Seine [d'où le nom de Port de Neuilly]. La partie du village sur la rive droite de la Seine est situé en Isle-de-France propre, celle sur la rive gauche dans le Mantois. (voir aussi, l'histoire de Neuilly : https://www.neuillysurseine.fr/neuilly-en-chronologie)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<026865d0-a2bd-4348-8d1c-7de7b021c276> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <85f74d64-0964-4f74-9b40-39d36e4c0f25> ;
    crm:P141_assigned "CRCV :  Saint-Pierre-le-Jeune de strasbourg (église) [Strasbourg]" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<02d0eb76-8671-499b-85e2-a43325ae79a5> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <0434f029-f918-4a59-913d-10abfd4b322f> ;
    crm:P141_assigned "Selon le site Perigny Story,  la seigneurie d’Aytré, comprenait le château des Réaux avec ses terres jusqu’à La Jarne, le Bourg jusqu’à La Courbe actuelle.  (http://perignystory.e-monsite.com/pages/content/histoire-des-voisins/seigneurs-et-maisons-nobles-d-aytre.html). La tour d'entrée, construite au XVIe siècle, est l'unique vestige du château des Réaux et abrite aujourd'hui un centre médico-éducatif (https://fr.wikipedia.org/wiki/Aytr%C3%A9)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<03912336-7d6f-4475-b8b8-e71276907438> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <32db6746-669a-459c-9170-739001047c44> ;
    crm:P141_assigned "CRCV : Corbeil-Essonnes [Essonne, ch.-. cant.]" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<03924d8a-6805-43b2-8c24-69a22be19b72> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <a8cbd2b0-8534-4b9f-83af-2e2de1869463> ;
    crm:P141_assigned "Les Villages Vovéens est, depuis le 1er janvier 2016, une commune nouvelle française située dans le département d’Eure-et-Loir, en région Centre-Val-de-Loire, née de la fusion des communes de Montainville, de Rouvray-Saint-Florentin, de Villeneuve-Saint-Nicolas et de Voves  (https://fr.wikipedia.org/wiki/Les_Villages_Vov%C3%A9ens, consulté le 4 décembre 2020)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<03a1dfcb-9bf5-4dc9-b372-2964d1bd2b04> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <f87b02d8-eeae-4fba-8f32-087fd360196b> ;
    crm:P141_assigned "Pays du Duché de Bourgogne, qui tire son nom de la ville de Dijon : il est borné au septentrion par le pays de Montagne &amp; le Bassigny ; à l'orient par la Franche-Comté, au midi par le Beaunois, &amp; à l'occident par l'Autunois.  (Claude Marin, Dictionnaire universel de la France ancienne et moderne, Paris, Saugrain, Vve J. Saugrain, P. Prault, 1726, t.1, col. 1040)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<03a9afda-a3e9-471c-94d8-17ec435030b9> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <5c14c946-75e9-4e83-a5c8-236c9f5afe39> ;
    crm:P141_assigned "Dans l'entrée Dunkerque, Marin écrit  Cette Ville forme avec un petit territoire voisin, un Gouvernement Militaire de Province, séparé &amp; indépendant de celui de la Flandre Françoise.  (Claude Marin, Dictionnaire universel de la France ancienne et moderne, Paris, Saugrain, Vve J. Saugrain, P. Prault, 1726, t.1, col. 1079)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

