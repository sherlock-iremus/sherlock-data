<e2e40c4c-67ef-4d26-bec1-a00f227af591> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <230b6cc7-46aa-4c20-ac10-28ab32256a25> ;
    crm:P141_assigned "Le site internet Des villages de Cassini aux communes d'aujourd'hui mentionne que la commune de Saint-Germer-de-Fly s'est appelée Saint-Germer après 1801 (sans précision de date) et ce jusqu'en 1961, date à laquelle elle a repris son nom d'avant (http://cassini.ehess.fr/fr/html/fiche.php?select_resultat=32127)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

