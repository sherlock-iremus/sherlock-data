<1d50c80a-445d-4868-9b38-6aa50e51b12a> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <d47fbaa3-122c-4d24-b499-ec5927c45926> ;
    crm:P141_assigned "Le site internet Des villages de Cassini aux communes d'aujourd'hui mentionne que la commune de Lonray s'est aussi appelée Louray entre 1793 et 1801 (http://cassini.ehess.fr/cassini/fr/html/fiche.php?select_resultat=34855). Toutes les autres graphies proviennent de nos cartes anciennes." ;
