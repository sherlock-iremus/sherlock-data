<8f29472b-067e-4b48-90db-af35e7bb9455> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <99398649-eac6-41cd-a4f9-f85a98942231> ;
    crm:P141_assigned "La commune de Saint-Secondin s'est alternativement appelée Molineuf et Saint-Secondin. Elle a définitivement pris le nom de Molineuf en 1913 (Cf. http://cassini.ehess.fr/cassini/fr/html/fiche.php?select_resultat=34611) et est désormais une des communes déléguées de la commune nouvelle de Valencisse." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

