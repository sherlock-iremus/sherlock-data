<2f6947ec-a43b-4532-a78a-1fc558584e16> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <bd4cb48d-99b3-47e2-a722-a25ff7872aec> ;
    crm:P141_assigned "Barbezieux-Saint-Hilaire est une commune du sud-ouest de la France, située dans le département de la Charente (région Nouvelle-Aquitaine). Elle résulte de l'association, en 1973, de la commune de Barbezieux et de celle de Saint-Hilaire.  (cf. https://fr.wikipedia.org/wiki/Barbezieux-Saint-Hilaire, consulté le 26/04/2021)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

