<beb48d87-27c1-4e57-a799-5e03792e5008> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <084a56cd-6382-4a65-9670-393508227c46> ;
    crm:P141_assigned "L'ancien village du Plessis-lez-Tours n'existe plus : ne subsistent que les vestiges du château situés sur le territoire de l'actuelle commune de La Riche." ;
