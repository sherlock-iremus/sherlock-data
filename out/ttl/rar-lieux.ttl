<0ef6deb4-feed-45e1-b376-1e180ea7b118> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <1f8bc52c-51b9-43d0-af1d-8c5fa23162ec> ;
    crm:P141_assigned "«Le théâtre fut construit en 1708 sous Philippe V, à l’initiative de l’acteur italien Francesco Bartoli. Il a accueillit la troupe théâtrale italienne des Trufaldines. Il fut détruit en 1737 par ordre de Philippe V. Un nouveau théâtre fut construit par les architectes Virgilio Rabaglio y Santiago Bonavia , grâce au mécène Francisco Palomares, à l’emplacement de l’actuelle place de Isabel II. Il ouvrit ses portes avec le Demetrio de Metastase, durant le carnaval de 1738. Incendié en 1810 par les Français, démoli en 1817» (cf. <a href= https://operabaroque.fr/Theatres_baroques_Europe.htm  rel= noopener noreferrer  target= _blank >https://operabaroque.fr/Theatres_baroques_Europe.htm</a>, consulté le 12 avril 2021)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

