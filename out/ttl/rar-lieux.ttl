<9c858ab0-045a-415c-b8fa-2ce35152c21f> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <c2eb82bc-288e-4780-9cf3-bf4f1916a48d> ;
    crm:P141_assigned "Château du XVIe siècle dont il ne reste que quelques ruines. Les anciennes caves du château abrite aujourd'hui le musée des faïences (pour plus d'information : https://www.pop.culture.gouv.fr/notice/merimee/PA00082175)." ;
