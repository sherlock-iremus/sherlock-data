<ce012295-d412-413d-b06c-599ed57dcc7a> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <545d9db7-d90e-42c1-90ee-c85d1f950570> ;
    crm:P141_assigned "Le gouvernement de Flandre [...]  est composé d'une partie du Comté de Flandre, du Comté de Cambresis entier ; d'une partie du Comté de Hainaut, d'une partie de l'Evêché de Liège, &amp; d'une partie du Comté de Namur.  (Claude Marin, Dictionnaire universel de la France ancienne et moderne, Paris, Saugrain, Vve J. Saugrain, P. Prault, 1726, t.1, col. 1217)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<ce56ebbb-0933-4427-9c93-2960dfff4992> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <e981220c-6b69-4023-8667-9c612a21be0c> ;
    crm:P141_assigned "«En 1623,César de Bourbonfonde le collège desOratoriensqui devient plus tard le lycée Ronsard, et dont une partie des bâtiments hébergent l'hôtel de ville et l'office du tourisme actuels» (cf. <a href= https://fr.wikipedia.org/wiki/Vend%C3%B4me  rel= noopener noreferrer  target= _blank >https://fr.wikipedia.org/wiki/Vend%C3%B4me</a>, consulté le 22 mars 2021)." ;
