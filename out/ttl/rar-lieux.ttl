<a5572837-4738-4d32-a210-5dd21831b8ec> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <f1ebde6c-9685-4599-9ac1-969e02182395> ;
    crm:P141_assigned "CRCV :  Thenailles [Aisne, arr. Vervins]" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
