<7905c3ef-ad5d-44b3-844c-aec688761f03> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <bd8bbfd4-f060-4fd1-bad0-284640f46d9b> ;
    crm:P141_assigned "Le palais du Coudenberg, anciennement appelé « Palais des anciens ducs de Braban », a été détruit lors d’un incendie en 1731. Des fouilles archéologiques ont permis de localiser au niveau de la Place Royale. (cf. https://fr.wikipedia.org/wiki/Palais_du_Coudenberg, consulté le 5 février 2021)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

