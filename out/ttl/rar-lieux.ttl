<ae9363fb-5910-418e-9844-077e2b8a9988> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <7fa9ce89-fc5f-4684-b2ff-0572dfae0c94> ;
    crm:P141_assigned "Sorges et Ligueux en Périgord est, au 1er janvier 2016, une commune nouvelle française située dans le département de la Dordogne en région Nouvelle-Aquitaine. Elle est issue du regroupement des communes de Ligueux et Sorges.  (cf. https://fr.wikipedia.org/wiki/Sorges_et_Ligueux_en_P%C3%A9rigord, consulté le 17 décembre 2020)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<ae9da938-2375-4d13-b2bf-8549bec7847e> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <c048d816-2bdc-4e39-b4f1-d4093e57efc2> ;
    crm:P141_assigned "Anizy-le-Château, Faucoucourt et Lizy ont fusionné le 1er janvier 2019 pour former la commune nouvelle d'Anizy-le-Grand (cf. https://fr.wikipedia.org/wiki/Anizy-le-Grand, consulté le 11 ocotbre 2021).  La commune s'est appelée Anizy-la-Rivière pendant la période révolutionnaire (cf. cassini.ehess.fr/fr/html/fiche.php?select_resultat=878)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

