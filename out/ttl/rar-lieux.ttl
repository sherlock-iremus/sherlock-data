<c2d1ae99-af9a-43e4-9d02-2505475b9aab> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <961e6212-a4c7-4410-922a-b05adebe3aa1> ;
    crm:P141_assigned "Bretteville-sur-Dives est une ancienne commune française, située dans le département du Calvados en région Normandie, devenue le 1er janvier 2017 une commune déléguée au sein de la commune nouvelle de Saint-Pierre-en-Auge.   (cf. https://fr.wikipedia.org/wiki/Bretteville-sur-Dives, consulté le 11 décembre 2020)." ;
