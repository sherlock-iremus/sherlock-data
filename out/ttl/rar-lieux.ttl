<4986694e-ced4-4ef8-8215-466fd742b22e> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <05a5fb3b-de02-4e73-9735-fa8e3b620cde> ;
    crm:P141_assigned "Saint-Loup-de-Gonois est une ancienne commune française située dans le département du Loiret en région Centre-Val de Loire  (cf. https://fr.wikipedia.org/wiki/Saint-Loup-de-Gonois, consulté le 16 février 2021). Elle a fusionné le 1er mars 2019 avec La Selle-sur-le-Bied pour former la commune nouvelle de La Selle-sur-le-Bied." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<498cea56-c432-47d6-b345-8d8d12237a76> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <a336b60d-e69a-499c-9b3e-9b6082b5ebcb> ;
    crm:P141_assigned "Le village de La Sauve fut créé à la Révolution (http://gael.gironde.fr/pages/Histo_commune.pdf), ce que confirme le dictionnaire universel de Marin qui ne mentionne que  l'abbaye (Claude Marin, Dictionnaire universel de la France ancienne et moderne, Paris, Saugrain, Vve J. Saugrain, P. Prault, 1726, t.3, col. 72-73)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<49be6097-a14a-481e-a5b4-091079074ec9> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <91f52ded-8ae8-4dad-9d15-cedb4c540439> ;
    crm:P141_assigned "En l’an 1083, une église et une dizaine de chaumières forment dans un lieu boisé et humide la paroisse d’Ursine. En 1674, Louvois, ministre de Louis XIV et seigneur de Chaville, inclut ce territoire dans son parc d’agrément. Les habitants d’Ursine doivent alors reconstruire leur village sur le plateau de Vélizy.  (http://annie.baussac.free.fr/velizy/historic/historic.htm)" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<49c879c5-8949-41db-9e7b-64fc378662d4> a crm:E13_Attribute_Assignement ;
