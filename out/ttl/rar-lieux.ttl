<a53f66c0-6f5f-431a-b817-81dc1a8d7ead> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <5efc4815-b50d-4dd7-829f-c92bcf3e55fc> ;
    crm:P141_assigned "Moulicent est une ancienne commune française, située dans le département de l'Orne en région Normandie, devenue le 1er janvier 2016 une commune déléguée au sein de la commune nouvelle de Longny les Villages.   (cf. https://fr.wikipedia.org/wiki/Moulicent, consulté le 17 décembre 2020)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
