<bb9b9092-44a4-4b5f-b1a3-b1df6f83b3aa> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <e0a265e5-f446-47c8-a830-d4e964fc4cb4> ;
    crm:P141_assigned "Le site internet Des villages de Cassini aux communes d'aujourd'hui mentionne que la commune de Nuits est devenue Nuits-Saint-Georges en 1892. Entre  1801 et 1892, cette commune s'est aussi appelée Nuits-sous-Beaune (http://cassini.ehess.fr/cassini/fr/html/fiche.php?select_resultat=25373)." ;
