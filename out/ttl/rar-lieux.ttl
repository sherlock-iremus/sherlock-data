<2ee09414-6bba-4482-bc61-8f94beec62ad> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <25b2dbcc-b60e-4aa7-8730-f04ba8c8ceda> ;
    crm:P141_assigned " La Selle-sur-le-Bied est une commune française située dans le Gâtinais, dans le département du Loiret en région Centre-Val de Loire.  Le 1er mars 2019, la commune absorbe celle de Saint-Loup-de-Gonois en prenant le statut administratif de commune nouvelle  (cf. https://fr.wikipedia.org/wiki/La_Selle-sur-le-Bied#Histoire, consulté le 16 février 2021).<span style= color: rgb(51, 51, 51); >" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<2f0220a5-cc3b-4e27-bb1a-f95d5406f495> a crm:E13_Attribute_Assignement ;
