<7148c0c0-3fb6-4833-ba4a-2b1a0d76a8f8> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <03cf2887-f88b-441e-b172-8ce2b4a26652> ;
    crm:P141_assigned "Dans l'entrée Tonnerre de son dictionnaire, Marin précise  Ville, Comté dans la Champagne [...] Le territoire de son Comté est abondant en vins fort estimés il y a aussi du bled &amp; des menus fruits, mais peu de pâturages. On l'appelle souvent le Tonnerrois, Tornodorensis Ager. C'est un un des Païs qui font parti du Gouvernement de Champagne.  (Claude Marin, Dictionnaire universel de la France ancienne et moderne, Paris, Saugrain, Vve J. Saugrain, P. Prault, 1726, t.3, col. 653)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<7180fe6a-41bb-4696-b53f-2e76d81e8627> a crm:E13_Attribute_Assignement ;
