<b27da126-1d95-4482-a24f-5055c7960dfe> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <10260c1c-b717-4491-9a6c-3029b2a65d10> ;
    crm:P141_assigned "C’est au 10 rue Losserand que l’on trouve le porche de l’entrée de l’ancien couvent des Capucins ainsi que la conciergerie datant du règne du roi Henri IV  (cf. https://paul-bert.jimdofree.com/lieux-faits-et-personnages/faits-divers/couvent-capucins/, consulté le 11 juin 2021)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<b27f4bcc-85c0-40d9-9579-590e5ebbf031> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <3dceaa00-1033-436b-a394-1fc40fa598bb> ;
    crm:P141_assigned "Saint-Denac est un lieu-dit situé sur le territoire de l'actuelle commune de Saint-andré-des-Eaux." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<b2dc6f60-65f6-47da-851a-bea6737f5a84> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <0a620c14-dcb5-473c-92e6-f62967110d8a> ;
    crm:P141_assigned "Hiers-Brouage est une ancienne commune du Sud-Ouest de la France située dans le département de la Charente-Maritime (région Nouvelle-Aquitaine). [...] Le 1er janvier 2019, elle fusionne avec Marennes pour former la commune nouvelle de Marennes-Hiers-Brouage.   (cf. https://fr.wikipedia.org/wiki/Hiers-Brouage, consulté le 15 janvier 2021)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<b2f927b1-a58b-4432-b70b-ad3de056ec3c> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <a5d35f99-7daf-4215-9469-eda101daa5c3> ;
    crm:P141_assigned "Pays, qui fait partie de la Beauce ou Mantoan. Il a pris son nom de Mantes sa Ville Capitale ; il est tout entier du Diocèse de Chartres, &amp; le dernier canton vers la Normandie, où l'on cultive des vignes.  (Claude Marin, Dictionnaire universel de la France ancienne et moderne, Paris, Saugrain, Vve J. Saugrain, P. Prault, 1726, t.2, col. 475)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<b3025017-31f0-4ed0-b8be-669069d78ef1> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <8f7db6ad-2ee1-4fae-977d-9de179f47411> ;
    crm:P141_assigned "Le site internet Des villages de Cassini aux communes d'aujourd'hui mentionne que la commune de Baugé-le-Vieil s’est appelée Viel-Baugé durant la période révolutionnaire (http://cassini.ehess.fr/cassini/fr/html/fiche.php?select_resultat=39806).\r « Le 1er janvier 2013, les communes de Baugé, Montpollin, Pontigné, Saint-Martin-d’Arcé et le Vieil-Baugé se sont regroupées pour former la commune nouvelle dénommée Baugé-en-Anjou, dont Baugé constitue une commune déléguée » (https://fr.wikipedia.org/wiki/Baug%C3%A9)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

