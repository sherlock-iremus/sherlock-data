<8543336c-eaa4-43cb-9427-54a64c1783f5> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <c257221c-333c-4881-873b-a46e30b106d7> ;
    crm:P141_assigned "Le château de Königsberg (en allemand : Königsberger Schloss) était un château situé à Königsberg, en Prusse-Orientale (en Allemagne et depuis 1946 sur le site de Kaliningrad, en Russie). Détruit après-guerre, il est remplacé pendant les années 1960 par la Maison des Soviets de Kaliningrad. Le château était constitué d'une cathédrale, d'un musée et de bâtiments administratifs.  (https://fr.wikipedia.org/wiki/Ch%C3%A2teau_de_K%C3%B6nigsberg - Consulté le 23/06/2020)" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<854650c7-b244-4db8-9f37-cbb16311a583> a crm:E13_Attribute_Assignement ;
