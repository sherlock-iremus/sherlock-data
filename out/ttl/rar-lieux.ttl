<632f40aa-8686-40f0-838b-7febd2d1b03f> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <250f2ed2-41a9-4266-bc2c-aa6e5e2ac48a> ;
    crm:P141_assigned "La commune de Vézins est issue de la réunion des anciennes communautés de Vézins, La Clau et Le Ram.  (https://fr.wikipedia.org/wiki/V%C3%A9zins-de-L%C3%A9v%C3%A9zou). Le Ram est réuni entre 1820-1832, à Vézins-de-Lévézou (http://cassini.ehess.fr/cassini/fr/html/fiche.php?select_resultat=28575)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

