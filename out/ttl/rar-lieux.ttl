<1799e366-a904-412a-aba5-3cd3fa990b4f> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <4a5afe53-afdb-4769-8790-c77ab40c75e2> ;
    crm:P141_assigned "Pays de la Gascogne [...]. Le Bazadois est borné au septentrion &amp; à l'occident par le Bourdelois, à l'orient par l'Agenois, &amp; au midi par le Condomois [...] Ses principales Villes sont Bazas, La Réole, sainte Baseille &amp; Langon.  (Claude Marin, Dictionnaire universel de la France ancienne et moderne, Paris, Saugrain, Vve J. Saugrain, P. Prault, 1726, t.1, col. 328)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

