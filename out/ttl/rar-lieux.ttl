<4c84fa13-b6ef-4e48-9215-1e303bdcbd87> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <c4e7f055-93c6-4c67-8ce5-8219db5f094d> ;
    crm:P141_assigned "Païs, qui fait partie de la Province de Picardie, dont il a été démembré pour être uni au Gouvernement Militaire de l'Isle de France. Il est borné au Septentrion par le Soissonnois ; à l'Orient par la Champagne ; au Midi par la Brie &amp; la Province de l'Isle de France ; &amp; à l'Occident par le Beauvoisis. [...] La Ville Capitale est Crespy ; les autres Villes sont, Senlis, Compiègne, Villers-Cotterêts &amp; la Ferté-Milon.  (Claude Marin, Dictionnaire universel de la France ancienne et moderne, Paris, Saugrain, Vve J. Saugrain, P. Prault, 1726, t.3, col. 742-743)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<4c8a669c-8b2f-4e1a-84aa-42377005ed44> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <586de045-f0cb-4a07-91dc-1ef341ae2287> ;
    crm:P141_assigned "D'après Dom. Cottineau, ce prieuré dépend du diocèse de Sisteron. (Dom L. H. Cottineau, Répertoire topo-bibliographique des abbayes et prieurés, Macon, Protat frères, 1939, t. 2, col. 2904)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<4ca6592a-d2a3-479f-915b-0950abae9193> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <d76af304-3c70-4215-9884-12f75526e81f> ;
    crm:P141_assigned "Château-Gontier est une commune déléguée française, située dans le département de la Mayenne en région Pays de la Loire, peuplée de 11 687 habitants. La fusion de Château-Gontier avec Azé et Saint-Fort au 1er janvier 2019 engendre la création de Château-Gontier-sur-Mayenne.   (cf. https://fr.wikipedia.org/wiki/Ch%C3%A2teau-Gontier, consulté le 7 janvier 2021)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<4cbafbad-9677-4fb4-aa71-da4513847a46> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <517fb17d-9857-40a1-b952-cff5b8081d25> ;
    crm:P141_assigned "Le village de Torcé (ou Torcé-en-Charnie de 1903 à 1973) fusionne avec le village de Viviers en 1973 pour former la commune de Torcé-Viviers-en-Charnie (https://fr.wikipedia.org/wiki/Torc%C3%A9-Viviers-en-Charnie)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

