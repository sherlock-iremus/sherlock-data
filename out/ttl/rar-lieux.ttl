<a696fa01-06a1-4fea-b4bd-02d5c1b970e4> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <964a006c-eccd-45a2-8e1b-290c95fc9ee5> ;
    crm:P141_assigned "”Alytus (Olita en français) est une ville lituanienne, située dans la région de Dzūkija, au sud du pays, à 116 km au sud de Vilnius. Elle est la capitale de l'apskritis éponyme” (cf. https://fr.wikipedia.org/wiki/Apskritis_d%27Alytus, consulté le 23 mars 2021)." ;
