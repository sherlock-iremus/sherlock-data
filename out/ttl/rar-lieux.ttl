<6a0ba517-5035-45eb-b74b-f66d4e2c9125> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <2ad709ed-a696-41cb-837f-c0c5e82cf7b8> ;
    crm:P141_assigned "Ce Village est situé près Paris ; il n'est presque rempli que de cabarets ; il y a un concours extraordinaire de peuple, particulièrement le jour de S. Lambert Patron dudit lieu. Ce Village a pris son nom de Girard de Méret, Abbé de S. Germain des Prez, qui vivoit en 1266. (Claude Marin, Dictionnaire universel de la France ancienne et moderne, Paris, Saugrain, Vve J. Saugrain, P. Prault, 1726, t.3, col. 764)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<6a3b4a90-183f-4c20-beb3-13ff2ab48259> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <678b01c5-9844-44fe-b47c-8e69c88f0544> ;
    crm:P141_assigned "Le château du Plessis-Lès-Tours est situé sur le territoire de l'actuelle commune de La Riche." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<6a3ea9b3-7fac-4e27-a3d1-80639dbe7bc9> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <46768e02-7151-4503-9f5d-899a9fac3da5> ;
    crm:P141_assigned "Veaunes est une commune française située dans le département de la Drôme en région Auvergne-Rhône-Alpes, devenue, le 1er janvier 2016, une commune déléguée de la commune nouvelle de Mercurol-Veaunes.   (cf. https://fr.wikipedia.org/wiki/Veaunes, consulté le 17 décembre 2020)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<6a4cb44f-db4f-404b-982f-dab2df3bdc7d> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <70220761-4266-4156-95cf-fa97202b04c2> ;
    crm:P141_assigned "Pendant la Révolution française, la ville prit le nom de Burges-les-Bains, rappelant à la fois la petite rivière qui traverse la commune et l'activité thermale qui en faisait la réputation. Elle reprit son ancien nom, Bourbon-L'Archambaud, qu'elle a conservé (cf. le site internet Des villages de Cassini aux communes d'aujourd'hui : http://cassini.ehess.fr/cassini/fr/html/fiche.php?select_resultat=5222)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<6a7d2291-45d3-4af1-b730-547a50d36ded> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <aff1bdc8-2a26-45e2-8695-64f3cc52a628> ;
    crm:P141_assigned "Potensac est aujourd'hui rattaché à Ordonnac." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<6a880477-55ac-4461-af84-93c08a59a421> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <473a1b5d-56b7-4e1d-afa9-e7d8422386c2> ;
    crm:P141_assigned "Le Vieil-Baugé est une ancienne commune française du Baugeois, située dans le département de Maine-et-Loire et la région Pays de la Loire. Le 1er janvier 2013, les communes de Baugé, Montpollin, Pontigné, Saint-Martin-d'Arcé et Le Vieil-Baugé se sont regroupées pour former la commune nouvelle dénommée Baugé-en-Anjou dont Le Vieil-Baugé constitue une commune déléguée.   (cf. https://fr.wikipedia.org/wiki/Le_Vieil-Baug%C3%A9, consulté le 17 décembre 2020)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<6af29d00-11d1-41fc-bdcf-e8ff7fc3fc03> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <28c5ad41-d93b-4ebb-86ea-8cdf14adfcde> ;
    crm:P141_assigned "Province de France, partagée dans les deux Gouvernemens militaires de l'Isle de France, &amp; d'Orléanois. [...] La Capitale du Gâtinois orléanois est Montargis ; les autres sont Châtillon sur Loing, Gien, Briare, &amp;c.  (Claude Marin, Dictionnaire universel de la France ancienne et moderne, Paris, Saugrain, Vve J. Saugrain, P. Prault, 1726, t.2, col. 20-21)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<6b04d1d0-7fcd-48b7-9158-26951170633f> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <ac305128-6e6f-42aa-bd50-e2575e82ce37> ;
    crm:P141_assigned "Mis sous séquestre à la Révolution et vendu en l'an VI, le château [de Seignelay] est démoli en 1798 et ses matériaux utilisés principalement pour la construction de la caserne et des écuries de Joigny, du manoir voisin de Guillebaudon, d'édifices privés et pour l'empierrement des routes.   (https://fr.wikipedia.org/wiki/Seignelay_(Yonne).)" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

