<12498a60-346d-47eb-be18-344ef5da264b> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <40100ccf-0a2a-4c54-bbcf-c735dd7ef9d1> ;
    crm:P141_assigned "Valence-en-Poitou est une commune nouvelle française située dans le département de la Vienne, en région Nouvelle-Aquitaine. Elle est issue de la fusion — au 1er janvier 2019 — des communes de Couhé, Ceaux-en-Couhé, Châtillon, Payré et Vaux  (https://fr.wikipedia.org/wiki/Valence-en-Poitou, consulté le 4 décembre 2020)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<125b2ca8-9ef9-4142-9094-18a0e5812a59> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <0a2f456f-f72e-4a79-a21e-ad1cc665cc4e> ;
    crm:P141_assigned "L’église collégiale Saint-Pierre à Lille fut fondée entre 1040 et 1050. Elle est disparue en 1791  (cf. http://vafl-s-applirecherche.unilim.fr/collegiales/index.php?i=fiche&amp;j=137, consulté le 2 avril 2021)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
