<8281c599-3ba6-4912-871b-39a65ed1e766> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <8b86e363-f7c4-4e55-aafc-bdcd3aac61b3> ;
    crm:P141_assigned "Lechâteau de l'Étangest un château disparu, anciennement situé sur l'actuelle commune deMarnes-la-Coquette. Dessiné par Jules Hardouin-Mansart, il fut construit par lemarquis de Barbézieux, il n'était pas achevé à sa mort. Michel Chamillart le racheta qui le fit démolir après avoir essayé de le vendre. (cf.<a href= https://fr.wikipedia.org/wiki/Ch%C3%A2teau_de_l%27%C3%89tang_(Marnes-la-Coquette)  rel= noopener noreferrer  target= _blank  style= color: var(--accent-color)  ; >https://fr.wikipedia.org/wiki/Ch%C3%A2teau_de_l%27%C3%89tang_(Marnes-la-Coquette)</a>, consulté le 12 mars 2021). " ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

