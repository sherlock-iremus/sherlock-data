<867916c1-9850-40a8-af5f-d2f8ea3eded1> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <00070225-828e-4591-b1f9-73056c6413a9> ;
    crm:P141_assigned "Pays &amp; Forêt, qui s'étend partie dans la Champagne, &amp; partie dans le Barrois [Duché de Lorraine et de Bar], dans une étendue de vingt lieuës, entre les rivières de la Meuse, de la Marne, &amp; de l'Aine, depuis Mouson &amp; Stenay, jusqu'au Bailliage de Bar-le-duc, &amp; depuis le Perthois, jusqu'à Mouson.  (Claude Marin, Dictionnaire universel de la France ancienne et moderne, Paris, Saugrain, Vve J. Saugrain, P. Prault, 1726, t.1, col. 153)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
