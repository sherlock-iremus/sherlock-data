<d5cab171-5cc1-44c3-8e0f-a4768eec77ad> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <f205aeca-c024-4a3c-b1c1-546d1d22af2e> ;
    crm:P141_assigned "Le château de Nointel de l'Oise a connu plusieurs constructions de 1218 à 1986 (https://fr.wikipedia.org/wiki/Ch%C3%A2teau_de_Nointel_(Oise) - Consulté le 16-11-2020). Ce château ne doit pas être confondu avec celui du même nom dans le diocèse de Senlis." ;
