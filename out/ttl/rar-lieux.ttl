<877ada61-d0a7-46ab-87e0-6a7762f59003> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <73c66aec-4b03-4ce4-b1be-fbe0f2d0b82a> ;
    crm:P141_assigned "«L'électeur de Brandebourg et premier roi de PrusseFrédéric Ierdécide la construction d'un nouvel édifice qui symbolisera une monarchie absolue et le redressement de la Prusse après laGuerre de Trente Ans. Le château est alors reconstruit dans le style baroque entre1699et1706par l'architecteAndreas Schlüter» (cf. <a href= https://fr.wikipedia.org/wiki/Ch%C3%A2teau_de_Berlin  rel= noopener noreferrer  target= _blank >https://fr.wikipedia.org/wiki/Ch%C3%A2teau_de_Berlin</a>, consulté le 25 mars 2021)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<878400ae-b661-422a-a7d0-62043a734ff6> a crm:E13_Attribute_Assignement ;
