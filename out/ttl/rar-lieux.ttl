<1db27213-9c90-4f47-9242-c343c3ac4163> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <c2db55f1-ed31-4491-a66e-9673fdc95461> ;
    crm:P141_assigned "«L'hôtel de ville de Dijonhéberge lesinstitutions municipalesdeDijondepuis1192, et est situé dans lePalais des ducs de Bourgognedans le centre historique de la ville» (cf. <a href= https://fr.wikipedia.org/wiki/H%C3%B4tel_de_ville_de_Dijon  rel= noopener noreferrer  target= _blank >https://fr.wikipedia.org/wiki/H%C3%B4tel_de_ville_de_Dijon</a>, consulté le 19 avril 2021)." ;
