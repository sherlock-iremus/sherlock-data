<78553665-bd45-4b25-8022-c0f3e4393cb9> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <158d7b16-f48d-4845-9353-9b85da579bf0> ;
    crm:P141_assigned "Allaines-Mervilliers est une ancienne commune française située dans le département d'Eure-et-Loir en région Centre-Val de Loire, devenue le 1er janvier 2019 une commune déléguée au sein de la commune nouvelle de Janville-en-Beauce.   (cf. https://fr.wikipedia.org/wiki/Allaines-Mervilliers, consulté le 17 décembre 2020)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<785536c0-c4eb-42d9-a9ea-c2188f9bca05> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <c728991d-356b-41af-95c0-0fdd8416aacf> ;
    crm:P141_assigned "Elle est aussi Siège [...] d'un Gouvernement dépendant de celui du Havre de Grace.  (Claude Marin, Dictionnaire universel de la France ancienne et moderne, Paris, Saugrain, Vve J. Saugrain, P. Prault, 1726, t.2, col. 699)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<785f7470-8768-4440-ab52-0165e8d973c4> a crm:E13_Attribute_Assignement ;
