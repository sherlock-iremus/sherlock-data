<4ef9343c-9ade-499d-9ad2-f754e168219b> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <13bfdfa3-3237-4074-aa40-cbe25510527b> ;
    crm:P141_assigned "Pays de la Champagne, borné au septentrion par le Rethelois &amp; le Laonnois ; à l'orient &amp; au midi par le Châlonois &amp; la Brie, à l'occident par le Soissonnois. [...] La Ville Capitale est Reims, la plus ancienne &amp; l'une des plus considérables de ces contrées ; les autres sont Fismes &amp; Cormicy.  (Claude Marin, Dictionnaire universel de la France ancienne et moderne, Paris, Saugrain, Vve J. Saugrain, P. Prault, 1726, t.2, col. 1332)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<4f0fd020-37b3-478a-b832-c6fdab531e92> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <86272783-cabc-40bf-8339-08eb625ec27b> ;
    crm:P141_assigned "Le site internet Des villages de Cassini aux communes d'aujourd'hui mentionne que la commune de Theuley-lès-Lavoncourt a pris le nom de Theuley en 1801 (http://cassini.ehess.fr/cassini/fr/html/fiche.php?select_resultat=34855)." ;
