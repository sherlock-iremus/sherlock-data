<f665bbaf-d6c7-4efc-af36-88e38745cdcb> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <2bb9acba-639f-4f94-ada5-82514f9c8083> ;
    crm:P141_assigned "Chênehutte-Trèves-Cunault est une ancienne commune française située dans le département de Maine-et-Loire, en région Pays de la Loire, devenue le 1er janvier 2016, une commune déléguée de la commune nouvelle de Gennes-Val de Loire, puis, le 1er janvier 2018, de Gennes-Val-de-Loire. La commune est née en 1973 de la fusion des anciennes communes de Chênehutte-les-Tuffeaux et Trèves-Cunault.   (https://fr.wikipedia.org/wiki/Ch%C3%AAnehutte-Tr%C3%A8ves-Cunault, consulté le 4 décembre 2020)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<f665f948-d60f-40d8-b6de-ee9ffcee1eb3> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <ac1e05f4-2c24-4b41-bca2-ef7abd1bbaba> ;
    crm:P141_assigned "Pays, du Gouvernement de la Province d'Orléanois. Il y a Comté &amp; Vicomté. Sa Ville Capitale est Châteaudun.  (Claude Marin, Dictionnaire universel de la France ancienne et moderne, Paris, Saugrain, Vve J. Saugrain, P. Prault, 1726, t.1, col. 1080)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

