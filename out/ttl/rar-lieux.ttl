<592043f9-3e6e-409a-a140-9b14d6c63373> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <f31a6462-6747-4919-adc0-bdaaed176dfd> ;
    crm:P141_assigned "“Il ne subsiste qu'une petite tourelle octogonale de l'ancien couvent des Carmes fondé au début du 15e siècle, par Guillaume de Montauban […] Le cloître est reconstruit en 1638. Vendu à la Révolution, l'église est démolie au début du 19e siècle et la chapelle, dédiée à Saint-Sébastien, en 1863 (cf. http://patrimoine.bzh/gertrude-diffusion/dossier/couvent-de-grands-carmes-29-rue-des-carmes-dol-de-bretagne/e6556450-be77-45e4-b88c-171327215036, consulté le 21 avril 2021).  " ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

