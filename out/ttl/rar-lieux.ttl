<8f02abae-d2b2-434d-80f0-05479f30b904> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <70b3e5ae-8c54-4747-841c-ec40fcae20c9> ;
    crm:P141_assigned "<strong style= color: rgb(0, 0, 0); >Notre-Dame-du-Touchet</strong>est une ancienne<a href= https://fr.wikipedia.org/wiki/Commune_(France)  rel= noopener noreferrer  target= _blank  style= color: var(--accent-color)  ; >commune française</a>, située dans le<a href= https://fr.wikipedia.org/wiki/D%C3%A9partement_fran%C3%A7ais  rel= noopener noreferrer  target= _blank  style= color: var(--accent-color)  ; >département</a>de la<a href= https://fr.wikipedia.org/wiki/Manche_(d%C3%A9partement)  rel= noopener noreferrer  target= _blank  style= color: var(--accent-color)  ; >Manche</a>en<a href= https://fr.wikipedia.org/wiki/R%C3%A9gion_fran%C3%A7aise  rel= noopener noreferrer  target= _blank  style= color: var(--accent-color)  ; >région</a><a href= https://fr.wikipedia.org/wiki/Normandie_(r%C3%A9gion_administrative)  rel= noopener noreferrer  target= _blank  style= color: var(--accent-color)  ; >Normandie</a>, devenue le1<sup>er</sup>janvier 2016une<a href= https://fr.wikipedia.org/wiki/Commune_d%C3%A9l%C3%A9gu%C3%A9e  rel= noopener noreferrer  target= _blank  style= color: var(--accent-color)  ; >commune déléguée</a>au sein de la<a href= https://fr.wikipedia.org/wiki/Commune_nouvelle  rel= noopener noreferrer  target= _blank  style= color: var(--accent-color)  ; >commune nouvelle</a>de<a href= https://fr.wikipedia.org/wiki/Mortain-Bocage  rel= noopener noreferrer  target= _blank  style= color: var(--accent-color)  ; >Mortain-Bocage</a>.  (cf. https://fr.wikipedia.org/wiki/Notre-Dame-du-Touchet, consulté le 2 avril 2021)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<8f2359d9-92bb-47fd-a805-c01312cf9860> a crm:E13_Attribute_Assignement ;
