<759f6a67-de8c-41fe-8a66-96fa4356f0df> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <def07d37-7450-4829-92c1-70eb06e47564> ;
    crm:P141_assigned "La cathédrale Notre-Dame-et-Saint-Lambert (Catedråle Notru-Dame-et-Sint-Lambiert di Lidje en wallon) fut la cathédrale de Liège jusqu'en 1794, date du début de sa destruction. Cette immense cathédrale gothique, à la mémoire de saint Lambert, occupait l'actuelle place Saint-Lambert, au cœur de Liège.  (https://fr.wikipedia.org/wiki/Cath%C3%A9drale_Notre-Dame-et-Saint-Lambert_de_Li%C3%A8ge)\r \r Elle faisait face au palais des princes-évêques et apparaît sur ce plan de Liège par Lerouge (https://gallica.bnf.fr/ark:/12148/btv1b8490588m?rk=107296;4)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

