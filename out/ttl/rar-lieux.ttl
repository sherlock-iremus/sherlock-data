<d8f5f319-9773-4b0d-a6c9-34ea34f890b4> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <0944810a-46d1-4f6c-bc32-c737613efa6e> ;
    crm:P141_assigned "«La reconstruction de l'édifice sur l'emplacement de l'ancien hôtel de ville, fut décidée par délibération du 3 décembre 1730. Les plans de l'architecte Cadas furent adoptés en 1741. L'édifice, y compris la tour qui le domine, fut terminé et inauguré le 15 août 1746» (cf. <a href= https://monumentum.fr/hotel-ville-pa00103383.html  rel= noopener noreferrer  target= _blank >https://monumentum.fr/hotel-ville-pa00103383.html</a>, consulté le 26 mars 2021)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

