<0d9fd26b-f5c7-4fd3-8e61-0ad7193efc55> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <9e6d20d3-a28f-42f8-ac66-b1656789c28f> ;
    crm:P141_assigned "Entre 1667 et 1668, au croisement de la rue des Tournelles et du boulevard Beaumarchais, l’architecte Jules Hardouin-Mansart fit édifier, pour son compte, un hôtel particulier  (cf. https://www.parismarais.com/fr/arts-et-culture/hotels-particuliers-du-marais/hotel-de-sagonne.html, consulté le 1er juin 2021)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<0de55507-8ef5-4230-9d7a-d681dc220b87> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <d23a5705-a40a-483f-92e2-53235d4e7be9> ;
    crm:P141_assigned "Pays, situé aux Frontières de la Normandie, &amp; de la Picardie : il s'étend assez avant dans le Beauvoisis. [...] Sa Capitale est la Ville de Neufchâtel ; les autres sont Gournay &amp; Aumale.  (Claude Marin, Dictionnaire universel de la France ancienne et moderne, Paris, Saugrain, Vve J. Saugrain, P. Prault, 1726, t.1, col. 522)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

