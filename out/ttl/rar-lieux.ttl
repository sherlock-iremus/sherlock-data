<c1d5f6b3-a4ed-4d9b-9804-304d8313f171> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <a54c2b2b-8495-4d3d-b691-b4d215df5005> ;
    crm:P141_assigned "La paix de Fribourg (1516) confirma aux Confédérés la possession de L., bailliage commun des XII cantons. Si le val Maggia en fut détaché, Brissago fut annexé (tout en conservant une certaine autonomie), tandis que le Gambarogno et le val Verzasca formèrent des communautés séparées à l'intérieur du bailliage. Un bailli (appelé commissaire), nommé à tour de rôle pour deux ans par chacun des cantons, exerçait des fonctions administratives, militaires, judiciaires et de police. Il était secondé par un bureau composé d'un secrétaire baillival, d'un lieutenant, d'un procureur fiscal et d'un notaire du tribunal de haute justice (notaio del malefizio).  (Dictionnaire historique de la Suisse, https://hls-dhs-dss.ch/fr/articles/008544/)" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<c24c9ac6-0950-4e64-9fd4-6122f8b4e1ed> a crm:E13_Attribute_Assignement ;
