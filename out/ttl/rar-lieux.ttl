<fe6d8084-f415-4a62-9b30-1dbd67ee440b> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <1cc39a41-ed7a-4d6c-a6d3-04c48d857a20> ;
    crm:P141_assigned "Le couvent des Trinitaires de Madrid, a été fondé en 1652 et démoli en 1897. De nos jours,  il ne reste que la chapelle du couvent - dite Capilla del Ave María - rue del Doctor Cortezo dans la ville de Madrid (cf. http://www.madridhistorico.com/seccion5_historia/nivel2_informacion.php?idmapa=8&amp;idinformacion=756&amp;pag=1, consulté le 7 juin 2021)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<feafc6d2-d4b3-4aa9-8e34-2084169cc76b> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <1252d148-51c4-404e-996b-b26ee52daab5> ;
    crm:P141_assigned "D'après le site Des villages de Cassini aux communes d'aujourd'hui, Varney s'est appelé Verney et Rembercourt durant la période révolutionnaire (cf.http://cassini.ehess.fr/fr/html/fiche.php?select_resultat=38918, consulté le 4 mars 2021)." ;
