<db932d57-e6af-42c7-88b6-169928f92865> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <3dc4f79a-e40f-4788-92fd-1086a02c47d3> ;
    crm:P141_assigned "Limeil, sur le plateau, a fusionné entre 1790 et 1794 avec Brévannes, dans la plaine,  pour former la commune de Limeil-Brévannes (https://fr.wikipedia.org/wiki/Limeil-Br%C3%A9vannes)." ;
