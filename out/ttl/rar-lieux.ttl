<431b8a13-f7e9-4022-bafb-75139dfada22> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <901eff48-e038-4937-95bd-6aeeda685daf> ;
    crm:P141_assigned "Chambon-sur-Cisse est une ancienne commune française située dans le département de Loir-et-Cher en région Centre-Val de Loire. Elle intègre la commune nouvelle de Valencisse avec le statut de commune déléguée le 1er janvier 2017.   (cf. https://fr.wikipedia.org/wiki/Chambon-sur-Cisse, consulté le 11 décembre 2020)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

