<26a79dc0-df45-4bb5-86f2-cf44d7aec7ac> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <b2936ae4-f6dc-4d06-98cd-4b9a99cb8b1a> ;
    crm:P141_assigned "Giéville est une ancienne commune française, située dans le département de la Manche en région Normandie, devenue le 1er janvier 2016 une commune déléguée au sein de la commune nouvelle de Torigny-les-Villes.   (cf. https://fr.wikipedia.org/wiki/Gi%C3%A9ville, consulté le 29 janvier 2021)." ;
