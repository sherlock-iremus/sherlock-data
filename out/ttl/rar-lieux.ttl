<17e763a2-41a5-43f2-827c-f98eb78011f7> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <0efb4111-e56b-4e54-9e90-40eda3c3b3c9> ;
    crm:P141_assigned "Le Mercure galant de juillet 1704 consacré aux réjouissances pour la naissance du duc de Bretagne indique que M. Chabrot, « bourgeois de Lyon, a donné une feste magnifique à sa maison de la Grenete » (MG-1704-07b_369)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<18081cc1-9259-4ff2-af62-77ead23a196e> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <c33e2df4-78d7-49c3-b9cf-463ed37d3739> ;
    crm:P141_assigned "Aujourd’hui disparu, il est possible de localiser l’ancien couvent des Dominicains en D4  sur cette carte de Lucien Bonnamas, publiée en 1890 (cf. <a href= https://gallica.bnf.fr/ark:/12148/btv1b530249101/f1.item.r=dijon  rel= noopener noreferrer  target= _blank >https://gallica.bnf.fr/ark:/12148/btv1b530249101/f1.item.r=dijon</a>, consulté le 19 avril 2021)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

