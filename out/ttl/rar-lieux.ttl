<d534d82e-85bc-4811-b0bf-45fefd2b7da0> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <66b5253e-284a-4a89-9f0a-52f0a3b4d77a> ;
    crm:P141_assigned "Le site internet Des villages de Cassini aux communes d'aujourd'hui mentionne que la commune de Saint-Ouen s'est appelée Bain-sur-Seine à la Révolution française. Elle a repris le nom de Saint-Ouen en 1801. (http://cassini.ehess.fr/cassini/fr/html/fiche.php?select_resultat=33844)." ;
