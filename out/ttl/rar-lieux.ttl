<608dbd0b-503a-40c3-ae2f-9e1978248f86> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <325c6e34-76c7-401b-b7e1-17cb28d53fa3> ;
    crm:P141_assigned "Le château de Mouchy, dit aussi château d'Humières, ou château de Monchy-Humières, est un château situé sur la commune de Monchy-Humières. Il fut la propriété des ducs d'Humières. De nos jours, son parc est constitué d'un golf  (cf. https://fr.wikipedia.org/wiki/Château_de_Mouchy_(Monchy-Humières), consulté le 17 juin 2021)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

