<4e307798-44ef-4a59-ac33-b40c548d025c> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <52875ffe-69be-44b6-b082-de66ddd3cb98> ;
    crm:P141_assigned "Le site internet Des villages de Cassini aux communes d'aujourd'hui mentionne que la commune de Parnes a absorbé celle d'Halincourt [dans le Vexin françois] entre 1790 et 1794 (http://cassini.ehess.fr/cassini/fr/html/fiche.php?select_resultat=61755)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

