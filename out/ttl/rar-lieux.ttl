<998087ef-ce4f-41ec-b3c0-46ad7dfc0090> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <c6e880ef-7951-44be-ab2e-f32551b8b7a4> ;
    crm:P141_assigned "La Sala dels Reis fut construit vers 1585. Elle constitue l’une des trois grandes salles avec accès au Patio de los Naranjos dans le Palais de la Generalitat à Barcelone (cf. https://www.hisour.com/es/palace-of-the-generalitat-of-catalonia-barcelona-spain-54452/, consulté le 27 avril 2021)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<99ca1710-dedb-4f02-9341-35dbaaf82c93> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <ac288e4d-320d-43ab-8b9d-f399b94c1ccf> ;
    crm:P141_assigned "Le site internet Des villages de Cassini aux communes d'aujourd'hui mentionne que la commune de Monestier, qui s'est nommé Monêtier-de-Briançon entre 1801 et 1893, est devenue Le Monêtier-les-Bains en 1893 (http://cassini.ehess.fr/cassini/fr/html/fiche.php?select_resultat=22909)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<99d03528-c46e-4c0a-a1ad-c4dbe02c26a8> a crm:E13_Attribute_Assignement ;
