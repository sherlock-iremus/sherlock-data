<9cb38475-cea8-4c8b-b1d8-42eaceece8e6> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <43150074-a8be-41c0-8f13-822cc00751a5> ;
    crm:P141_assigned "Province, dont la plus grande partie forme le Gouvernement militaire de la Province d'Anjou, &amp; le reste fait partie du petit Gouvernement militaire de la province du Saumurois. Cette Province est bornée au septentrion par le Maine, à l'orient par la Touraine, au midi par le Poitou, &amp; à l'occident par la Bretagne.  (Claude Marin, Dictionnaire universel de la France ancienne et moderne, Paris, Saugrain, Vve J. Saugrain, P. Prault, 1726, t.1, col. 119)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

