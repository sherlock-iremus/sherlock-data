<0892e6c1-d808-45a8-b8d3-5c07ef04cd19> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <899a80f7-40c0-444f-b031-338a3ea2b5d6> ;
    crm:P141_assigned "Un article du Mercure galant de juillet 1704 consacré aux réjouissances pour la naissance du duc de Bretagne fait le récit des festivités organisées par le marquis d’Argenson en son hôtel particulier." ;
