<a7b7385e-c1f9-4799-941c-79f4354ed7e2> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <9aeb5392-4da3-4caa-b64f-2cd61738c9cb> ;
    crm:P141_assigned "L'abbaye bénédictine a été  réduite en prieuré conventuel en 1155  (Dom L. H. Cottineau, Répertoire topo-bibliographique des abbayes et prieurés, Macon, Protat frères, 1939, t. 1, col. 1283).\r En 1760, Gigny fut sécularisée ; les moines constituèrent alors un collège de chanoines [Collégiale Saint-Pierre-Saint-Louis]. La communauté fut supprimée en 1788-89. L'église monastique devint l'église paroissiale Saint-Taurin. (https://fr.wikipedia.org/wiki/Abbaye_Saint-Pierre_de_Gigny)" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<a7ecbe0d-7e71-4804-9331-165ba0a349e5> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <53759bcd-3bec-4bec-8b1d-5463248e6aff> ;
    crm:P141_assigned "Magny-Cours est né de la fusion en 1830 des villages de Magny et de celui de Cours (http://cassini.ehess.fr/cassini/fr/html/fiche.php?select_resultat=10761)." ;
