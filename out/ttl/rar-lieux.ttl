<757e394a-d786-471c-8c48-7738215fed79> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <497b4ca6-ecc3-4c09-a512-05578d6ea214> ;
    crm:P141_assigned "Datant de 1650, le château Rozet devient le château Banquet en 1713. Il est aujourd'hui le siège de la société Alesia au 96 rue de Lausanne. \r (http://www.swisscastles.ch/Geneve/banquet.html - consulté le 09-06-2020)" ;
