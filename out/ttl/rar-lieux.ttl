<79c5df61-78c1-4043-b5bc-f406ad0775ec> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <73e61f39-8631-4fae-9349-c84c840cfe5a> ;
    crm:P141_assigned "Le châteaux de Vantoux est cité en 1330 sous Eudes de Saulx. Les ruines de cette maison forte des comtes de Saulx sont démolies en 1670 par Jean I de Berbisey. Elle est reconstruite dès 1699 par Jean II de Berbisey et achevée en 1704. L'architecte de cet ensemble est vraisemblablement Jules Hardouin Mansart (cf. art. Wikipedia https://fr.wikipedia.org/wiki/Messigny-et-Vantoux#Histoire consulté le 25 janvier 2018)" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

