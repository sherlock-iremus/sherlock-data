<d46a9842-fd6b-4937-b5f0-dd6e7ec58e69> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <c40ac5ef-3724-4474-9d47-3e227696d9e0> ;
    crm:P141_assigned "Ce n'étoit autrefois qu'un Village, nommé Corbigny, que Marie Reine d'Hongrie, Gouvernante des Pays Bas, fit fortifier en 1577. &amp; lui donna le nom de son neveu Philippe II.  (Claude Marin, Dictionnaire universel de la France ancienne et moderne, Paris, Saugrain, Vve J. Saugrain, P. Prault, 1726, t.2, col. 1119)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<d48bce3d-8b35-4e16-9f13-71eaf6639207> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <5a1542aa-8d62-4460-96b7-3f4ff8c64879> ;
    crm:P141_assigned "Pays de la Normandie, situé vers l'embouchure de la Seine au nord ; il est borné au septentrion par la mer, à l'orient par le pays de Bray, qui en a fait autrefois partie ; entre le septentrion &amp; l'orient par le Vexin Normand, &amp; au midi &amp; à l'occident, la Seine le sépare du pays d'Auge &amp; du reste de la Normandie.  (Claude Marin, Dictionnaire universel de la France ancienne et moderne, Paris, Saugrain, Vve J. Saugrain, P. Prault, 1726, t.1, col. 660)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

