<e61a3ab3-c6a8-48cc-b10f-561199cd0d26> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <35044add-69c2-41e9-a1ac-abaabf724802> ;
    crm:P141_assigned "Thizy est une ancienne commune française, située dans le département du Rhône en région Rhône-Alpes. Depuis le 1er janvier 2013, elle est une commune déléguée de la commune nouvelle de Thizy-les-Bourgs.   (cf. https://fr.wikipedia.org/wiki/Thizy_(Rh%C3%B4ne), consulté le 17 décembre 2020)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<e625e631-1546-42aa-a38b-d5d78631e9e1> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <7d41f187-5a57-429b-9552-36f3263dd932> ;
    crm:P141_assigned " Barbezieux-Saint-Hilaire est une commune du sud-ouest de la France, située dans le département de la Charente (région Nouvelle-Aquitaine). Elle résulte de l'association, en 1973, de la commune de Barbezieux et de celle de Saint-Hilaire.  (cf. https://fr.wikipedia.org/wiki/Barbezieux-Saint-Hilaire, consulté le 26/04/2021)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

