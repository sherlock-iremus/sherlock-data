<462e3cc2-5bc6-4a6a-b950-d27f51379446> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <4b5ec211-68c7-4808-9694-1da6182181b0> ;
    crm:P141_assigned "Province, qui fait partie du Gouvernement militaire de la Province de Metz &amp; Verdun. [...] Ce pays est borné au septentrion, par la Prévôté de Thionville, qui est du Duché de Luxembourg &amp; par une partie de la Lorraine Allemande ; à l'occident [sic. pour l'orient] par la Lorraine Allemande ; au midy, par la Lorraine Romande ; &amp; à l'occident par le Barrois.  (Claude Marin, Dictionnaire universel de la France ancienne et moderne, Paris, Saugrain, Vve J. Saugrain, P. Prault, 1726, t.2, col. 595)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

