<ae7383d1-e8f0-43c0-b989-bb8dd1f5e6fb> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <3d240809-832b-421c-9e3e-bbf3c771c909> ;
    crm:P141_assigned "<span style= color: rgb(32, 33, 34); >Les départements sont les entités territoriales de premier niveau en Colombie. Le pays est divisé administrativement et politiquement en 32 départements, qui sont régis depuis chacune de leur capitale départementale  (cf. https://fr.wikipedia.org/wiki/Administration_territoriale_de_la_Colombie#Départements, consulté le 2 juillet 2021)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

