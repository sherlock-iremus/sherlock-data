<55cd5b3a-e108-4c64-bcab-328c1a2148e2> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <f57e63ce-79b8-42c0-9ab6-67df73895630> ;
    crm:P141_assigned "Le château de Frémont (ou Fromont) est aujourd'hui l'hôtel de ville de Ris-Orangis. Sous l'Ancien Régime, ce château était indépendant du village de Ris et de celui d'Orangis." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<56197775-5cfd-4ddf-a8bd-fece2e42a332> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <9e80f65b-af5e-4f3f-80b9-2e4fda3633ba> ;
    crm:P141_assigned "Le site internet Des villages de Cassini aux communes d'aujourd'hui mentionne que la commune de Mortagne est devenue Mortagne-au-Perche en 1923. Entre 1801 et 1923, elle s'est également appelée Mortagne-sur-Huisne (http://cassini.ehess.fr/cassini/fr/html/fiche.php?select_resultat=24048)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<56283ff2-2a42-4344-82a6-f9ea615f4e6b> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <2296cafb-4b4e-4b58-a3f4-9f48bcd65f6d> ;
    crm:P141_assigned "Le couvent des Récollets ainsi que sa chapelle furent détruits «lors de la construction du lycée de Lille entre 1848 et 1852» (cf. <a href= https://fr.wikipedia.org/wiki/Rue_des_Arts_(Lille)  rel= noopener noreferrer  target= _blank  style= color: rgb(102, 102, 102); >https://fr.wikipedia.org/wiki/Rue_des_Arts_(Lille)</a>, consulté le 19 mars 2021). Ils étaient situés dans la rue des Arts à Lille. " ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<563e8078-5b3c-470f-9e1d-6f51dc3a7bd4> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <492016ee-937e-4ec1-816a-ba4fb9b370a4> ;
    crm:P141_assigned "Sur cette carte  datée de 1759, Charlottenburg est située au nord-ouest de Berlin (cf. “Carte itineraire de l'empire d'Allemagne et de ses frontières”, https://gallica.bnf.fr/ark:/12148/btv1b530406551/f1.item.zoom, consulté le 29 mars 2021). Le domaine de Charlottenbourg, nommé Lietzenburg jusqu’en 1705, est aujourd’hui un quartier du centre-ouest de Berlin, dans l'arrondissement de Charlottenbourg-Wilmersdorf (cf. https://fr.wikipedia.org/wiki/Château_de_Charlottenbourg, consulté le 29 mars 2021)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<568099c1-f6b7-4e50-b489-d20632246088> a crm:E13_Attribute_Assignement ;
