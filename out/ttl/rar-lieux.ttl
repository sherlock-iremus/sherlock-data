<efc99a3c-f422-43ba-94c2-f4d69f5f852b> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <34283fc8-fea2-464a-b125-6989486372d6> ;
    crm:P141_assigned "Dans la Provence, Diocèse de Gap, Parlement &amp; Intendance d'Aix, Viguerie &amp; Recette de Sisteron, a 376 habitans. Cette Paroisse est située dans la vallée de Cornillon, enclavée dans le Dauphiné.  (Claude Marin, Dictionnaire universel de la France ancienne et moderne, Paris, Saugrain père, Vve J. Saugrain, Pierre Prault, 1726, t. 2, col. 1166)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<eff8573b-3bf9-4eae-9175-b3ef59b2d925> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <552d077a-4b5a-4cee-bb5c-90b5f323f487> ;
    crm:P141_assigned "CRCV :  Troarn [Calvados, arr. Caen]" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<f03df551-93c2-44e0-96a4-08e5cfc5f662> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <7a1d7e5f-51f3-485d-8597-7e1bdb4cfbf7> ;
    crm:P141_assigned "Au XVIe s., la ville de Bâle acquit le statut de république urbaine et d'État territorial indépendant, tout en s'intégrant à la Confédération, dont elle faisait partie depuis 1501 et en s'émancipant de toute sujétion à l'égard de l'évêque. Le patriciat, d'origine noble (chevaliers) ou bourgeoise (Achtburger), perdit son influence et le pouvoir passa entièrement aux corporations. Le Conseil s'affranchit unilatéralement de l'autorité épiscopale en 1521. De plus, l'introduction de la Réforme en 1529 priva l'évêque de la juridiction spirituelle.   (https://hls-dhs-dss.ch/fr/articles/007387)" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<f052d9fc-bebf-4828-a34b-1ab656fa2d3a> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <dd1b44e2-1cb0-4f25-a685-542578c82a27> ;
    crm:P141_assigned "CRCV : Albano (église) [Albano Laziale]" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<f05d78bc-826c-42ef-85ac-3bbc7761ab1c> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <bab17de0-adee-41eb-97df-a79b6f060613> ;
    crm:P141_assigned "Nous ne sommes pas parvenus à géolocaliser cette abbaye que la Description de la ville et des fauxbourgs de Paris en vingt planches... avec un détail de toutes les Abbayes &amp; Églises, des Convents, Communautez... Dressée &amp; gravée sous les ordres de M. D'Argenson décrit enc es termes : \r « De Notre Dame de Paix, Chanoinesses de l’Ordre de saint Augustin, établies cy devant à Nanterre en 1647, depuis transférées vers l’année 1656 au village de Chaillot, à present nommé le Fauxbourg de la Conference, par les soins du Pere Beurier Abbé de sainte Geneviève, &amp; General de la Congregation de France ; Quartier du Palais Royal. » (Paris, Jean de la Caille, 1714,  Table Alphabétique, Historique &amp; Chronologique de tout ce qu’il y a de plus considerable dans cette Description de la Ville &amp; Fauxbourgs de Paris ,  VIII. Abbayes de filles , n. p.)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<f063c7c2-d81e-46bc-9394-9e34367e9fec> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <6c8db06b-f57d-4a5f-9e2f-d43c085cf254> ;
    crm:P141_assigned "CRCV : Baudrigue (château de) [Aude, comm. Roullens]" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<f0692242-f74d-4289-bfc0-a5966cc64d94> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <f582f2c0-d40a-4d65-86ac-dbaced1dedbf> ;
    crm:P141_assigned "L'église, anciennement Saints-Paul et Pierre, fut dédicacée à saint Étienne ; rasée elle se situait aux 35 et 36 de la rue de l'Equerre.   (https://fr.wikipedia.org/wiki/Abbaye_Saint-%C3%89tienne-les-Dames)\r \r Elle figure sur ce plan de 1722 (https://gallica.bnf.fr/ark:/12148/btv1b84932695/f1.item)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<f08e28fc-254d-4148-b6c4-e3f465be722b> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <18858cfb-d610-48fe-91f2-9d4c74cbbab2> ;
    crm:P141_assigned "Caudebec-en-Caux est une ancienne commune française située dans le département de la Seine-Maritime, en Normandie. [...] La fusion communale de trois communes dont Caudebec-en-Caux, le 1er janvier 2016, donne naissance à la commune nouvelle de Rives-en-Seine et attribue par voie de conséquence, le statut de commune déléguée à Caudebec-en-Caux.   (cf. https://fr.wikipedia.org/wiki/Caudebec-en-Caux, consulté le 15 janvier 2021)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<f0b39f4e-15d3-4bfa-a4da-d9e1c01735e6> a crm:E13_Attribute_Assignement ;
