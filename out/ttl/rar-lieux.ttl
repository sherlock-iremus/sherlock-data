<2b716845-aa27-42e2-9baa-8907d1245e0b> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <c9f85c05-1e87-41ca-8ca5-3e2b4d495342> ;
    crm:P141_assigned "Pays de la Champagne, qui a pris son nom de sa Ville Capitale Châlons ; il est borné au septentrion par le Rémois &amp; le pays d'Argonne, à l'Orient par le Duché de Bar, au midi par le Pertois, &amp; à l'Occident par la Champagne propre.  (Claude Marin, Dictionnaire universel de la France ancienne et moderne, Paris, Saugrain, Vve J. Saugrain, P. Prault, 1726, t.1, col. 691)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<2b77b399-468a-43d2-95e6-36e8c98de984> a crm:E13_Attribute_Assignement ;
