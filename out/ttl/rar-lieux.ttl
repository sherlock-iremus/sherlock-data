<26f96c20-f6e0-4cd7-96bb-956407793eb8> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <e7914e4b-2541-4e04-acdd-de4c4f83d39f> ;
    crm:P141_assigned "Dans la Provence, Diocèse de Gap, Parlement &amp; Intendance d'Aix, Viguerie &amp; Recette de Sisteron. Ce lieu est Chef d'une Vallée, qui est enclavée dans le Dauphiné, &amp; qui comprend plusieurs Paroisses &amp; Villages, qui dépendent du Gouvernement militaire de Provence.  (Claude Marin, Dictionnaire universel de la France ancienne et moderne, Paris, Saugrain père, Vve J. Saugrain, Pierre Prault, 1726, t. 1, col. 917.)" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<276bf116-8852-4a26-aa32-a4320ac426d6> a crm:E13_Attribute_Assignement ;
