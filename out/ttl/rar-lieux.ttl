<4190c674-05bd-4467-85db-49b45b57c1ad> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <ac860b51-048f-4349-aa5b-7655e414baa7> ;
    crm:P141_assigned "Le château de Montbazon est un château Renaissance construit au XVe siècle. Il est toutefois détruit un peu plus de trois siècles plus tard. Aujourd'hui il reste un  ensemble d'aménagements fortifiés situés sur la commune française de Montbazon dans le département d'Indre-et-Loire et la région Centre-Val de Loire dont le château faisait partie." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<41b221c8-8b21-484e-94d0-82dba1b84b71> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <ba88a7b1-7001-47b5-9c20-e47cff616620> ;
    crm:P141_assigned "Le château de Montmorency était un château situé sur la commune de Montmorency, dans le Val-d'Oise. Il n'en reste de nos jours que de rares vestiges, dont l'Orangerie de Crozat (actuel conservatoire de musique de la ville).  (https://fr.wikipedia.org/wiki/Ch%C3%A2teau_de_Montmorency - consulté le 10-11-2020)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

