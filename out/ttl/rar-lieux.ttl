<289b3f4a-c265-4386-8bc0-8e4bb0f575dd> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <634722a3-ce6c-4fb3-b491-6e5c23af4c23> ;
    crm:P141_assigned "Le village d'Orangis a fusionné en 1793 avec celui de Ris pour former la commune de Ris et Orangis réunis qui prendra ensuite le nom de Brutus puis celui de Ris-Orangis dès 1801 (https://fr.wikipedia.org/wiki/Ris-Orangis). (fr)" ;
