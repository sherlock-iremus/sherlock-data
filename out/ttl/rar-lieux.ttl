<4e8eecaf-1f3c-405c-bbc6-97f6c53764ec> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <c44ea09c-a586-4c19-a20e-a59bd1377cdb> ;
    crm:P141_assigned "Les bâtiments de l’abbaye ont été détruits à la Révolution française. Les ruines se trouvent aujourd’hui sur les terres de la commune de Bussy-la-Côte. Il est possible de géolocaliser l’abbaye sur une carte de Nicolas Sanson, datant de 1656, à l'ouest, entre Bussy-la-Coste et Loupy le Chastel (cf. https://gallica.bnf.fr/ark:/12148/btv1b85923829, consulté le 3 mars 2021). L'abbaye était située sur le territoire de l'actuelle commune du Val d'Ornain." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

