<973bc432-2f59-4979-9be0-2b5a7c334137> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <72aed630-ed57-401c-ac56-8205c0dfc3ae> ;
    crm:P141_assigned "Le site internet Des villages de Cassini aux communes d'aujourd'hui mentionne que le village de Montmartre s'est appelé Mont-Marat durant la période révolutionnaire puis réuni à Paris en 1859 (http://cassini.ehess.fr/cassini/fr/html/fiche.php?select_resultat=23671)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

