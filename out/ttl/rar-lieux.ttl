<9fa7916d-9222-4aa2-980e-ca7d81d373c4> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <38a5c037-7f2c-40e4-8043-98a4ac318e2a> ;
    crm:P141_assigned "Pardeilhan-Betbezé a été réuni à Beaucaire en 1839 ; il constitue désormais un hameau de Beaucaire nommé Pardailhan." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<9fabab16-f8ea-44b0-930f-a397b9afa831> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <acf0ebb0-85ce-46d4-8c36-dd0c2ab60314> ;
    crm:P141_assigned "La commune de Vézins est issue de la réunion des anciennes communautés de Vézins, La Clau et Le Ram. [...] La Clau était le siège d'une commanderie des hospitaliers de Saint-Jean-de-Jérusalem et la communauté du Ram appartenait au domaine royal hérité des Comtes de Rodez. Plusieurs paroisses se partageaient le territoire de la commune actuelle, parfois à cheval sur d'autres communautés.  (https://fr.wikipedia.org/wiki/V%C3%A9zins-de-L%C3%A9v%C3%A9zou)" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<9fd6047e-5c11-45b3-b402-27ff18f7fa7d> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <31c79b92-a622-4425-b0a0-2fad10db8db6> ;
    crm:P141_assigned "CRCV :  Montauban [Tarn-et-Garonne, ch.-l. dép.]" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<9fe190d6-fc6c-43a1-bac0-dbd0a70063ea> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <f99b8e9d-c210-4a45-93bb-cbe4f6b74867> ;
    crm:P141_assigned "Païs qui fait partie de la basse Picardie, &amp; du Gouvernement Militaire de la Province de Picardie. Il est compris entre la Somme &amp; et Abbeville, au Nord ; &amp; la Bresle qui la sépare au Sud de la Normandie. Sa Ville Capitale est S. Valéry, Port de Mer, situé à l'embouchure de la Somme. Il n'y a point d'autres Villes. On le confond souvent avec le Ponthieu. On dit aussi Vimeu.  (Claude Marin, Dictionnaire universel de la France ancienne et moderne, Paris, Saugrain, Vve J. Saugrain, P. Prault, 1726, t.3, col. 885). (fr)" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<9fe7632e-4247-42c3-93c5-fe6c3caa839c> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <d41ad2a1-c4a3-4362-a780-e1a4ea76c89f> ;
    crm:P141_assigned "Le Guédeniau est une ancienne commune française située dans le département de Maine-et-Loire, en région Pays de la Loire, devenue le 1er janvier 2016, une commune déléguée de la commune nouvelle de Baugé-en-Anjou.  (cf. https://fr.wikipedia.org/wiki/Le_Gu%C3%A9deniau, consulté le 17 décembre 2020)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<9fec3896-1bec-4ab0-92c6-fbd661b357cc> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <db310344-9035-4c96-8c3f-fbeb7f8dbaef> ;
    crm:P141_assigned "Ondefontaine est une ancienne commune française, située dans le pays du Bocage virois, le département du Calvados en région Normandie, devenue le 1er janvier 2017 une commune déléguée au sein de la commune nouvelle de Les Monts d'Aunay.  (cf. https://fr.wikipedia.org/wiki/Ondefontaine, consulté le 15 janvier 2021)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

