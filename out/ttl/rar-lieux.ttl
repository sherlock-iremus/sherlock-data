<873d2c7d-6bb5-4ea9-8098-3cd347f4d557> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <a88c7bd0-f6e8-44e3-8c31-23c3af4ccb65> ;
    crm:P141_assigned "La ville de Clermont-Ferrand est née de la fusion des villes de Montferrand et de Clermont, décidée par Louis XIII (Édit de Troyes, 15 avril 1630), confirmé et rendu effectif en 1731 sous Louis XV (second Édit d'union) qui donne naissance à la capitale auvergnate de Clermont-Ferrand. (https://fr.wikipedia.org/wiki/Clermont_(ville) et https://fr.wikipedia.org/wiki/Montferrand_(quartier)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

