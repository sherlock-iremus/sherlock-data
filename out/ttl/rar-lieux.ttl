<ec62b5df-d8f4-430f-baa5-fede545a8a7b> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <4147baa6-63bf-4506-9bea-0927541106e8> ;
    crm:P141_assigned "Saint-Médard est une ancienne commune du centre-ouest de la France située dans le département des Deux-Sèvres en région Nouvelle-Aquitaine. Elle a fusionné le 1er janvier 2019 au sein de la commune nouvelle de Celles-sur-Belle, dont Saint-Médard est désormais une commune déléguée.   (cf. https://fr.wikipedia.org/wiki/Saint-M%C3%A9dard_(Deux-S%C3%A8vres), consulté le 29 janvier 2021)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<ec77320b-af46-4bc8-8e80-a220b03a04af> a crm:E13_Attribute_Assignement ;
