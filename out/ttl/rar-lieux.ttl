<e98efe8f-0d1e-4efa-91db-d622d0a1df21> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <e7117ac4-ff5b-4d94-8ab5-aa82fb122713> ;
    crm:P141_assigned "Pays de Picardie, qui fait partie du Gouvernement Militaire de l'Isle de France. Il est borné au septentrion par la Thierache, à l'orient par la Champagne, au midy par le Soissonnois, &amp; à l'occident par le Noyonnois. Ce pays a pris son nom de la Ville de Laon sa Capitale.  (Claude Marin, Dictionnaire universel de la France ancienne et moderne, Paris, Saugrain, Vve J. Saugrain, P. Prault, 1726, t.2, col. 302)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

