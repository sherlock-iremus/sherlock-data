<ccffecb8-8c54-43d4-ba51-4d7013eda4c8> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <e3cb6b89-4985-48d2-a225-c5abf560b4e6> ;
    crm:P141_assigned "Le château de Luynes, situé en Indre-et-Loire, est un château français, qui était au départ une forteresse médiévale édifiée au XIIIe siècle, sur un promontoire rocheux surplombant le val de Loire  (https://fr.wikipedia.org/wiki/Ch%C3%A2teau_de_Luynes - Consulté le 24-06-2020)" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<cd1b8154-af48-41b9-bb7f-c654bd8cd025> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <9f73ac59-5bb3-468a-a6c9-276e6ef6daa2> ;
    crm:P141_assigned "Les communes de Chénehutte et Les Tuffeaux (qui avait déjà fusionné pour former Chênehutte-les-Tuffeaux), Trèves et Cunault (qui avait déjà fusionné pour former Trèves-Cunault) ont fusionné en 1793 pour devenir la commune de Chênehutte-Trèves-Cunault. Cette commune fait maintenant partie de la commune nouvelle de Gennes-Val-de-Loire." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

