<59595a05-32f2-4f1a-913b-8ec3014348aa> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <5e207984-94f9-426a-888a-c893d437dc8b> ;
    crm:P141_assigned "Les Essards est une ancienne commune d'Indre et Loire. Le 1er janvier 2017, elle prend le statut administratif de commune déléguée après avoir été est intégrée à la commune nouvelle de Langeais (cf. https://fr.wikipedia.org/wiki/Les_Essards_(Indre-et-Loire), consultée le 13 septembre 2021)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<595b2d2e-b226-488d-b883-6e13272d08d9> a crm:E13_Attribute_Assignement ;
