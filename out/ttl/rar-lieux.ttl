<5bab6734-6f72-4fed-9946-2ab8dce3bb35> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <6bc56399-0cc4-4936-8214-27c524954c3f> ;
    crm:P141_assigned "La Chapelle-de-Mardore est une ancienne commune française, située dans le département du Rhône en région Rhône-Alpes. Elle est partie intégrante de la commune de Thizy-les-Bourgs depuis le 1er janvier 2013.  (cf. https://fr.wikipedia.org/wiki/La_Chapelle-de-Mardore, consulté le 17 décembre 2020)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<5bb2e913-badf-45cf-b905-7e0fb0704188> a crm:E13_Attribute_Assignement ;
