    crm:P141_assigned "CRCV : Autrèche [Indre-et-Loire, arr. Tours]" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<b0a8365c-83ea-4261-a866-631a5082b711> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <72fc9554-1e8c-422f-95a3-5ef7f7154ebb> ;
    crm:P141_assigned "Cette Ville est sur la petite rivière de Guier, qui sépare le Dauphiné de la Savoye, &amp; la divise en deux : la partie occidentale est de Dauphiné, l'autre est de Savoye.  (Dictionnaire universel de la France ancienne et moderne, Paris, Saugrain père, Vve J. Saugrain, Pierre Prault, 1726, t. 2, col. 1175)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

