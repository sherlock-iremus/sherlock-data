<58a6bdcb-c0b4-403e-925b-a7adfedc861c> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <1fd296ed-67be-4f2b-8965-88d689beb8b9> ;
    crm:P141_assigned "D'après le site internet Des villages de Cassini aux communes d'aujourd'hui, les villages de Saint-Ouen et de l'Aumône constituent déjà la commune de Saint-Ouen l'Aumône en 1801. Ce site mentionne par ailleurs que la commune de Saint-Ouen-l’Aumône s'est appelée l’Aumône-la-Montagne puis Montagne-sur-Oise durant la période révolutionnaire (http://cassini.ehess.fr/cassini/fr/html/fiche.php?select_resultat=33869)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<58b9a369-e533-456b-8ef4-4b31c832ba7c> a crm:E13_Attribute_Assignement ;
