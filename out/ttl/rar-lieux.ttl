<92fbad91-6c0a-4732-9c8e-cc2db667acc3> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <4df71fd8-b9a6-494c-a2e3-e5111685e52f> ;
    crm:P141_assigned "Cuon est une ancienne commune française située dans le département de Maine-et-Loire, en région Pays de la Loire, devenue le 1er janvier 2016, une commune déléguée de la commune nouvelle de Baugé-en-Anjou.  (cf. https://fr.wikipedia.org/wiki/Cuon_(Maine-et-Loire), consulté le 17 décembre 2020)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

