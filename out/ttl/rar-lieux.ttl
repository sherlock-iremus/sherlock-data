<37d2d101-0553-43d2-9102-13e1c1923683> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <cc7310d7-f381-47b7-867b-741930e78e3c> ;
    crm:P141_assigned "D'après le plan de Madrid de 1706 par Nicolas de Fer, le Monastère Saint-Jérôme-le-Royal se situait du côté gauche du Buen Retiro, au sud de la Porte d'Alcalá (cf. Fer, Nicolas de. Madrid, Paris: chez J. F. Benard, 1706)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

