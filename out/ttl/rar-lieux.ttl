<2ca932f7-a6be-4635-9148-a6f9258ea344> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <9a23c7fd-4a46-4a51-a74c-0aa0dcedde4b> ;
    crm:P141_assigned "«Construit par Jules Hardouin-Mansart, premier architecte du roi Louis XIV, à la demande du duc de Noailles, entre 1678 et 1682, cette demeure fut ensuite séparée en deux en 1832 lors de la création de la rue d’Alsace» (cf. <a href= https://www.seine-saintgermain.fr/fr/fiche/4873832/un-pavillon-cache-au-coeur-de-saint-germain-lhotel-de-noailles/  rel= noopener noreferrer  target= _blank >https://www.seine-saintgermain.fr/fr/fiche/4873832/un-pavillon-cache-au-coeur-de-saint-germain-lhotel-de-noailles/</a>, consulté le 19 mars 2021)." ;
