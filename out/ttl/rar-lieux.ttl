<60487e1a-5cb6-4701-ac4f-4eb529543039> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <f2a5c47a-4adf-4882-86d5-30eef1a67fd3> ;
    crm:P141_assigned "Dans la Provence, Diocèse de Carpentras, Parlement &amp; Intendance d'Aix, Viguerie &amp; Recette d'Apt, a 74 habitans. Cette Paroisse est du nombre des Terres adjacentes.  (Claude Marin, Dictionnaire universel de la France ancienne et moderne, Paris, Saugrain père, Vve J. Saugrain, Pierre Prault, 1726, t. 1, col. 232.)" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

