<97fe15f6-93d0-43ec-a4a6-bb4b49225343> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <b97b954a-720f-42c9-bc31-933dd7fa5b89> ;
    crm:P141_assigned "Le château de Salzdahlum, achevé en 1694, a été construit pour Antoine-Ulrich, duc de Brunswick-Lüneburg afin de servir de résidence secondaire. À la fin du XVIII<sup>e </sup>siècle, le château à été petit à petit démantelé. Les terres de l’ancien château sont aujourd’hui celles du «Domäne Salzdahlum» (cf. <a href= https://www.geocaching.com/geocache/GC3BV5M_das-furstliche-lustschloss-zu%20salzdahlum?guid=df703347-cda4-4bfd-b883-4d6fb3dcba12  rel= noopener noreferrer  target= _blank >https://www.geocaching.com/geocache/GC3BV5M_das-furstliche-lustschloss-zu salzdahlum?guid=df703347-cda4-4bfd-b883-4d6fb3dcba12</a>, consulté le 15/04/2021; voir aussi, pour une description du château et de ses différentes pièces: WITTIG, Holger, <em>Das fürstliche LustschloßSalzdahlum, Band 1: Das Schloss und die Sammlungsbauten</em>, Books on Demand GmbH, 2005. ISBN: 3-8334-0591-0). " ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

