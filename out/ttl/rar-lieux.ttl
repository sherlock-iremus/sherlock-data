<d964148b-972c-4656-9059-f4821118242f> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <bed9a96e-0e81-4fac-b5d6-1a1a687effaa> ;
    crm:P141_assigned "Le Gouvernement de Province Militaire de Picardie comprend outre la basse Picardie [Pays reconquis, Boulonois, Ponthieu et le Vimeu], les quatre premiers pays de la haute [Amiénois, Santerre, Vermandois, Thiérarche], &amp; la Province d'Artois. (Claude Marin, Dictionnaire universel de la France ancienne et moderne, Paris, Saugrain, Vve J. Saugrain, P. Prault, 1726, t.2, col. 1120)." ;
