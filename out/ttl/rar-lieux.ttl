<fdd4833d-4825-41ea-91bc-aec1ff43bdcc> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <59e64626-ce7e-461a-a8f5-c53876791787> ;
    crm:P141_assigned "L'Amiral de Rochefort correspond vraisemblablement à l'une des fontaines de cette ville (cf. Viaud, Jean-Théodore. Histoire de la ville et du port de Rochefort. Tome 1. Rochefort :  Honorine Fleury, 1845, p. 431)." ;
