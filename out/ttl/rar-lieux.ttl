<6f5a4e74-3c4e-400b-8ef9-0cdac02919dd> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <0df3162b-7908-4a33-afcc-87aba0517f9d> ;
    crm:P141_assigned "Province de France, partagée dans les deux Gouvernemens militaires de l'Isle de France, &amp; d'Orléanois. [...] La Ville Capitale du Gâtinois François est Nemours, les autres sont Melun, Châteaulandon, Milly &amp; Fontainebleau.  (Claude Marin, Dictionnaire universel de la France ancienne et moderne, Paris, Saugrain, Vve J. Saugrain, P. Prault, 1726, t.2, col. 20-21)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<6f69e97f-fc42-4e3a-9674-d975c4cd1242> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <7b8ce81f-aeb0-41fc-892f-b2aef3ddc742> ;
    crm:P141_assigned "Les communes d'Antoing et de Fontenoy on fusionné en 1977." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<6f849a25-4259-4206-86aa-0574fa7fb6f0> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <9be37f90-1df2-4a02-aa24-4fcf6541c00b> ;
    crm:P141_assigned "Château-du-Loir est une ancienne commune française, située dans le département de la Sarthe en région Pays de la Loire [...]. Elle fait partie [avec Montabon et Vouvray-sur-Loir] de la commune nouvelle de Montval-sur-Loir.  (https://fr.wikipedia.org/wiki/Ch%C3%A2teau-du-Loir)" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<6f8daa51-1efb-4c33-9ec3-44d70ea883dc> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <82875f6f-ba23-48ca-9e66-68a2d7b5ab0a> ;
    crm:P141_assigned "Les terres composant la communauté de la vallée de Lugano, qui constituaient déjà au Moyen Age une entité politico-administrative centrée autour du bourg, passèrent sous la domination suisse en 1512 et devinrent un bailliage commun gouverné par un bailli (landfogto ou capitaine) résidant à Lugano et désigné à tour de rôle par les XII cantons. Nommé pour deux ans, le bailli gérait l'administration et détenait les pouvoirs judiciaires et de police; en cas de guerre, il assumait la charge de commandant de tous les bailliages italiens. Il était assisté par un lieutenant, qu'il nommait lui-même, par un secrétaire baillival, deux fiscaux et deux chanceliers, tous autochtones.   (Dictionnaire historique de la Suisse, https://hls-dhs-dss.ch/fr/articles/008545)" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<6fb708f3-2341-4e3b-922f-2e744f7babc6> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <8cb02c47-f099-4682-bff4-b5b3f2697661> ;
    crm:P141_assigned "Jendure  est une dépendance du Village de l'Isle en Rigault, dans la Paroisse de Ville-sur-Saux  (Claude Marin, Dictionnaire universel de la France ancienne et moderne, Paris, Saugrain, Vve J. Saugrain, P. Prault, 1726, t.3, col. 1079)" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<6fc5c62c-10c5-47c8-ab85-9ff2b0f0ca6d> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <5705733f-53e2-4444-9b0d-300a2802caff> ;
    crm:P141_assigned "Malétable est une ancienne commune française, située dans le département de l'Orne en région Normandie, devenue le 1er janvier 2016 une commune déléguée au sein de la commune nouvelle de Longny les Villages.  (cf. https://fr.wikipedia.org/wiki/Mal%C3%A9table, consulté le 17 décembre 2020)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<7002eda9-3e65-4cb1-9426-461b82ba7986> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <9f290934-3365-494d-8951-b8ac9d5dbfa6> ;
    crm:P141_assigned "Le château Saint-Georges (Castel San Giorgio en italien) est la partie ancienne fortifiée de ce qui constitue le palazzo Ducale de Mantoue." ;
