<08d14e04-0eb1-4185-a2f2-bf02b07d3529> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <c4e33082-3589-40db-90ee-2bff8094ac0a> ;
    crm:P141_assigned "Mercurol-Veaunes est une commune nouvelle située dans le département de la Drôme, en région Auvergne-Rhône-Alpes, qui a été créée le 1er janvier 2016. Elle comprend une commune déléguée : Veaunes. Le siège de cette nouvelle collectivité se trouve dans l'ancienne commune de Mercurol.  (https://fr.wikipedia.org/wiki/Mercurol-Veaunes, consulté le 17 décembre 2020)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<0939bc26-e6ee-405c-98f6-67336e23944b> a crm:E13_Attribute_Assignement ;
