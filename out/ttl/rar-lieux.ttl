<aff73aef-0961-4a23-9b6e-9ac1261a5051> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <99314d0e-0fe0-4fa5-be01-0f339ba93750> ;
    crm:P141_assigned " Collonges-lès-Premières est une ancienne commune française située dans le département de la Côte-d'Or en région Bourgogne-Franche-Comté  (cf. https://fr.wikipedia.org/wiki/Collonges-lès-Premières, consulté le 16 février 2021). Elle a fusionné le 28 février 2019 avec la commune de Premières pour former la commune nouvelle de Collonges-et-Premières.<span style= color: rgb(51, 51, 51); >" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<b0240b4d-44d3-4921-bb31-f9765a5f2e44> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <fa6c9a38-2a69-4911-83c0-0beb32909b1c> ;
    crm:P141_assigned "Le site internet Des villages de Cassini aux communes d'aujourd'hui mentionne que la commune de Mérindol est devenue Mérindol-les-Oliviers en 1920 (http://cassini.ehess.fr/cassini/fr/html/fiche.php?select_resultat=22095)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<b0372d24-1a3a-48e6-8cbe-6fde368adc81> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <f8ace2a4-b1c5-4de9-8724-7c165ccbd449> ;
    crm:P141_assigned "Province, bornée par le Comté de Flandres, le Hainaut &amp; le Cambrésis à l'orient, &amp; par la Picardie à l'occident &amp; au midi.  [...] L'Artois peut avoir treize lieuës dans sa plus grande étenduë, du septentrion au midi, &amp; dix-huit de l'orient à l'occident. La Flandre Françoise le borne au septentrion, la Picardie au midi, &amp; à l'occident, &amp; le Haynaut François avec le Cambrésis, à l'orient. [...] La Province d'Artois est unie à la Lieutenance générale du Gouvernement militaire de la Province de Picardie [...] Les Villes les plus considérables après Arras, sont S. Omer, Evêché Suffragant de Cambray, Aire, Béthune, Hesdin &amp; Bapaume, toutes très-fortes.  Claude Marin, Dictionnaire universel de la France ancienne et moderne, Paris, Saugrain, Vve J. Saugrain, P. Prault, 1726, t.1, col. 175-176)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<b06ac685-b243-48e1-8896-e40f687f878f> a crm:E13_Attribute_Assignement ;
