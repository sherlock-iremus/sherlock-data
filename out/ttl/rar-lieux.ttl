<94bbf096-f377-4944-91db-9d2aba776997> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <912751a9-efee-4a04-84ec-fb87c363bd17> ;
    crm:P141_assigned "Dans le site internet Des villages de Cassini aux communes d'aujourd'hui, il est mentionné le fait que le village de Saint-Aignan devient Saint-Aignan-de-Couptrain en 1953. Il n'est néanmoins pas précisé que sous l'Ancien Régime ce village s’appelait Saint-Aignan-en-Lassay. (http://cassini.ehess.fr/cassini/fr/html/fiche.php?select_resultat=30256)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<951efc0e-044e-4f83-abc2-09ea4ec10607> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <e5973d9f-5cc1-47f0-a953-a2ef10e08e3d> ;
    crm:P141_assigned " En octobre 1915, la commune a été supprimée et les deux communes (Taverny et maintenant Saint-Leu-la-Forêt) constituantes ont été rétablies.  (cf. https://fr.wikipedia.org/wiki/Saint-Leu-Taverny, consulté le 28 juin 2021)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<958fa303-2894-41f0-b2ee-ceeaa3b9454a> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <b66b91cd-8fdc-4b77-81e0-16e3b8e6c3eb> ;
    crm:P141_assigned "Le Bourg d'Alise est plus souvent connu sous le nom de sainte Reine, à cause de la dévotion que l'on a pour cette Sainte, qui a souffert le martyre.  (Claude Marin, Dictionnaire universel de la France ancienne et moderne, Paris, Saugrain, Vve J. Saugrain, P. Prault, 1726, t.1, col. 67)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<959da8d3-58c5-45f0-bcb7-edc031409395> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <cf591aba-6e77-4296-ab54-1dd1426c53c7> ;
    crm:P141_assigned "CRCV : Agde [Hérault, ch.-l. cant.]" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
