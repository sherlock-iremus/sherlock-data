<03c43033-99a9-452b-96fe-0e08961445b2> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <14010c9a-e85b-46fd-a732-4b2e623baf85> ;
    crm:P141_assigned "CRCV :  Saint-Jean-d'Angély [Charente-Maritime, ch.-l. cant.]" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<03c68987-23b5-45ba-af70-ec5a89864fc5> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <f2db4d87-32ab-448a-a527-604b9a031125> ;
    crm:P141_assigned "Point d'origine de la ville moderne, le château domine la vallée de la Marne. Construit à partir du IXe siècle, il a été profondément remanié au fil du temps. Aujourd'hui, le vieux château est un lieu de promenade et héberge un spectacle de fauconnerie.  (https://fr.wikipedia.org/wiki/Ch%C3%A2teau-Thierry#Le_ch%C3%A2teau - Consulté le 02-06-2020).  La porte Saint-Jean servait autrefois d'entrée principale au château de Château-Thierry.  (https://fr.wikipedia.org/wiki/Porte_Saint-Jean_%28Ch%C3%A2teau-Thierry%29 - Consulté le 02-06-2020)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<03cf47eb-80d3-4ffc-a200-4ec8142f12cf> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <a6e58eba-17cd-48a1-8f0f-f1ee2d2b7a74> ;
    crm:P141_assigned "Boscherville est aujourd'hui un quartier de Grand-Bourgtheroulde" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<03e538ad-2919-4261-938f-6b6dba52c36f> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <627331c3-828e-48b3-8a6b-12300c9bdd50> ;
    crm:P141_assigned "Bussy-la-Côte est une commune associée du département de la Meuse, en région Grand Est. […] Le 1er janvier 1973, Mussey devient Val-d'Ornain à la suite de sa fusion-association avec Bussy-la-Côte et Varney.  (cf. https://fr.wikipedia.org/wiki/Bussy-la-C%C3%B4te, consulté le 4 mars 2021)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<03ea5cd9-e6df-4678-b2d9-1748c9a41c09> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <2effaa00-1c84-44bb-ba88-b0e64bcd53b3> ;
    crm:P141_assigned "Bauquay (parfois orthographié Beauquay) est une ancienne commune française, située dans le Bocage virois et dans le département du Calvados en région Normandie, peuplée de 296 habitants.   (cf. https://fr.wikipedia.org/wiki/Bauquay, consulté le 15 janvier 2021). Depuis le 1er janvier 2017, elle est une des sept communes déléguées de la commune nouvelle des Monts d'Aunay. (cf. https://fr.wikipedia.org/wiki/Les_Monts_d%27Aunay, consulté le 15 janvier 2021)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<0413be48-8522-4720-aa0c-e19505197b9b> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <fec3c521-6e63-49a1-b443-f7e427544340> ;
    crm:P141_assigned "En 1685, Louis XIV décide la construction d'une nouvelle cathédrale pour affirmer son pouvoir et marquer la victoire sur la religion réformée. Henri de Nesmond, évêque de Montauban, choisit en 1691 l'emplacement de la place des Monges. Plusieurs îlots de maisons sont alors détruits pour accueillir le nouvel édifice, dont la première pierre est posée le 10 avril 1692 (source : centre du patrimoine de Montauban)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

