<5408f02b-ea7a-4d84-96a9-bb44088e3f4e> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <edf438c7-7c41-49f3-a254-098a14aa93c9> ;
    crm:P141_assigned "Vexin-sur-Epte est une commune nouvelle française, constituée le 1er janvier 2016, par quatorze communes membres de la communauté de communes Epte-Vexin-Seine situées dans le département de l'Eure en région Normandie.  (cf. https://fr.wikipedia.org/wiki/Vexin-sur-Epte, consulté le 5 octobre 2021)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<541e8128-8a7d-437c-b135-8ef15c4b3b8a> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <5c1c02fa-d30d-44d3-8cb7-ee35f0ed3ec0> ;
    crm:P141_assigned "Située sur le territoire géographique du cercle de Franconie, Nuremberg était une ville libre d’Empire, c’est-à-dire une ville autonome du Saint-Empire romain directement subordonnée à l'empereur et non à un prince d'Empire, grâce à l'immédiateté impériale." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<54200766-cba7-4641-8acc-b47749681692> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <be86d45f-8196-4b5e-b44c-00a204b6803f> ;
    crm:P141_assigned "Canton de la Confédération de 1501 à 1798 et depuis 1803, de la République helvétique de 1798 à 1803.  (Dictionnaire historique de la Suisse, https://hls-dhs-dss.ch/fr/articles/007388/)" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<542a3492-44f3-4bb7-b36b-2ddd520afc80> a crm:E13_Attribute_Assignement ;
