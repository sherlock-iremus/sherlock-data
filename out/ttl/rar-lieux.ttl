<62ab680a-33cf-4d42-8b50-326616d02276> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <fca3ae91-a5d7-4b5e-b87d-381802824746> ;
    crm:P141_assigned "<strong style= color: rgb(0, 0, 0); >Saint-Jean-du-Corail</strong>est une ancienne<a href= https://fr.wikipedia.org/wiki/Commune_(France)  rel= noopener noreferrer  target= _blank  style= color: var(--accent-color)  ; >commune française</a>, située dans le<a href= https://fr.wikipedia.org/wiki/D%C3%A9partement_fran%C3%A7ais  rel= noopener noreferrer  target= _blank  style= color: var(--accent-color)  ; >département</a>de la<a href= https://fr.wikipedia.org/wiki/Manche_(d%C3%A9partement)  rel= noopener noreferrer  target= _blank  style= color: var(--accent-color)  ; >Manche</a>en<a href= https://fr.wikipedia.org/wiki/R%C3%A9gion_fran%C3%A7aise  rel= noopener noreferrer  target= _blank  style= color: var(--accent-color)  ; >région</a><a href= https://fr.wikipedia.org/wiki/Normandie_(r%C3%A9gion_administrative)  rel= noopener noreferrer  target= _blank  style= color: var(--accent-color)  ; >Normandie</a>, devenue le1<sup>er</sup>janvier 2016une<a href= https://fr.wikipedia.org/wiki/Commune_d%C3%A9l%C3%A9gu%C3%A9e  rel= noopener noreferrer  target= _blank  style= color: var(--accent-color)  ; >commune déléguée</a>au sein de la<a href= https://fr.wikipedia.org/wiki/Commune_nouvelle  rel= noopener noreferrer  target= _blank  style= color: var(--accent-color)  ; >commune nouvelle</a>de<a href= https://fr.wikipedia.org/wiki/Mortain-Bocage  rel= noopener noreferrer  target= _blank  style= color: var(--accent-color)  ; >Mortain-Bocage</a>.  (cf. https://fr.wikipedia.org/wiki/Saint-Jean-du-Corail, consulté le 2 avril 2021)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<62ae6c5f-fa43-4bd2-9dc9-5067efeb6272> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <b62cbb82-659e-4406-880c-be56378a71b8> ;
    crm:P141_assigned "Le château des Ducs, logis des Ducs ou Grand Logis, est un édifice situé à Argentan, en France. Il est aujourd'hui le palais de justice de la vielle d'Argentan (https://fr.wikipedia.org/wiki/Ch%C3%A2teau_des_Ducs_(Argentan)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<62d580bc-1cc1-4d7b-b367-d64dd78efdaf> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <449e6dad-28cf-4102-bf53-0f58306b31f8> ;
    crm:P141_assigned "Saint-Hilaire (ou Saint-Hilaire-de-Barbezieux) est une commune associée à Barbezieux, dans le département de la Charente (région Nouvelle-Aquitaine). [...] Saint-Hilaire est située dans le sud-ouest du département de la Charente, à 2 km au sud-ouest de Barbezieux et à 33 km au sud-ouest d'Angoulême. Elle a été associée à Barbezieux le 1er janvier 1973 par arrêté préfectoral du 4 décembre 1972.   (cf. https://fr.wikipedia.org/wiki/Saint-Hilaire_(Charente), consulté le 5 mai 2021)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<630c2e89-8668-4f96-a2a4-5b46a00c9264> a crm:E13_Attribute_Assignement ;
