<dba53a88-c6a9-432f-bf9e-00c8e04c08ea> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <bbade45d-86aa-414a-8dfd-b675a86c60f3> ;
    crm:P141_assigned "Le 1er janvier 2019, la commune [de Montlaur] fusionne avec Pradelles-en-Val pour former la commune nouvelle de Val-de-Dagne dont la création est actée par arrêté du préfet de l'Aude en date du 5 décembre 2018 . (https://fr.wikipedia.org/wiki/Montlaur_(Aude), consulté le 11 décembre 2020)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<dbaccb52-9801-4154-ae64-bd85d624385a> a crm:E13_Attribute_Assignement ;
