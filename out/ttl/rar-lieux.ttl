<74249ebd-af4f-4af5-a4a4-98dcea66c128> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <3c67c462-989b-4c32-955c-6160f52fe490> ;
    crm:P141_assigned "Allié des Confédérés en 1352 et, après un retour passager sous la domination habsbourgeoise, canton de la Confédération dès 1388 environ. Partie du canton de la Linth sous la République helvétique (1798-1803), puis à nouveau canton suisse.   (Dictionnaire historique de la Suisse, https://hls-dhs-dss.ch/fr/articles/007374/)" ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

