<35e8b846-feb5-4976-990f-f085011ec8dd> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <9b2799d3-bb58-4d4c-b047-637496d9984b> ;
    crm:P141_assigned "Vaulandry est une commune déléguée française, située dans le département de Maine-et-Loire, en région Pays de la Loire Le 1er janvier 2013, Vaulandry fusionne avec Clefs pour former la commune nouvelle de Clefs-Val d'Anjou, dont elle est une commune déléguée. Le 1er janvier 2016, Clefs et Vaulandry fusionnent avec d'autres communes, pour former la commune nouvelle de Baugé-en-Anjou dont elles constituent depuis cette date des communes déléguées.   (cf. https://fr.wikipedia.org/wiki/Vaulandry, consulté le 17 décembre 2020)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

