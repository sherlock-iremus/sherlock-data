<0f88158c-e675-46f9-b765-c0758cb8ec17> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <476dba34-22ce-4096-9e81-7c71baa0e9d4> ;
    crm:P141_assigned "Marennes-Hiers-Brouage est une commune nouvelle du sud-ouest de la France, située dans le département de la Charente-Maritime en région Nouvelle-Aquitaine, créée le 1ᵉʳ janvier 2019. Elle résulte de la fusion des anciennes communes de Marennes et de Hiers-Brouage (https://fr.wikipedia.org/wiki/Marennes-Hiers-Brouage, consulté le 27 novembre 2020)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

