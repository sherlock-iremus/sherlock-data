<84747a1b-5252-45d0-b073-b26632d8e6f8> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <588d8f4e-f07c-49e7-b7a7-790facc9be0f> ;
    crm:P141_assigned "Le quartier de Bury est situé sur le territoire de l'actuelle commune de Molineuf (ou Saint-Secondin, le village ayant porté alternativement ces deux noms). Molineuf est une des communes déléguées de la commune nouvelle de Valencisse." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<847e22db-317a-46e9-aaa7-26a276590699> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <c660dddd-6d7d-41fd-b162-91f05b196b64> ;
    crm:P141_assigned "Le couvent de l'Oratoire du Louvre était situé rue Saint-Honoré - 1er arrondissement, à la hauteur de la rue de l'Oratoire  (cf. http://www.francegenweb.org/wiki/index.php?title=Couvent_de_l%27Oratoire_du_Louvre, consulté le 4 juin 2021)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

<849ee2f6-f2ec-4445-a85d-1ef632c021e1> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <26e0c898-0139-47f6-8975-8e58ba53ffb4> ;
    crm:P141_assigned "Mâconois ou Masconois, Masticonensis Pagus, Pays de Bourgogne, dont Mâcon est la Capitale ; il est situé le long de la Saône, &amp; borné au septentrion par le Châlonois ; à l'orient par la Bresse, au midy par le Beaujolois, &amp; à l'occident par le Charolois. [...] Les Villes principales du Mâconois sont Mâcon, S. Genoux, Cluny &amp; Tournus. (Claude Marin, Dictionnaire universel de la France ancienne et moderne, Paris, Saugrain, Vve J. Saugrain, P. Prault, 1726, t.1, col. 434-435)." ;
    crm:P14_carried_out_by <684b4c1a-be76-474c-810e-0f5984b47921> ;
    crm:P177_assigned_property_type crm:P3_has_note .

