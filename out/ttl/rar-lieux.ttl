<d0d59de4-16df-4d1d-bcb8-6e9694c221d9> a crm:E13_Attribute_Assignement ;
    crm:P140_assigned_attribute_to <65d2750c-9159-4ef0-a93e-0265e586435e> ;
    crm:P141_assigned "Le site internet Des villages de Cassini aux communes d'aujourd'hui mentionne que la commune de Montbonnot fusionne avec Saint-Martin-de-Miséré en 1851 et prend alors le nom de Montbonnot-Saint-Martin (http://http://cassini.ehess.fr/cassini/fr/html/fiche.php?select_resultat=23211)." ;
