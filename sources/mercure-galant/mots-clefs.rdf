	<dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2022-03-28</dcterms:modified>
	<dcterms:identifier>55b60125-f11e-4590-8b0f-d7e0c4a14e1c</dcterms:identifier>
	<dcterms:description>a8f39a9d-66cb-445d-9245-ae8d1bbba335##96c40443-9b54-440e-a7a9-efff530f61c3##cfe660d5-2ffb-4018-ad22-b797f63fccb5##d5cf4746-1005-4d42-8520-a26aa4cd5f01##55b60125-f11e-4590-8b0f-d7e0c4a14e1c</dcterms:description>
	<dcterms:creator>tbottini</dcterms:creator>
	<dcterms:contributor>tbottini</dcterms:contributor>
	<skos:historyNote xml:lang="fr">D'après le Littré (1872-1877) : 1. Présent considérable, donné sous la forme d'un autre qui l'est beaucoup moins. 2. Fête en usage parmi les Espagnols (5 décembre) ; consiste à faire à ses amis des présents, sans qu'ils sachent d'où ils leur viennent.</skos:historyNote>
</rdf:Description>

