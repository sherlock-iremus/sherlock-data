	<skos:prefLabel xml:lang="fr">Sapate</skos:prefLabel>
	<skos:broader rdf:resource="https://opentheso.huma-num.fr/opentheso/?idc=d5cf4746-1005-4d42-8520-a26aa4cd5f01&amp;idt=th317"/>
