	<skos:prefLabel xml:lang="fr">Ode (genre poétique)</skos:prefLabel>
	<skos:broader rdf:resource="https://opentheso.huma-num.fr/opentheso/?idc=753dc9e2-d7a8-4151-bea9-d64547ebb664&amp;idt=th317"/>
